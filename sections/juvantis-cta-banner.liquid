{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #CTABanner-{{ section.id }} {
    background: linear-gradient(135deg, #4ea1d9 0%, #73c25e 100%);
    color: #fcfcfc;
  }

  #CTABanner-{{ section.id }} .cta-banner__wrapper {
    text-align: center;
    max-width: 72rem;
    margin: 0 auto;
  }

  #CTABanner-{{ section.id }} .cta-banner__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.6rem;
    color: #fcfcfc;
  }

  @media screen and (min-width: 750px) {
    #CTABanner-{{ section.id }} .cta-banner__heading {
      font-size: 4.4rem;
    }
  }

  #CTABanner-{{ section.id }} .cta-banner__text {
    font-size: 1.6rem;
    line-height: 1.6;
    margin-bottom: 3.2rem;
    opacity: 0.9;
    color: #fcfcfc;
  }

  #CTABanner-{{ section.id }} .cta-banner__button {
    display: inline-block;
    padding: 1.6rem 4rem;
    background: #fcfcfc;
    color: #020912;
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.3s ease, transform 0.2s ease;
    border: none;
    cursor: pointer;
    letter-spacing: 0.05rem;
  }

  #CTABanner-{{ section.id }} .cta-banner__button:hover {
    opacity: 0.9;
    transform: translateY(-0.1rem);
  }

  {%- if section.settings.secondary_button_label != blank -%}
    #CTABanner-{{ section.id }} .cta-banner__secondary {
      display: inline-block;
      padding: 1.6rem 3.2rem;
      background: transparent;
      color: #fcfcfc;
      font-family: var(--font-heading-family);
      font-size: 1.6rem;
      font-weight: 600;
      text-decoration: none;
      border: 0.2rem solid #fcfcfc;
      margin-left: 1.6rem;
      transition: background 0.3s ease;
      cursor: pointer;
    }

    #CTABanner-{{ section.id }} .cta-banner__secondary:hover {
      background: rgba(252, 252, 252, 0.15);
    }
  {%- endif -%}

  #CTABanner-{{ section.id }} .cta-banner__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    justify-content: center;
  }
{%- endstyle -%}

<div
  id="CTABanner-{{ section.id }}"
>
  <div class="page-width section-{{ section.id }}-padding">
    <div class="cta-banner__wrapper">
      {%- if section.settings.heading != blank -%}
        <h2 class="cta-banner__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="cta-banner__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}
      <div class="cta-banner__buttons">
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="cta-banner__button"
          >
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_button_label != blank -%}
          <a
            {% if section.settings.secondary_button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.secondary_button_link }}"
            {% endif %}
            class="cta-banner__secondary"
          >
            {{- section.settings.secondary_button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Juvantis CTA Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Bereit f\u00fcr deine Health-Transformation?",
      "label": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Starte noch heute mit deinem Digital Health Twin und verstehe deine Gesundheit wie nie zuvor.",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Jetzt kostenlos starten",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Zweiter Button Text (optional)"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Zweiter Button Link"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Juvantis CTA Banner"
    }
  ]
}
{% endschema %}
