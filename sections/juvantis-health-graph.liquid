{%- comment -%}
  Juvantis Section: Health Graph (D3.js Knowledge Graph)
  Zweck: Interaktiver medizinischer Knowledge Graph als Fullscreen-iframe
  Erstellt: 2026-04-05
{%- endcomment -%}

{%- if template.suffix == 'health-graph' -%}

{%- style -%}
  .section-header,
  .header-wrapper,
  header.header,
  .announcement-bar,
  footer.footer,
  .footer,
  .shopify-section-group-footer-group,
  .shopify-section-group-header-group { display: none !important; }
  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }
  main#MainContent { padding: 0 !important; margin: 0 !important; }
  body { overflow: hidden !important; }

  .jv-hg-frame {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    border: none;
    z-index: 999;
    background: #0A0F1A;
  }
{%- endstyle -%}

<iframe
  class="jv-hg-frame"
  src="{{ 'health-graph.html' | asset_url }}"
  title="Juvantis Health Graph"
  allow="fullscreen"
  loading="eager"
></iframe>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Health Graph",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand unten" }
  ],
  "presets": [{ "name": "Juvantis: Health Graph" }]
}
{% endschema %}
