{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PartnerPraxis-{{ section.id }} .partner__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__heading {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .partner__heading {
      font-size: 4.8rem;
    }
  }

  #PartnerPraxis-{{ section.id }} .partner__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 100rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .partner__content {
      grid-template-columns: 1fr 1fr;
    }
  }

  #PartnerPraxis-{{ section.id }} .partner__image-wrapper {
    text-align: center;
  }

  #PartnerPraxis-{{ section.id }} .partner__image-wrapper img {
    max-width: 100%;
    height: auto;
  }

  #PartnerPraxis-{{ section.id }} .partner__placeholder {
    background: rgba(var(--color-foreground), 0.04);
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding: 6rem 3rem;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    color: rgba(var(--color-foreground), 0.3);
  }

  #PartnerPraxis-{{ section.id }} .partner__info {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__name {
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__specialty {
    font-size: 1.6rem;
    color: rgb(var(--color-button));
    font-weight: 500;
    margin-bottom: 0.8rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__doctors {
    font-size: 1.5rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
  }

  #PartnerPraxis-{{ section.id }} .partner__detail {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__detail-icon {
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }

  #PartnerPraxis-{{ section.id }} .partner__languages {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__lang-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    font-size: 1.2rem;
    font-weight: 600;
    font-family: var(--font-heading-family);
    background: rgba(var(--color-button), 0.1);
    color: rgb(var(--color-button));
    letter-spacing: 0.05rem;
  }

  #PartnerPraxis-{{ section.id }} .partner__cta {
    margin-top: 1.2rem;
  }
{%- endstyle -%}

<div
  id="PartnerPraxis-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    {%- if section.settings.heading != blank -%}
      <div class="partner__header">
        <h2 class="partner__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="partner__content">
      <div class="partner__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '300, 500, 800',
              sizes: '(min-width: 750px) 400px, 100vw'
          }}
        {%- else -%}
          <div class="partner__placeholder">
            GP Medical Center Westend
          </div>
        {%- endif -%}
      </div>

      <div class="partner__info">
        {%- if section.settings.practice_name != blank -%}
          <h3 class="partner__name">{{ section.settings.practice_name | escape }}</h3>
        {%- endif -%}

        {%- if section.settings.specialty != blank -%}
          <p class="partner__specialty">{{ section.settings.specialty | escape }}</p>
        {%- endif -%}

        {%- if section.settings.doctors != blank -%}
          <div class="partner__doctors">{{ section.settings.doctors }}</div>
        {%- endif -%}

        {%- if section.settings.address != blank -%}
          <div class="partner__detail">
            <span class="partner__detail-icon">&#128205;</span>
            <span>{{ section.settings.address | escape }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.phone != blank -%}
          <div class="partner__detail">
            <span class="partner__detail-icon">&#128222;</span>
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" style="color: inherit; text-decoration: none;">
              {{ section.settings.phone | escape }}
            </a>
          </div>
        {%- endif -%}

        {%- if section.settings.languages != blank -%}
          <div class="partner__detail">
            <span class="partner__detail-icon">&#127760;</span>
            <div class="partner__languages">
              {%- assign langs = section.settings.languages | split: ',' -%}
              {%- for lang in langs -%}
                <span class="partner__lang-badge">{{ lang | strip | escape }}</span>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="partner__cta">
            <a
              {% if section.settings.button_link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ section.settings.button_link }}"
              {% endif %}
              class="button button--primary"
            >
              {{- section.settings.button_label | escape -}}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Juvantis Partnerpraxis",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Unsere Partnerpraxis",
      "label": "Überschrift"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Praxis-Bild oder Logo"
    },
    {
      "type": "text",
      "id": "practice_name",
      "default": "GP Medical Center Westend",
      "label": "Praxisname"
    },
    {
      "type": "text",
      "id": "specialty",
      "default": "Hausärztliche und Innere Medizin im Herzen Frankfurts",
      "label": "Fachrichtung / Beschreibung"
    },
    {
      "type": "richtext",
      "id": "doctors",
      "default": "<p>Dr. med. Siegbert Stracke, MBA<br>Docteur en m\u00e9d. Sonja Saul</p>",
      "label": "Ärzte"
    },
    {
      "type": "text",
      "id": "address",
      "default": "Grüneburgweg 12, 60322 Frankfurt am Main",
      "label": "Adresse"
    },
    {
      "type": "text",
      "id": "phone",
      "default": "069-247 574 523",
      "label": "Telefon"
    },
    {
      "type": "text",
      "id": "languages",
      "default": "DE, EN, FR, ES",
      "label": "Sprachen (kommagetrennt)"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Zur Partnerpraxis",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "default": "/pages/partnerpraxis",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-1",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Juvantis Partnerpraxis"
    }
  ]
}
{% endschema %}

