{%- style -%}
  /* ===== BASE PADDING ===== */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ===== SCROLL REVEAL ANIMATION ===== */
  @keyframes pp-reveal {
    from { opacity: 0; transform: translateY(2.4rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @supports (animation-timeline: view()) {
    #PP-{{ section.id }} .pp-animate {
      animation: pp-reveal linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 25%;
    }
  }
  @supports not (animation-timeline: view()) {
    #PP-{{ section.id }} .pp-animate {
      animation: pp-reveal 0.6s ease both;
    }
    #PP-{{ section.id }} .pp-animate:nth-child(2) { animation-delay: 0.1s; }
    #PP-{{ section.id }} .pp-animate:nth-child(3) { animation-delay: 0.2s; }
    #PP-{{ section.id }} .pp-animate:nth-child(4) { animation-delay: 0.3s; }
    #PP-{{ section.id }} .pp-animate:nth-child(5) { animation-delay: 0.35s; }
    #PP-{{ section.id }} .pp-animate:nth-child(6) { animation-delay: 0.4s; }
  }

  /* ===== HERO HEADER ===== */
  #PP-{{ section.id }} .pp-hero {
    text-align: center;
    max-width: 80rem;
    margin: 0 auto 6rem;
    position: relative;
  }
  #PP-{{ section.id }} .pp-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.8rem;
    background: linear-gradient(135deg, rgba(78,161,217,0.10) 0%, rgba(115,194,94,0.10) 100%);
    border: 0.1rem solid rgba(78,161,217,0.2);
    border-radius: 10rem;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    color: #4ea1d9;
    margin-bottom: 2rem;
  }
  #PP-{{ section.id }} .pp-hero__badge svg {
    width: 1.4rem; height: 1.4rem; fill: #4ea1d9;
  }
  #PP-{{ section.id }} .pp-hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.2rem;
  }
  #PP-{{ section.id }} .pp-hero__heading span {
    background: linear-gradient(135deg, #4ea1d9 0%, #73c25e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  #PP-{{ section.id }} .pp-hero__subtitle {
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
    max-width: 60rem;
    margin: 0 auto 1.6rem;
  }
  #PP-{{ section.id }} .pp-hero__desc {
    font-size: 1.5rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.55);
    max-width: 56rem;
    margin: 0 auto 2rem;
  }
  #PP-{{ section.id }} .pp-hero__langs {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 2.4rem;
    flex-wrap: wrap;
  }
  #PP-{{ section.id }} .pp-lang-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.4rem;
    background: rgba(var(--color-foreground), 0.04);
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 10rem;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.02rem;
    color: rgba(var(--color-foreground), 0.7);
    transition: all 0.25s ease;
  }
  #PP-{{ section.id }} .pp-lang-pill:hover {
    background: rgba(78,161,217,0.08);
    border-color: rgba(78,161,217,0.2);
    color: #4ea1d9;
  }
  #PP-{{ section.id }} .pp-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.6rem 4rem;
    background: linear-gradient(135deg, #4ea1d9 0%, #73c25e 100%);
    color: #fff;
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.03rem;
    border-radius: 1.2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 0.4rem 2rem rgba(78,161,217,0.25);
  }
  #PP-{{ section.id }} .pp-hero__cta:hover {
    transform: translateY(-0.2rem);
    box-shadow: 0 0.8rem 3.2rem rgba(78,161,217,0.35);
  }
  #PP-{{ section.id }} .pp-hero__cta svg {
    width: 1.8rem; height: 1.8rem; fill: currentColor;
    transition: transform 0.3s ease;
  }
  #PP-{{ section.id }} .pp-hero__cta:hover svg {
    transform: translateX(0.3rem);
  }

  /* ===== DIVIDER ===== */
  #PP-{{ section.id }} .pp-divider {
    width: 6rem;
    height: 0.3rem;
    background: linear-gradient(90deg, #4ea1d9, #73c25e);
    border-radius: 0.2rem;
    margin: 0 auto;
  }

  /* ===== SECTION HEADERS ===== */
  #PP-{{ section.id }} .pp-section-header {
    text-align: center;
    margin: 8rem auto 4rem;
    max-width: 70rem;
  }
  #PP-{{ section.id }} .pp-section-header__label {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    color: #4ea1d9;
    margin-bottom: 1.2rem;
  }
  #PP-{{ section.id }} .pp-section-header__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.6rem, 4vw, 4rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }
  #PP-{{ section.id }} .pp-section-header__desc {
    font-size: 1.5rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.6);
    max-width: 54rem;
    margin: 0 auto;
  }

  /* ===== TEAM CARDS ===== */
  #PP-{{ section.id }} .pp-team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  #PP-{{ section.id }} .pp-doctor-card {
    position: relative;
    background: rgb(var(--color-background));
    border-radius: 2rem;
    padding: 3.6rem 3.2rem 3.2rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.06);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    overflow: hidden;
  }
  #PP-{{ section.id }} .pp-doctor-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 0.4rem;
    background: linear-gradient(90deg, #4ea1d9, #73c25e);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  #PP-{{ section.id }} .pp-doctor-card:hover {
    transform: translateY(-0.4rem);
    box-shadow: 0 2rem 5rem rgba(var(--color-foreground), 0.08);
  }
  #PP-{{ section.id }} .pp-doctor-card:hover::before {
    opacity: 1;
  }
  #PP-{{ section.id }} .pp-doctor-card__top {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  #PP-{{ section.id }} .pp-doctor-card__avatar {
    flex-shrink: 0;
    width: 7.2rem;
    height: 7.2rem;
    border-radius: 1.6rem;
    background: linear-gradient(135deg, rgba(78,161,217,0.12) 0%, rgba(115,194,94,0.12) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    font-weight: 700;
    color: #4ea1d9;
    letter-spacing: -0.02em;
  }
  #PP-{{ section.id }} .pp-doctor-card__meta {
    flex: 1;
    min-width: 0;
  }
  #PP-{{ section.id }} .pp-doctor-card__name {
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }
  #PP-{{ section.id }} .pp-doctor-card__title {
    font-size: 1.4rem;
    font-weight: 500;
    color: #4ea1d9;
    margin-bottom: 1.2rem;
  }
  #PP-{{ section.id }} .pp-doctor-card__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  #PP-{{ section.id }} .pp-cred-pill {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(var(--color-foreground), 0.04);
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.6rem;
    font-size: 1.15rem;
    font-weight: 500;
    color: rgba(var(--color-foreground), 0.65);
    line-height: 1.4;
  }
  #PP-{{ section.id }} .pp-doctor-card__bio {
    font-size: 1.45rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    margin-bottom: 2rem;
  }

  /* CV accordion */
  #PP-{{ section.id }} .pp-cv-accordion {
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    padding-top: 1.6rem;
  }
  #PP-{{ section.id }} .pp-cv-accordion summary {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-heading-family);
    font-size: 1.35rem;
    font-weight: 600;
    cursor: pointer;
    color: rgba(var(--color-foreground), 0.8);
    list-style: none;
    padding: 0.8rem 0;
    transition: color 0.25s ease;
  }
  #PP-{{ section.id }} .pp-cv-accordion summary::marker,
  #PP-{{ section.id }} .pp-cv-accordion summary::-webkit-details-marker { display: none; }
  #PP-{{ section.id }} .pp-cv-accordion summary:hover { color: #4ea1d9; }
  #PP-{{ section.id }} .pp-cv-accordion summary svg {
    width: 1.6rem; height: 1.6rem;
    fill: currentColor;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  #PP-{{ section.id }} .pp-cv-accordion[open] summary svg {
    transform: rotate(180deg);
  }
  #PP-{{ section.id }} .pp-cv-section {
    margin-top: 1.6rem;
    padding-left: 0.4rem;
  }
  #PP-{{ section.id }} .pp-cv-section__label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 0.8rem;
  }
  #PP-{{ section.id }} .pp-cv-section__label svg {
    width: 1.3rem; height: 1.3rem; fill: currentColor;
  }
  #PP-{{ section.id }} .pp-cv-section__content {
    font-size: 1.3rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.6);
    padding-left: 0.8rem;
    border-left: 0.2rem solid rgba(78,161,217,0.15);
  }
  #PP-{{ section.id }} .pp-cv-section__content p { margin: 0.35rem 0; }

  /* ===== SERVICES BENTO GRID ===== */
  #PP-{{ section.id }} .pp-svc-category { margin-bottom: 4rem; }
  #PP-{{ section.id }} .pp-svc-category:last-child { margin-bottom: 0; }
  #PP-{{ section.id }} .pp-svc-cat-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 0.2rem solid rgba(78,161,217,0.15);
    color: rgba(var(--color-foreground), 0.85);
  }
  #PP-{{ section.id }} .pp-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-bento {
      grid-template-columns: repeat(2, 1fr);
    }
    #PP-{{ section.id }} .pp-bento-card--featured {
      grid-column: span 2;
    }
  }
  @media screen and (min-width: 990px) {
    #PP-{{ section.id }} .pp-bento {
      grid-template-columns: repeat(auto-fit, minmax(min(26rem, 100%), 1fr));
    }
    #PP-{{ section.id }} .pp-bento-card--featured {
      grid-column: span 2;
    }
  }
  #PP-{{ section.id }} .pp-bento-card {
    position: relative;
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.06);
    border-radius: 1.6rem;
    padding: 2.4rem;
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    overflow: hidden;
  }
  #PP-{{ section.id }} .pp-bento-card:hover {
    transform: translateY(-0.3rem);
    box-shadow: 0 1.6rem 4rem rgba(var(--color-foreground), 0.06);
    border-color: rgba(78,161,217,0.2);
  }
  #PP-{{ section.id }} .pp-bento-card__icon {
    width: 4.8rem;
    height: 4.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(78,161,217,0.08) 0%, rgba(115,194,94,0.08) 100%);
    border-radius: 1.2rem;
    font-size: 2.2rem;
    margin-bottom: 1.6rem;
  }
  #PP-{{ section.id }} .pp-bento-card--featured .pp-bento-card__icon {
    width: 5.6rem;
    height: 5.6rem;
    font-size: 2.6rem;
    border-radius: 1.4rem;
  }
  #PP-{{ section.id }} .pp-bento-card__name {
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  #PP-{{ section.id }} .pp-bento-card--featured .pp-bento-card__name {
    font-size: 2rem;
  }
  #PP-{{ section.id }} .pp-bento-card__desc {
    font-size: 1.35rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.6);
  }
  #PP-{{ section.id }} .pp-bento-card--featured .pp-bento-card__desc {
    font-size: 1.45rem;
    max-width: 52rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-bento-card--featured {
      display: flex;
      align-items: center;
      gap: 2.4rem;
      padding: 3.2rem;
    }
    #PP-{{ section.id }} .pp-bento-card--featured .pp-bento-card__icon {
      margin-bottom: 0;
      flex-shrink: 0;
    }
  }

  /* ===== SCHEDULE TIMELINE ===== */
  #PP-{{ section.id }} .pp-schedule-wrap {
    max-width: 72rem;
    margin: 0 auto;
  }
  #PP-{{ section.id }} .pp-day-row {
    display: flex;
    align-items: stretch;
    gap: 1.6rem;
    padding: 1.6rem 0;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
    transition: background 0.25s ease;
  }
  #PP-{{ section.id }} .pp-day-row:last-of-type { border-bottom: none; }
  #PP-{{ section.id }} .pp-day-row:hover {
    background: rgba(var(--color-foreground), 0.015);
    border-radius: 1.2rem;
    margin: 0 -1.2rem;
    padding: 1.6rem 1.2rem;
  }
  #PP-{{ section.id }} .pp-day-row__label {
    flex-shrink: 0;
    width: 10rem;
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
  }
  #PP-{{ section.id }} .pp-day-row__chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
    flex: 1;
  }
  #PP-{{ section.id }} .pp-time-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    background: rgba(var(--color-foreground), 0.04);
    border-radius: 0.8rem;
    font-size: 1.35rem;
    font-weight: 500;
    color: rgba(var(--color-foreground), 0.8);
    transition: all 0.25s ease;
  }
  #PP-{{ section.id }} .pp-time-chip svg {
    width: 1.4rem; height: 1.4rem;
    fill: rgba(var(--color-foreground), 0.35);
  }
  #PP-{{ section.id }} .pp-time-chip--akut {
    background: linear-gradient(135deg, rgba(78,161,217,0.10) 0%, rgba(115,194,94,0.10) 100%);
    color: #4ea1d9;
    font-weight: 600;
    border: 0.1rem solid rgba(78,161,217,0.15);
  }
  #PP-{{ section.id }} .pp-time-chip--akut svg {
    fill: #4ea1d9;
  }
  #PP-{{ section.id }} .pp-time-chip--note {
    font-style: italic;
    color: rgba(var(--color-foreground), 0.5);
    font-size: 1.25rem;
    background: none;
    padding: 0.6rem 0;
  }
  @media screen and (max-width: 749px) {
    #PP-{{ section.id }} .pp-day-row {
      flex-direction: column;
      gap: 0.6rem;
      padding: 1.4rem 0;
    }
    #PP-{{ section.id }} .pp-day-row:hover {
      margin: 0; padding: 1.4rem 0;
    }
    #PP-{{ section.id }} .pp-day-row__label { width: auto; }
  }

  /* Schedule note */
  #PP-{{ section.id }} .pp-schedule-note {
    margin-top: 2.4rem;
    padding: 1.6rem 2rem;
    background: linear-gradient(135deg, rgba(78,161,217,0.05) 0%, rgba(115,194,94,0.05) 100%);
    border-radius: 1.2rem;
    border-left: 0.3rem solid #4ea1d9;
    font-size: 1.35rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
  }

  /* Schedule info cards */
  #PP-{{ section.id }} .pp-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(26rem, 100%), 1fr));
    gap: 1.6rem;
    margin-top: 3.2rem;
  }
  #PP-{{ section.id }} .pp-info-card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.06);
    border-radius: 1.6rem;
    padding: 2.4rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  #PP-{{ section.id }} .pp-info-card:hover {
    transform: translateY(-0.2rem);
    box-shadow: 0 1.2rem 3.2rem rgba(var(--color-foreground), 0.05);
  }
  #PP-{{ section.id }} .pp-info-card h4 {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  #PP-{{ section.id }} .pp-info-card__content {
    font-size: 1.3rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.65);
  }
  #PP-{{ section.id }} .pp-info-card__content p { margin: 0.3rem 0; }
  #PP-{{ section.id }} .pp-info-card__content ul { padding-left: 1.6rem; margin: 0.3rem 0; }
  #PP-{{ section.id }} .pp-info-card__content li { margin-bottom: 0.2rem; }

  /* ===== CONTACT SECTION ===== */
  #PP-{{ section.id }} .pp-contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-contact-layout {
      grid-template-columns: 1fr 1fr;
    }
  }
  #PP-{{ section.id }} .pp-contact-details {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #PP-{{ section.id }} .pp-contact-row {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
    padding: 1.8rem 0;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
    transition: padding-left 0.25s ease;
  }
  #PP-{{ section.id }} .pp-contact-row:last-child { border-bottom: none; }
  #PP-{{ section.id }} .pp-contact-row:hover { padding-left: 0.4rem; }
  #PP-{{ section.id }} .pp-contact-row__icon {
    flex-shrink: 0;
    width: 4.4rem;
    height: 4.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(78,161,217,0.08) 0%, rgba(115,194,94,0.08) 100%);
    border-radius: 1.2rem;
  }
  #PP-{{ section.id }} .pp-contact-row__icon svg {
    width: 2rem; height: 2rem; fill: #4ea1d9;
  }
  #PP-{{ section.id }} .pp-contact-row__label {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.4);
    margin-bottom: 0.3rem;
  }
  #PP-{{ section.id }} .pp-contact-row__value {
    font-size: 1.5rem;
    line-height: 1.5;
    font-weight: 500;
  }
  #PP-{{ section.id }} .pp-contact-row__value a {
    color: rgba(var(--color-foreground), 0.85);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  #PP-{{ section.id }} .pp-contact-row__value a:hover { color: #4ea1d9; }
  #PP-{{ section.id }} .pp-contact-row__sub {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.45);
    margin-top: 0.3rem;
  }
  #PP-{{ section.id }} .pp-contact-row__sub a {
    color: rgba(var(--color-foreground), 0.55);
    text-decoration: none;
  }
  #PP-{{ section.id }} .pp-contact-row__sub a:hover { color: #4ea1d9; }

  /* CTA buttons */
  #PP-{{ section.id }} .pp-contact-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 2.4rem;
  }
  #PP-{{ section.id }} .pp-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.4rem 3.2rem;
    background: linear-gradient(135deg, #4ea1d9 0%, #73c25e 100%);
    color: #fff;
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02rem;
    border-radius: 1.2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 0.4rem 1.6rem rgba(78,161,217,0.2);
  }
  #PP-{{ section.id }} .pp-cta-primary:hover {
    transform: translateY(-0.2rem);
    box-shadow: 0 0.8rem 2.8rem rgba(78,161,217,0.3);
  }
  #PP-{{ section.id }} .pp-cta-primary svg { width: 1.6rem; height: 1.6rem; fill: currentColor; }
  #PP-{{ section.id }} .pp-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.4rem 2.8rem;
    background: transparent;
    border: 0.15rem solid rgba(var(--color-foreground), 0.12);
    color: rgba(var(--color-foreground), 0.8);
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 1.2rem;
    transition: all 0.3s ease;
  }
  #PP-{{ section.id }} .pp-cta-secondary:hover {
    border-color: #4ea1d9;
    color: #4ea1d9;
    transform: translateY(-0.1rem);
  }
  #PP-{{ section.id }} .pp-cta-secondary svg { width: 1.4rem; height: 1.4rem; fill: currentColor; }

  /* Map */
  #PP-{{ section.id }} .pp-map-wrapper {
    border-radius: 1.6rem;
    overflow: hidden;
    min-height: 36rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.06);
    background: rgba(var(--color-foreground), 0.02);
  }
  #PP-{{ section.id }} .pp-map-wrapper iframe {
    width: 100%; height: 100%; min-height: 36rem; border: none;
  }
  #PP-{{ section.id }} .pp-map-consent {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 36rem; padding: 3.2rem; text-align: center;
  }
  #PP-{{ section.id }} .pp-map-consent__icon {
    width: 6rem; height: 6rem;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, rgba(78,161,217,0.08) 0%, rgba(115,194,94,0.08) 100%);
    border-radius: 1.6rem;
    margin-bottom: 1.6rem;
  }
  #PP-{{ section.id }} .pp-map-consent__icon svg {
    width: 2.8rem; height: 2.8rem; fill: #4ea1d9;
  }
  #PP-{{ section.id }} .pp-map-consent p {
    font-size: 1.35rem; color: rgba(var(--color-foreground), 0.55);
    margin-bottom: 1.6rem; max-width: 30rem;
    line-height: 1.6;
  }
  #PP-{{ section.id }} .pp-map-btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.4rem;
    background: linear-gradient(135deg, #4ea1d9 0%, #73c25e 100%);
    color: #fff;
    font-size: 1.35rem; font-weight: 600;
    border: none; cursor: pointer;
    border-radius: 1rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  #PP-{{ section.id }} .pp-map-btn:hover {
    transform: translateY(-0.1rem);
    box-shadow: 0 0.4rem 1.2rem rgba(78,161,217,0.25);
  }
{%- endstyle -%}

{%- comment -%} Only render on dedicated page, not on homepage (Shopify rendering instance workaround) {%- endcomment -%}
{%- unless template.name == 'index' -%}

{%- assign doctors = section.blocks | where: "type", "doctor" -%}
{%- assign services = section.blocks | where: "type", "service" -%}
{%- assign infos = section.blocks | where: "type", "schedule_info" -%}
{%- assign is_full = false -%}
{%- if doctors.size > 0 -%}{%- assign is_full = true -%}{%- endif -%}

<div id="PP-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">

    {%- comment -%} ===== HERO HEADER ===== {%- endcomment -%}
    <div class="pp-hero pp-animate">
      <div class="pp-hero__badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Juvantis Partnerpraxis
      </div>
      {%- if section.settings.heading != blank -%}
        <h2 class="pp-hero__heading">
          <span>{{ section.settings.heading | escape }}</span>
        </h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="pp-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="pp-hero__desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
      {%- if section.settings.address != blank -%}
        <p class="pp-hero__desc" style="margin-top:0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:1.4rem;height:1.4rem;fill:rgba(var(--color-foreground),0.4);vertical-align:-0.2rem;margin-right:0.4rem;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
          {{ section.settings.address | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.languages != blank -%}
        <div class="pp-hero__langs">
          {%- assign langs = section.settings.languages | split: ',' -%}
          {%- for lang in langs -%}
            <span class="pp-lang-pill">{{ lang | strip | escape }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if is_full == false and section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="pp-hero__cta">
          {{ section.settings.button_label | escape }}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- if is_full -%}

      {%- comment -%} ===== TEAM ===== {%- endcomment -%}
      <div class="pp-section-header pp-animate">
        <span class="pp-section-header__label">Unser Team</span>
        <h3 class="pp-section-header__title">Erfahrene Fach&auml;rzte</h3>
        <p class="pp-section-header__desc">Internationale Kompetenz und langj&auml;hrige klinische Erfahrung f&uuml;r Ihre bestm&ouml;gliche Versorgung</p>
      </div>
      <div class="pp-team-grid">
        {%- for block in doctors -%}
          <div class="pp-doctor-card pp-animate" {{ block.shopify_attributes }}>
            <div class="pp-doctor-card__top">
              <div class="pp-doctor-card__avatar">
                {%- assign name_parts = block.settings.name | split: ' ' -%}
                {%- for part in name_parts -%}
                  {%- unless part == 'Dr.' or part == 'med.' or part == 'Dr' or part == 'med' -%}
                    {{ part | slice: 0 }}
                  {%- endunless -%}
                {%- endfor -%}
              </div>
              <div class="pp-doctor-card__meta">
                <h4 class="pp-doctor-card__name">{{ block.settings.name | escape }}</h4>
                {%- if block.settings.title != blank -%}
                  <p class="pp-doctor-card__title">{{ block.settings.title | escape }}</p>
                {%- endif -%}
                {%- if block.settings.qualifications != blank -%}
                  <div class="pp-doctor-card__pills">
                    {%- assign quals = block.settings.qualifications | newline_to_br | split: '<br />' -%}
                    {%- for q in quals -%}
                      {%- assign q_stripped = q | strip -%}
                      {%- if q_stripped != blank -%}
                        <span class="pp-cred-pill">{{ q_stripped | escape }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
            {%- if block.settings.bio != blank -%}
              <p class="pp-doctor-card__bio">{{ block.settings.bio | escape }}</p>
            {%- endif -%}
            {%- if block.settings.career != blank or block.settings.education != blank -%}
              <details class="pp-cv-accordion">
                <summary>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                  Vollst&auml;ndiger Lebenslauf
                </summary>
                {%- if block.settings.career != blank -%}
                  <div class="pp-cv-section">
                    <div class="pp-cv-section__label">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/></svg>
                      Berufliche Erfahrung
                    </div>
                    <div class="pp-cv-section__content">{{ block.settings.career }}</div>
                  </div>
                {%- endif -%}
                {%- if block.settings.education != blank -%}
                  <div class="pp-cv-section">
                    <div class="pp-cv-section__label">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg>
                      Ausbildung
                    </div>
                    <div class="pp-cv-section__content">{{ block.settings.education }}</div>
                  </div>
                {%- endif -%}
              </details>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} ===== SERVICES (Bento Grid) ===== {%- endcomment -%}
      {%- if services.size > 0 -%}
        <div class="pp-section-header pp-animate">
          <span class="pp-section-header__label">Leistungsspektrum</span>
          <h3 class="pp-section-header__title">Unsere Leistungen</h3>
          <p class="pp-section-header__desc">Umfassende haus&auml;rztliche und internistische Versorgung mit modernster Diagnostik</p>
        </div>

        {%- assign categories = "" -%}
        {%- for block in services -%}
          {%- unless categories contains block.settings.category -%}
            {%- if categories != "" -%}{%- assign categories = categories | append: "|||" -%}{%- endif -%}
            {%- assign categories = categories | append: block.settings.category -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign cat_list = categories | split: "|||" -%}

        {%- for cat in cat_list -%}
          <div class="pp-svc-category pp-animate">
            {%- if cat != blank -%}
              <div class="pp-svc-cat-label">{{ cat | escape }}</div>
            {%- endif -%}
            <div class="pp-bento">
              {%- assign cat_index = 0 -%}
              {%- for block in services -%}
                {%- if block.settings.category == cat -%}
                  <div class="pp-bento-card{% if cat_index == 0 %} pp-bento-card--featured{% endif %}" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <div class="pp-bento-card__icon">{{ block.settings.icon }}</div>
                    {%- endif -%}
                    <div>
                      <h5 class="pp-bento-card__name">{{ block.settings.name | escape }}</h5>
                      {%- if block.settings.description != blank -%}
                        <p class="pp-bento-card__desc">{{ block.settings.description | escape }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                  {%- assign cat_index = cat_index | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} ===== SCHEDULE (Timeline) ===== {%- endcomment -%}
      <div class="pp-section-header pp-animate">
        <span class="pp-section-header__label">Sprechzeiten</span>
        <h3 class="pp-section-header__title">&Ouml;ffnungszeiten</h3>
      </div>
      <div class="pp-schedule-wrap pp-animate">
        {%- if section.settings.mo_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Montag</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.mo_hours }}</span>
              {%- if section.settings.mo_akut != blank -%}
                <span class="pp-time-chip pp-time-chip--akut"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg> Akut {{ section.settings.mo_akut }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.di_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Dienstag</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.di_hours }}</span>
              {%- if section.settings.di_akut != blank -%}
                <span class="pp-time-chip pp-time-chip--akut"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg> Akut {{ section.settings.di_akut }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.mi_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Mittwoch</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.mi_hours }}</span>
              {%- if section.settings.mi_akut != blank -%}
                <span class="pp-time-chip pp-time-chip--akut"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg> Akut {{ section.settings.mi_akut }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.do_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Donnerstag</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.do_hours }}</span>
              {%- if section.settings.do_akut != blank -%}
                <span class="pp-time-chip pp-time-chip--akut"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg> Akut {{ section.settings.do_akut }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.fr_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Freitag</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.fr_hours }}</span>
              {%- if section.settings.fr_akut != blank -%}
                <span class="pp-time-chip pp-time-chip--akut"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg> Akut {{ section.settings.fr_akut }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.sa_hours != blank -%}
          <div class="pp-day-row">
            <div class="pp-day-row__label">Samstag</div>
            <div class="pp-day-row__chips">
              <span class="pp-time-chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ section.settings.sa_hours }}</span>
              <span class="pp-time-chip pp-time-chip--note">nur nach Vereinbarung</span>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.schedule_note != blank -%}
          <div class="pp-schedule-note">{{ section.settings.schedule_note | escape }}</div>
        {%- endif -%}

        {%- if infos.size > 0 -%}
          <div class="pp-info-grid">
            {%- for block in infos -%}
              <div class="pp-info-card pp-animate" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4>{{ block.settings.title | escape }}</h4>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="pp-info-card__content">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ===== CONTACT ===== {%- endcomment -%}
      <div class="pp-section-header pp-animate">
        <span class="pp-section-header__label">Kontakt</span>
        <h3 class="pp-section-header__title">Kontakt &amp; Anfahrt</h3>
      </div>
      <div class="pp-contact-layout pp-animate">
        <div class="pp-contact-details">
          {%- if section.settings.address != blank -%}
            <div class="pp-contact-row">
              <div class="pp-contact-row__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg></div>
              <div>
                <div class="pp-contact-row__label">Adresse</div>
                <div class="pp-contact-row__value">{{ section.settings.address | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <div class="pp-contact-row">
              <div class="pp-contact-row__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
              <div>
                <div class="pp-contact-row__label">Telefon</div>
                <div class="pp-contact-row__value"><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone | escape }}</a></div>
                {%- if section.settings.phone_private != blank -%}
                  <div class="pp-contact-row__sub">Privatpatienten: <a href="tel:{{ section.settings.phone_private | remove: ' ' | remove: '-' }}">{{ section.settings.phone_private | escape }}</a></div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.fax != blank -%}
            <div class="pp-contact-row">
              <div class="pp-contact-row__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg></div>
              <div>
                <div class="pp-contact-row__label">Fax</div>
                <div class="pp-contact-row__value">{{ section.settings.fax | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <div class="pp-contact-row">
              <div class="pp-contact-row__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
              <div>
                <div class="pp-contact-row__label">E-Mail</div>
                <div class="pp-contact-row__value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a></div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.website != blank -%}
            <div class="pp-contact-row">
              <div class="pp-contact-row__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95a15.65 15.65 0 00-1.38-3.56A8.03 8.03 0 0118.92 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 015.08 16zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/></svg></div>
              <div>
                <div class="pp-contact-row__label">Website</div>
                <div class="pp-contact-row__value"><a href="{{ section.settings.website }}" target="_blank" rel="noopener noreferrer">{{ section.settings.website | remove: 'https://' | remove: 'http://' | remove_last: '/' }}</a></div>
              </div>
            </div>
          {%- endif -%}

          <div class="pp-contact-ctas">
            {%- if section.settings.doctolib_url != blank -%}
              <a href="{{ section.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="pp-cta-primary">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z"/></svg>
                Online-Termin buchen
              </a>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="pp-cta-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                Jetzt anrufen
              </a>
            {%- endif -%}
          </div>
        </div>

        <div class="pp-map-wrapper">
          {%- if section.settings.maps_embed_url != blank -%}
            <div id="pp-map-consent-{{ section.id }}" class="pp-map-consent">
              <div class="pp-map-consent__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              </div>
              <p>Zum Anzeigen der Karte wird eine Verbindung zu Google Maps hergestellt.</p>
              <button class="pp-map-btn" onclick="document.getElementById('pp-map-consent-{{ section.id }}').style.display='none';document.getElementById('pp-map-frame-{{ section.id }}').innerHTML='<iframe src=&quot;{{ section.settings.maps_embed_url }}&quot; allowfullscreen loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>';">Karte laden</button>
            </div>
            <div id="pp-map-frame-{{ section.id }}"></div>
          {%- else -%}
            <div class="pp-map-consent">
              <div class="pp-map-consent__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              </div>
              <p>Google Maps Embed-URL in den Einstellungen hinterlegen.</p>
            </div>
          {%- endif -%}
        </div>
      </div>

    {%- endif -%}
  </div>
</div>

{%- endunless -%}

{% schema %}
{
  "name": "Juvantis Partnerpraxis",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "default": "GP Medical Center Westend", "label": "Praxisname" },
    { "type": "text", "id": "subtitle", "default": "Praxis Dr. Stracke & Kollegen", "label": "Untertitel" },
    { "type": "textarea", "id": "description", "label": "Beschreibung" },
    { "type": "text", "id": "address", "default": "Grüneburgweg 12, 60322 Frankfurt am Main", "label": "Adresse" },
    { "type": "text", "id": "languages", "default": "DE, EN, FR, ES", "label": "Sprachen (kommagetrennt)" },
    { "type": "text", "id": "button_label", "default": "Termin buchen", "label": "Button Text" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Sprechzeiten" },
    { "type": "text", "id": "mo_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Montag" },
    { "type": "text", "id": "mo_akut", "default": "11:00–12:00", "label": "Montag Akut" },
    { "type": "text", "id": "di_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Dienstag" },
    { "type": "text", "id": "di_akut", "default": "11:00–12:00", "label": "Dienstag Akut" },
    { "type": "text", "id": "mi_hours", "default": "08:00–11:00", "label": "Mittwoch" },
    { "type": "text", "id": "mi_akut", "default": "11:00–12:00", "label": "Mittwoch Akut" },
    { "type": "text", "id": "do_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Donnerstag" },
    { "type": "text", "id": "do_akut", "default": "11:00–12:00", "label": "Donnerstag Akut" },
    { "type": "text", "id": "fr_hours", "default": "08:00–11:00", "label": "Freitag" },
    { "type": "text", "id": "fr_akut", "default": "11:00–12:00", "label": "Freitag Akut" },
    { "type": "text", "id": "sa_hours", "default": "09:00–13:00", "label": "Samstag" },
    { "type": "textarea", "id": "schedule_note", "default": "Akutsprechstunde täglich Mo–Fr 11:00–12:00 Uhr (ohne Termin)", "label": "Sprechzeiten-Hinweis" },
    { "type": "header", "content": "Kontakt" },
    { "type": "text", "id": "phone", "default": "069-247 574 523", "label": "Telefon" },
    { "type": "text", "id": "phone_private", "default": "069-247 574 526", "label": "Privatpatienten" },
    { "type": "text", "id": "fax", "default": "069-97206408", "label": "Fax" },
    { "type": "text", "id": "email", "default": "praxis@westend-hausarzt.de", "label": "E-Mail" },
    { "type": "url", "id": "website", "label": "Website" },
    { "type": "url", "id": "doctolib_url", "label": "Doctolib" },
    { "type": "text", "id": "maps_embed_url", "label": "Google Maps Embed-URL" },
    { "type": "select", "id": "color_scheme", "options": [
      { "value": "accent-1", "label": "Akzent 1" },
      { "value": "accent-2", "label": "Akzent 2" },
      { "value": "background-1", "label": "Hintergrund 1" },
      { "value": "background-2", "label": "Hintergrund 2" },
      { "value": "inverse", "label": "Invertiert" }
    ], "default": "background-2", "label": "Farbschema" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand oben", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand unten", "default": 52 }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Arzt / Ärztin",
      "settings": [
        { "type": "text", "id": "name", "default": "Dr. med.", "label": "Name" },
        { "type": "text", "id": "title", "label": "Fachbezeichnung" },
        { "type": "textarea", "id": "qualifications", "label": "Qualifikationen" },
        { "type": "textarea", "id": "bio", "label": "Biografie" },
        { "type": "richtext", "id": "career", "label": "Berufliche Erfahrung" },
        { "type": "richtext", "id": "education", "label": "Ausbildung" }
      ]
    },
    {
      "type": "service",
      "name": "Leistung",
      "settings": [
        { "type": "text", "id": "icon", "default": "🩺", "label": "Icon" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "description", "label": "Beschreibung" },
        { "type": "text", "id": "category", "default": "Weitere Leistungen", "label": "Kategorie" }
      ]
    },
    {
      "type": "schedule_info",
      "name": "Sprechzeiten-Info",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "richtext", "id": "content", "label": "Inhalt" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis Partnerpraxis" }]
}
{% endschema %}
