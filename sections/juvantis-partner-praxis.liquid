{%- style -%}
  /* ===== APPLE-STYLE BASE ===== */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ===== SCROLL REVEAL — Apple-style subtle fade ===== */
  @keyframes ap-fadein {
    from { opacity: 0; transform: translateY(1.6rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @supports (animation-timeline: view()) {
    #AP-{{ section.id }} .ap-reveal {
      animation: ap-fadein linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 20%;
    }
  }
  @supports not (animation-timeline: view()) {
    #AP-{{ section.id }} .ap-reveal {
      animation: ap-fadein 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) both;
    }
    #AP-{{ section.id }} .ap-reveal:nth-child(2) { animation-delay: 0.08s; }
    #AP-{{ section.id }} .ap-reveal:nth-child(3) { animation-delay: 0.16s; }
    #AP-{{ section.id }} .ap-reveal:nth-child(4) { animation-delay: 0.24s; }
  }

  /* ===== LAYOUT ===== */
  #AP-{{ section.id }} {
    --ap-white: #fff;
    --ap-gray: #f5f5f7;
    --ap-text: #1d1d1f;
    --ap-text-secondary: #6e6e73;
    --ap-text-tertiary: #86868b;
    --ap-blue: #0071e3;
    --ap-blue-hover: #0077ed;
    --ap-border: rgba(0,0,0,0.04);
    --ap-max-width: 98rem;
    --ap-content-width: 72rem;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  #AP-{{ section.id }} * { box-sizing: border-box; }

  #AP-{{ section.id }} .ap-section {
    padding: 6rem 2.4rem;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-section {
      padding: 10rem 4rem;
    }
  }
  @media screen and (min-width: 1200px) {
    #AP-{{ section.id }} .ap-section {
      padding: 12rem 4rem;
    }
  }
  #AP-{{ section.id }} .ap-section--gray {
    background: var(--ap-gray);
  }
  #AP-{{ section.id }} .ap-section--white {
    background: var(--ap-white);
  }
  #AP-{{ section.id }} .ap-container {
    max-width: var(--ap-max-width);
    margin: 0 auto;
  }
  #AP-{{ section.id }} .ap-container--narrow {
    max-width: var(--ap-content-width);
    margin: 0 auto;
  }

  /* ===== HERO ===== */
  #AP-{{ section.id }} .ap-hero {
    text-align: center;
    padding: 8rem 2.4rem 6rem;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-hero {
      padding: 12rem 4rem 8rem;
    }
  }
  @media screen and (min-width: 1200px) {
    #AP-{{ section.id }} .ap-hero {
      padding: 14rem 4rem 10rem;
    }
  }
  #AP-{{ section.id }} .ap-hero__eyebrow {
    display: inline-block;
    font-size: 1.7rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ap-text-secondary);
    margin-bottom: 1.2rem;
  }
  #AP-{{ section.id }} .ap-hero__heading {
    font-size: clamp(4rem, 7vw, 8rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ap-text);
    margin: 0 auto 1.6rem;
    max-width: 90rem;
  }
  #AP-{{ section.id }} .ap-hero__subtitle {
    font-size: clamp(1.8rem, 2.5vw, 2.8rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ap-text-secondary);
    margin: 0 auto 2.4rem;
    max-width: 68rem;
  }
  #AP-{{ section.id }} .ap-hero__desc {
    font-size: 1.7rem;
    line-height: 1.53;
    font-weight: 400;
    color: var(--ap-text-secondary);
    max-width: 52rem;
    margin: 0 auto 2rem;
  }
  #AP-{{ section.id }} .ap-hero__address {
    font-size: 1.7rem;
    font-weight: 400;
    color: var(--ap-text-tertiary);
    margin-bottom: 3.2rem;
  }
  #AP-{{ section.id }} .ap-hero__langs {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }
  #AP-{{ section.id }} .ap-lang {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--ap-text-tertiary);
    padding: 0.5rem 1.4rem;
    background: var(--ap-gray);
    border-radius: 10rem;
    letter-spacing: 0.02em;
  }
  #AP-{{ section.id }} .ap-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.2rem 3rem;
    background: var(--ap-blue);
    color: #fff;
    font-size: 1.7rem;
    font-weight: 400;
    text-decoration: none;
    border-radius: 98rem;
    transition: background 0.3s ease;
  }
  #AP-{{ section.id }} .ap-hero__cta:hover {
    background: var(--ap-blue-hover);
  }
  #AP-{{ section.id }} .ap-hero__cta svg {
    width: 1.2rem; height: 1.2rem; fill: currentColor;
    transition: transform 0.2s ease;
  }
  #AP-{{ section.id }} .ap-hero__cta:hover svg {
    transform: translateX(0.2rem);
  }

  /* ===== SECTION HEADERS (Apple style) ===== */
  #AP-{{ section.id }} .ap-heading {
    text-align: center;
    margin-bottom: 5.6rem;
  }
  #AP-{{ section.id }} .ap-heading__eyebrow {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ap-text-tertiary);
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  #AP-{{ section.id }} .ap-heading__title {
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    line-height: 1.07;
    letter-spacing: -0.035em;
    color: var(--ap-text);
    margin-bottom: 1.2rem;
  }
  #AP-{{ section.id }} .ap-heading__desc {
    font-size: 1.7rem;
    font-weight: 400;
    line-height: 1.53;
    color: var(--ap-text-secondary);
    max-width: 52rem;
    margin: 0 auto;
  }

  /* ===== TEAM — Apple editorial layout ===== */
  #AP-{{ section.id }} .ap-team {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  #AP-{{ section.id }} .ap-doctor {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    padding: 4.8rem 0;
    border-bottom: 1px solid var(--ap-border);
    align-items: start;
  }
  #AP-{{ section.id }} .ap-doctor:last-child {
    border-bottom: none;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-doctor {
      grid-template-columns: 28rem 1fr;
      gap: 6rem;
      padding: 6rem 0;
    }
  }
  @media screen and (min-width: 990px) {
    #AP-{{ section.id }} .ap-doctor {
      grid-template-columns: 32rem 1fr;
      gap: 8rem;
    }
  }
  #AP-{{ section.id }} .ap-doctor__avatar {
    width: 100%;
    aspect-ratio: 1;
    max-width: 20rem;
    background: var(--ap-gray);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4.8rem;
    font-weight: 700;
    color: var(--ap-text-secondary);
    letter-spacing: -0.04em;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-doctor__avatar {
      max-width: 100%;
      margin: 0;
    }
  }
  #AP-{{ section.id }} .ap-doctor__info {
    padding-top: 0.4rem;
  }
  #AP-{{ section.id }} .ap-doctor__name {
    font-size: clamp(2.4rem, 3.5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ap-text);
    margin-bottom: 0.6rem;
  }
  #AP-{{ section.id }} .ap-doctor__title {
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ap-text-secondary);
    margin-bottom: 2rem;
  }
  #AP-{{ section.id }} .ap-doctor__quals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 2.4rem;
  }
  #AP-{{ section.id }} .ap-qual {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ap-text-secondary);
    padding: 0.5rem 1.2rem;
    background: var(--ap-gray);
    border-radius: 0.6rem;
    line-height: 1.4;
  }
  #AP-{{ section.id }} .ap-doctor__bio {
    font-size: 1.7rem;
    line-height: 1.58;
    font-weight: 400;
    color: var(--ap-text-secondary);
    margin-bottom: 2.4rem;
  }

  /* CV accordion — Apple details */
  #AP-{{ section.id }} .ap-cv {
    border-top: 1px solid var(--ap-border);
    margin-top: 0.8rem;
  }
  #AP-{{ section.id }} .ap-cv summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.6rem 0;
    font-size: 1.7rem;
    font-weight: 600;
    color: var(--ap-blue);
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
    letter-spacing: -0.01em;
  }
  #AP-{{ section.id }} .ap-cv summary::marker,
  #AP-{{ section.id }} .ap-cv summary::-webkit-details-marker { display: none; }
  #AP-{{ section.id }} .ap-cv summary:hover { color: var(--ap-blue-hover); }
  #AP-{{ section.id }} .ap-cv summary svg {
    width: 1.6rem; height: 1.6rem; fill: currentColor;
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    flex-shrink: 0;
  }
  #AP-{{ section.id }} .ap-cv[open] summary svg {
    transform: rotate(45deg);
  }
  #AP-{{ section.id }} .ap-cv__block {
    padding-bottom: 2.4rem;
  }
  #AP-{{ section.id }} .ap-cv__label {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ap-text-tertiary);
    margin-bottom: 1.2rem;
  }
  #AP-{{ section.id }} .ap-cv__content {
    font-size: 1.5rem;
    line-height: 1.7;
    color: var(--ap-text-secondary);
  }
  #AP-{{ section.id }} .ap-cv__content p {
    margin: 0.4rem 0;
  }

  /* ===== SERVICES — Apple tile grid ===== */
  #AP-{{ section.id }} .ap-services-cat {
    margin-bottom: 4.8rem;
  }
  #AP-{{ section.id }} .ap-services-cat:last-child {
    margin-bottom: 0;
  }
  #AP-{{ section.id }} .ap-cat-label {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ap-text);
    margin-bottom: 2.4rem;
    text-align: center;
  }
  #AP-{{ section.id }} .ap-tiles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-tiles {
      grid-template-columns: repeat(2, 1fr);
    }
    #AP-{{ section.id }} .ap-tile--hero {
      grid-column: 1 / -1;
    }
  }
  @media screen and (min-width: 990px) {
    #AP-{{ section.id }} .ap-tiles {
      grid-template-columns: repeat(3, 1fr);
    }
    #AP-{{ section.id }} .ap-tile--hero {
      grid-column: 1 / -1;
    }
  }
  #AP-{{ section.id }} .ap-tile {
    background: var(--ap-white);
    border-radius: 2rem;
    padding: 3.2rem;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    position: relative;
    overflow: hidden;
  }
  #AP-{{ section.id }} .ap-section--white .ap-tile {
    background: var(--ap-gray);
  }
  #AP-{{ section.id }} .ap-tile:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.06);
  }
  #AP-{{ section.id }} .ap-tile--hero {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-tile--hero {
      flex-direction: row;
      align-items: center;
      gap: 3.2rem;
      padding: 4.8rem;
    }
  }
  #AP-{{ section.id }} .ap-tile__icon {
    font-size: 3.6rem;
    line-height: 1;
    margin-bottom: 2rem;
  }
  #AP-{{ section.id }} .ap-tile--hero .ap-tile__icon {
    font-size: 4.8rem;
    margin-bottom: 0;
    flex-shrink: 0;
  }
  #AP-{{ section.id }} .ap-tile__name {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ap-text);
    margin-bottom: 0.8rem;
    line-height: 1.2;
  }
  #AP-{{ section.id }} .ap-tile--hero .ap-tile__name {
    font-size: 2.4rem;
  }
  #AP-{{ section.id }} .ap-tile__desc {
    font-size: 1.5rem;
    line-height: 1.58;
    color: var(--ap-text-secondary);
  }
  #AP-{{ section.id }} .ap-tile--hero .ap-tile__desc {
    font-size: 1.7rem;
  }

  /* ===== SCHEDULE — Apple clean table ===== */
  #AP-{{ section.id }} .ap-schedule {
    max-width: 68rem;
    margin: 0 auto;
  }
  #AP-{{ section.id }} .ap-day {
    display: flex;
    align-items: baseline;
    padding: 2rem 0;
    border-bottom: 1px solid var(--ap-border);
    gap: 2rem;
    transition: opacity 0.2s ease;
  }
  #AP-{{ section.id }} .ap-day:last-of-type {
    border-bottom: none;
  }
  #AP-{{ section.id }} .ap-day:hover {
    opacity: 0.7;
  }
  #AP-{{ section.id }} .ap-day__name {
    flex-shrink: 0;
    width: 12rem;
    font-size: 1.7rem;
    font-weight: 600;
    color: var(--ap-text);
    letter-spacing: -0.01em;
  }
  #AP-{{ section.id }} .ap-day__times {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    flex: 1;
    align-items: baseline;
  }
  #AP-{{ section.id }} .ap-time {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--ap-text-secondary);
  }
  #AP-{{ section.id }} .ap-time--akut {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ap-blue);
    background: rgba(0,113,227,0.06);
    padding: 0.3rem 1rem;
    border-radius: 0.5rem;
  }
  #AP-{{ section.id }} .ap-time--note {
    font-size: 1.3rem;
    font-style: italic;
    color: var(--ap-text-tertiary);
  }
  @media screen and (max-width: 749px) {
    #AP-{{ section.id }} .ap-day {
      flex-direction: column;
      gap: 0.4rem;
      padding: 1.6rem 0;
    }
    #AP-{{ section.id }} .ap-day__name { width: auto; }
  }
  #AP-{{ section.id }} .ap-note {
    margin-top: 3.2rem;
    padding: 2rem 2.4rem;
    background: var(--ap-gray);
    border-radius: 1.2rem;
    font-size: 1.5rem;
    line-height: 1.58;
    color: var(--ap-text-secondary);
  }
  #AP-{{ section.id }} .ap-section--gray .ap-note {
    background: var(--ap-white);
  }

  /* Schedule info tiles */
  #AP-{{ section.id }} .ap-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(26rem, 100%), 1fr));
    gap: 1.6rem;
    margin-top: 4rem;
  }
  #AP-{{ section.id }} .ap-info-tile {
    background: var(--ap-white);
    border-radius: 2rem;
    padding: 3.2rem;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  #AP-{{ section.id }} .ap-section--white .ap-info-tile {
    background: var(--ap-gray);
  }
  #AP-{{ section.id }} .ap-info-tile:hover {
    transform: scale(1.02);
  }
  #AP-{{ section.id }} .ap-info-tile h4 {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ap-text);
    margin-bottom: 1.2rem;
  }
  #AP-{{ section.id }} .ap-info-tile__content {
    font-size: 1.5rem;
    line-height: 1.58;
    color: var(--ap-text-secondary);
  }
  #AP-{{ section.id }} .ap-info-tile__content p { margin: 0.4rem 0; }
  #AP-{{ section.id }} .ap-info-tile__content ul { padding-left: 1.8rem; margin: 0.4rem 0; }
  #AP-{{ section.id }} .ap-info-tile__content li { margin-bottom: 0.3rem; }

  /* ===== CONTACT — Apple split layout ===== */
  #AP-{{ section.id }} .ap-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media screen and (min-width: 750px) {
    #AP-{{ section.id }} .ap-contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }
  #AP-{{ section.id }} .ap-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--ap-border);
  }
  #AP-{{ section.id }} .ap-contact-item:last-child {
    border-bottom: none;
  }
  #AP-{{ section.id }} .ap-contact-item__icon {
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ap-gray);
    border-radius: 50%;
  }
  #AP-{{ section.id }} .ap-section--gray .ap-contact-item__icon {
    background: var(--ap-white);
  }
  #AP-{{ section.id }} .ap-contact-item__icon svg {
    width: 1.8rem; height: 1.8rem; fill: var(--ap-text-tertiary);
  }
  #AP-{{ section.id }} .ap-contact-item__label {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ap-text-tertiary);
    margin-bottom: 0.2rem;
  }
  #AP-{{ section.id }} .ap-contact-item__value {
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--ap-text);
    line-height: 1.4;
  }
  #AP-{{ section.id }} .ap-contact-item__value a {
    color: var(--ap-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  #AP-{{ section.id }} .ap-contact-item__value a:hover {
    color: var(--ap-blue);
  }
  #AP-{{ section.id }} .ap-contact-item__sub {
    font-size: 1.3rem;
    color: var(--ap-text-tertiary);
    margin-top: 0.2rem;
  }
  #AP-{{ section.id }} .ap-contact-item__sub a {
    color: var(--ap-text-tertiary);
    text-decoration: none;
  }
  #AP-{{ section.id }} .ap-contact-item__sub a:hover { color: var(--ap-blue); }

  /* CTA links — Apple style */
  #AP-{{ section.id }} .ap-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 2.4rem;
    margin-top: 3.2rem;
    align-items: center;
  }
  #AP-{{ section.id }} .ap-cta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.2rem 2.8rem;
    background: var(--ap-blue);
    color: #fff;
    font-size: 1.7rem;
    font-weight: 400;
    text-decoration: none;
    border-radius: 98rem;
    transition: background 0.3s ease;
  }
  #AP-{{ section.id }} .ap-cta-pill:hover {
    background: var(--ap-blue-hover);
  }
  #AP-{{ section.id }} .ap-cta-pill svg { width: 1.2rem; height: 1.2rem; fill: currentColor; }
  #AP-{{ section.id }} .ap-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.7rem;
    font-weight: 400;
    color: var(--ap-blue);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  #AP-{{ section.id }} .ap-cta-link:hover { color: var(--ap-blue-hover); }
  #AP-{{ section.id }} .ap-cta-link svg {
    width: 1rem; height: 1rem; fill: currentColor;
    transition: transform 0.2s ease;
  }
  #AP-{{ section.id }} .ap-cta-link:hover svg {
    transform: translateX(0.2rem);
  }

  /* Map */
  #AP-{{ section.id }} .ap-map {
    border-radius: 2rem;
    overflow: hidden;
    min-height: 40rem;
    background: var(--ap-gray);
  }
  #AP-{{ section.id }} .ap-section--gray .ap-map {
    background: var(--ap-white);
  }
  #AP-{{ section.id }} .ap-map iframe {
    width: 100%; height: 100%; min-height: 40rem; border: none;
  }
  #AP-{{ section.id }} .ap-map-consent {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 40rem; padding: 4rem; text-align: center;
  }
  #AP-{{ section.id }} .ap-map-consent svg {
    width: 3.2rem; height: 3.2rem; fill: var(--ap-text-tertiary);
    margin-bottom: 1.6rem;
  }
  #AP-{{ section.id }} .ap-map-consent p {
    font-size: 1.5rem; color: var(--ap-text-tertiary);
    margin-bottom: 2rem; max-width: 28rem; line-height: 1.53;
  }
  #AP-{{ section.id }} .ap-map-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 1rem 2.4rem;
    background: var(--ap-blue);
    color: #fff;
    font-size: 1.5rem; font-weight: 400;
    border: none; cursor: pointer;
    border-radius: 98rem;
    transition: background 0.3s ease;
    font-family: inherit;
  }
  #AP-{{ section.id }} .ap-map-btn:hover {
    background: var(--ap-blue-hover);
  }
{%- endstyle -%}

{%- comment -%} Only render on dedicated page, not on homepage (Shopify rendering instance workaround) {%- endcomment -%}
{%- unless template.name == 'index' -%}

{%- assign doctors = section.blocks | where: "type", "doctor" -%}
{%- assign services = section.blocks | where: "type", "service" -%}
{%- assign infos = section.blocks | where: "type", "schedule_info" -%}
{%- assign is_full = false -%}
{%- if doctors.size > 0 -%}{%- assign is_full = true -%}{%- endif -%}

<div id="AP-{{ section.id }}" class="section-{{ section.id }}-padding">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <div class="ap-hero ap-reveal">
    <div class="ap-hero__eyebrow">Juvantis Partnerpraxis</div>
    {%- if section.settings.heading != blank -%}
      <h2 class="ap-hero__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="ap-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="ap-hero__desc">{{ section.settings.description | escape }}</p>
    {%- endif -%}
    {%- if section.settings.address != blank -%}
      <p class="ap-hero__address">{{ section.settings.address | escape }}</p>
    {%- endif -%}
    {%- if section.settings.languages != blank -%}
      <div class="ap-hero__langs">
        {%- assign langs = section.settings.languages | split: ',' -%}
        {%- for lang in langs -%}
          <span class="ap-lang">{{ lang | strip | escape }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if is_full == false and section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a href="{{ section.settings.button_link }}" class="ap-hero__cta">
        {{ section.settings.button_label | escape }}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12"><path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    {%- endif -%}
  </div>

  {%- if is_full -%}

    {%- comment -%} ===== TEAM ===== {%- endcomment -%}
    <div class="ap-section ap-section--gray">
      <div class="ap-container">
        <div class="ap-heading ap-reveal">
          <div class="ap-heading__eyebrow">Unser Team</div>
          <h3 class="ap-heading__title">Erfahrene Fach&auml;rzte</h3>
          <p class="ap-heading__desc">Internationale Kompetenz und langj&auml;hrige klinische Erfahrung f&uuml;r Ihre bestm&ouml;gliche Versorgung.</p>
        </div>
        <div class="ap-team ap-container--narrow">
          {%- for block in doctors -%}
            <div class="ap-doctor ap-reveal" {{ block.shopify_attributes }}>
              <div class="ap-doctor__avatar">
                {%- assign name_parts = block.settings.name | split: ' ' -%}
                {%- for part in name_parts -%}
                  {%- unless part == 'Dr.' or part == 'med.' or part == 'Dr' or part == 'med' or part == 'en' or part == 'méd.' -%}
                    {{ part | slice: 0 }}
                  {%- endunless -%}
                {%- endfor -%}
              </div>
              <div class="ap-doctor__info">
                <h4 class="ap-doctor__name">{{ block.settings.name | escape }}</h4>
                {%- if block.settings.title != blank -%}
                  <p class="ap-doctor__title">{{ block.settings.title | escape }}</p>
                {%- endif -%}
                {%- if block.settings.qualifications != blank -%}
                  <div class="ap-doctor__quals">
                    {%- assign quals = block.settings.qualifications | newline_to_br | split: '<br />' -%}
                    {%- for q in quals -%}
                      {%- assign q_stripped = q | strip -%}
                      {%- if q_stripped != blank -%}
                        <span class="ap-qual">{{ q_stripped | escape }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                {%- if block.settings.bio != blank -%}
                  <p class="ap-doctor__bio">{{ block.settings.bio | escape }}</p>
                {%- endif -%}
                {%- if block.settings.career != blank or block.settings.education != blank -%}
                  <details class="ap-cv">
                    <summary>
                      Lebenslauf ansehen
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                    </summary>
                    {%- if block.settings.career != blank -%}
                      <div class="ap-cv__block">
                        <div class="ap-cv__label">Berufliche Erfahrung</div>
                        <div class="ap-cv__content">{{ block.settings.career }}</div>
                      </div>
                    {%- endif -%}
                    {%- if block.settings.education != blank -%}
                      <div class="ap-cv__block">
                        <div class="ap-cv__label">Ausbildung</div>
                        <div class="ap-cv__content">{{ block.settings.education }}</div>
                      </div>
                    {%- endif -%}
                  </details>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- comment -%} ===== SERVICES ===== {%- endcomment -%}
    {%- if services.size > 0 -%}
      <div class="ap-section ap-section--white">
        <div class="ap-container">
          <div class="ap-heading ap-reveal">
            <div class="ap-heading__eyebrow">Leistungsspektrum</div>
            <h3 class="ap-heading__title">Unsere Leistungen</h3>
            <p class="ap-heading__desc">Umfassende haus&auml;rztliche und internistische Versorgung mit modernster Diagnostik.</p>
          </div>

          {%- assign categories = "" -%}
          {%- for block in services -%}
            {%- unless categories contains block.settings.category -%}
              {%- if categories != "" -%}{%- assign categories = categories | append: "|||" -%}{%- endif -%}
              {%- assign categories = categories | append: block.settings.category -%}
            {%- endunless -%}
          {%- endfor -%}
          {%- assign cat_list = categories | split: "|||" -%}

          {%- for cat in cat_list -%}
            <div class="ap-services-cat ap-reveal">
              {%- if cat != blank -%}
                <div class="ap-cat-label">{{ cat | escape }}</div>
              {%- endif -%}
              <div class="ap-tiles">
                {%- assign cat_index = 0 -%}
                {%- for block in services -%}
                  {%- if block.settings.category == cat -%}
                    <div class="ap-tile{% if cat_index == 0 %} ap-tile--hero{% endif %}" {{ block.shopify_attributes }}>
                      {%- if block.settings.icon != blank -%}
                        <div class="ap-tile__icon">{{ block.settings.icon }}</div>
                      {%- endif -%}
                      <div>
                        <h5 class="ap-tile__name">{{ block.settings.name | escape }}</h5>
                        {%- if block.settings.description != blank -%}
                          <p class="ap-tile__desc">{{ block.settings.description | escape }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- assign cat_index = cat_index | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ===== SCHEDULE ===== {%- endcomment -%}
    <div class="ap-section ap-section--gray">
      <div class="ap-container">
        <div class="ap-heading ap-reveal">
          <div class="ap-heading__eyebrow">Sprechzeiten</div>
          <h3 class="ap-heading__title">&Ouml;ffnungszeiten</h3>
        </div>
        <div class="ap-schedule ap-reveal">
          {%- if section.settings.mo_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Montag</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.mo_hours }}</span>
                {%- if section.settings.mo_akut != blank -%}
                  <span class="ap-time--akut">Akut {{ section.settings.mo_akut }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.di_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Dienstag</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.di_hours }}</span>
                {%- if section.settings.di_akut != blank -%}
                  <span class="ap-time--akut">Akut {{ section.settings.di_akut }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.mi_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Mittwoch</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.mi_hours }}</span>
                {%- if section.settings.mi_akut != blank -%}
                  <span class="ap-time--akut">Akut {{ section.settings.mi_akut }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.do_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Donnerstag</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.do_hours }}</span>
                {%- if section.settings.do_akut != blank -%}
                  <span class="ap-time--akut">Akut {{ section.settings.do_akut }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.fr_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Freitag</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.fr_hours }}</span>
                {%- if section.settings.fr_akut != blank -%}
                  <span class="ap-time--akut">Akut {{ section.settings.fr_akut }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.sa_hours != blank -%}
            <div class="ap-day">
              <div class="ap-day__name">Samstag</div>
              <div class="ap-day__times">
                <span class="ap-time">{{ section.settings.sa_hours }}</span>
                <span class="ap-time--note">nur nach Vereinbarung</span>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.schedule_note != blank -%}
            <div class="ap-note">{{ section.settings.schedule_note | escape }}</div>
          {%- endif -%}

          {%- if infos.size > 0 -%}
            <div class="ap-info-grid">
              {%- for block in infos -%}
                <div class="ap-info-tile ap-reveal" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h4>{{ block.settings.title | escape }}</h4>
                  {%- endif -%}
                  {%- if block.settings.content != blank -%}
                    <div class="ap-info-tile__content">{{ block.settings.content }}</div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- comment -%} ===== CONTACT ===== {%- endcomment -%}
    <div class="ap-section ap-section--white">
      <div class="ap-container">
        <div class="ap-heading ap-reveal">
          <div class="ap-heading__eyebrow">Kontakt</div>
          <h3 class="ap-heading__title">Kontakt &amp; Anfahrt</h3>
        </div>
        <div class="ap-contact-grid ap-reveal">
          <div>
            {%- if section.settings.address != blank -%}
              <div class="ap-contact-item">
                <div class="ap-contact-item__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg></div>
                <div>
                  <div class="ap-contact-item__label">Adresse</div>
                  <div class="ap-contact-item__value">{{ section.settings.address | escape }}</div>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <div class="ap-contact-item">
                <div class="ap-contact-item__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
                <div>
                  <div class="ap-contact-item__label">Telefon</div>
                  <div class="ap-contact-item__value"><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone | escape }}</a></div>
                  {%- if section.settings.phone_private != blank -%}
                    <div class="ap-contact-item__sub">Privatpatienten: <a href="tel:{{ section.settings.phone_private | remove: ' ' | remove: '-' }}">{{ section.settings.phone_private | escape }}</a></div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.fax != blank -%}
              <div class="ap-contact-item">
                <div class="ap-contact-item__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg></div>
                <div>
                  <div class="ap-contact-item__label">Fax</div>
                  <div class="ap-contact-item__value">{{ section.settings.fax | escape }}</div>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.email != blank -%}
              <div class="ap-contact-item">
                <div class="ap-contact-item__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
                <div>
                  <div class="ap-contact-item__label">E-Mail</div>
                  <div class="ap-contact-item__value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a></div>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.website != blank -%}
              <div class="ap-contact-item">
                <div class="ap-contact-item__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95a15.65 15.65 0 00-1.38-3.56A8.03 8.03 0 0118.92 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 015.08 16zm0-8a8.03 8.03 0 014.33-3.56A15.65 15.65 0 008.03 8H5.08zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/></svg></div>
                <div>
                  <div class="ap-contact-item__label">Website</div>
                  <div class="ap-contact-item__value"><a href="{{ section.settings.website }}" target="_blank" rel="noopener noreferrer">{{ section.settings.website | remove: 'https://' | remove: 'http://' | remove_last: '/' }}</a></div>
                </div>
              </div>
            {%- endif -%}

            <div class="ap-ctas">
              {%- if section.settings.doctolib_url != blank -%}
                <a href="{{ section.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="ap-cta-pill">
                  Termin buchen
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12"><path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
              {%- if section.settings.phone != blank -%}
                <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="ap-cta-link">
                  Jetzt anrufen
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12"><path d="M4.5 2L8.5 6L4.5 10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>

          <div class="ap-map">
            {%- if section.settings.maps_embed_url != blank -%}
              <div id="ap-map-consent-{{ section.id }}" class="ap-map-consent">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
                <p>Zum Anzeigen der Karte wird eine Verbindung zu Google Maps hergestellt.</p>
                <button class="ap-map-btn" onclick="document.getElementById('ap-map-consent-{{ section.id }}').style.display='none';document.getElementById('ap-map-frame-{{ section.id }}').innerHTML='<iframe src=&quot;{{ section.settings.maps_embed_url }}&quot; allowfullscreen loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>';">Karte laden</button>
              </div>
              <div id="ap-map-frame-{{ section.id }}"></div>
            {%- else -%}
              <div class="ap-map-consent">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
                <p>Google Maps Embed-URL in den Einstellungen hinterlegen.</p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

  {%- endif -%}
</div>

{%- endunless -%}

{% schema %}
{
  "name": "Juvantis Partnerpraxis",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "default": "GP Medical Center Westend", "label": "Praxisname" },
    { "type": "text", "id": "subtitle", "default": "Praxis Dr. Stracke & Kollegen", "label": "Untertitel" },
    { "type": "textarea", "id": "description", "label": "Beschreibung" },
    { "type": "text", "id": "address", "default": "Grüneburgweg 12, 60322 Frankfurt am Main", "label": "Adresse" },
    { "type": "text", "id": "languages", "default": "DE, EN, FR, ES", "label": "Sprachen (kommagetrennt)" },
    { "type": "text", "id": "button_label", "default": "Termin buchen", "label": "Button Text" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Sprechzeiten" },
    { "type": "text", "id": "mo_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Montag" },
    { "type": "text", "id": "mo_akut", "default": "11:00–12:00", "label": "Montag Akut" },
    { "type": "text", "id": "di_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Dienstag" },
    { "type": "text", "id": "di_akut", "default": "11:00–12:00", "label": "Dienstag Akut" },
    { "type": "text", "id": "mi_hours", "default": "08:00–11:00", "label": "Mittwoch" },
    { "type": "text", "id": "mi_akut", "default": "11:00–12:00", "label": "Mittwoch Akut" },
    { "type": "text", "id": "do_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Donnerstag" },
    { "type": "text", "id": "do_akut", "default": "11:00–12:00", "label": "Donnerstag Akut" },
    { "type": "text", "id": "fr_hours", "default": "08:00–11:00", "label": "Freitag" },
    { "type": "text", "id": "fr_akut", "default": "11:00–12:00", "label": "Freitag Akut" },
    { "type": "text", "id": "sa_hours", "default": "09:00–13:00", "label": "Samstag" },
    { "type": "textarea", "id": "schedule_note", "default": "Akutsprechstunde täglich Mo–Fr 11:00–12:00 Uhr (ohne Termin)", "label": "Sprechzeiten-Hinweis" },
    { "type": "header", "content": "Kontakt" },
    { "type": "text", "id": "phone", "default": "069-247 574 523", "label": "Telefon" },
    { "type": "text", "id": "phone_private", "default": "069-247 574 526", "label": "Privatpatienten" },
    { "type": "text", "id": "fax", "default": "069-97206408", "label": "Fax" },
    { "type": "text", "id": "email", "default": "praxis@westend-hausarzt.de", "label": "E-Mail" },
