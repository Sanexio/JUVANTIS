{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Section header — matches theme pattern */
  #PP-{{ section.id }} .pp-header {
    text-align: center;
    max-width: 80rem;
    margin: 0 auto 4rem;
  }
  #PP-{{ section.id }} .pp-heading {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    line-height: 1.2;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-heading { font-size: 4.8rem; }
  }
  #PP-{{ section.id }} .pp-subtitle {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
    margin-top: 0.8rem;
  }
  #PP-{{ section.id }} .pp-desc {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.6);
    margin-top: 0.4rem;
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
  }
  #PP-{{ section.id }} .pp-langs {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }
  #PP-{{ section.id }} .pp-lang {
    display: inline-block;
    padding: 0.3rem 1rem;
    background: rgba(var(--color-button), 0.08);
    color: rgb(var(--color-button));
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.05rem;
  }
  #PP-{{ section.id }} .pp-header-cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 1.4rem 3.2rem;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.05rem;
    transition: opacity 0.3s ease, transform 0.2s ease;
  }
  #PP-{{ section.id }} .pp-header-cta:hover {
    opacity: 0.9;
    transform: translateY(-0.1rem);
  }

  /* Subsection headers */
  #PP-{{ section.id }} .pp-sub {
    text-align: center;
    margin: 6rem auto 3.2rem;
    max-width: 80rem;
  }
  #PP-{{ section.id }} .pp-sub-title {
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    line-height: 1.2;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-sub-title { font-size: 3.2rem; }
  }
  #PP-{{ section.id }} .pp-sub-desc {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    margin-top: 0.6rem;
  }

  /* Team grid */
  #PP-{{ section.id }} .pp-team {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-team { grid-template-columns: repeat(2, 1fr); }
  }

  /* Doctor card — matches theme card pattern */
  #PP-{{ section.id }} .pp-doc {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding: 3.2rem 2.4rem;
    text-align: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  #PP-{{ section.id }} .pp-doc:hover {
    box-shadow: 0 0.4rem 2.4rem rgba(var(--color-foreground), 0.08);
    transform: translateY(-0.2rem);
  }
  #PP-{{ section.id }} .pp-doc__name {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  #PP-{{ section.id }} .pp-doc__title {
    font-size: 1.4rem;
    color: rgb(var(--color-button));
    font-weight: 500;
    margin-bottom: 0.8rem;
  }
  #PP-{{ section.id }} .pp-doc__quals {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.6);
    white-space: pre-line;
    margin-bottom: 1.2rem;
  }
  #PP-{{ section.id }} .pp-doc__bio {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
  }

  /* CV expandable */
  #PP-{{ section.id }} .pp-cv {
    margin-top: 1.6rem;
    text-align: left;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding-top: 1.2rem;
  }
  #PP-{{ section.id }} .pp-cv summary {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    cursor: pointer;
    color: rgb(var(--color-button));
    list-style: none;
  }
  #PP-{{ section.id }} .pp-cv summary::marker,
  #PP-{{ section.id }} .pp-cv summary::-webkit-details-marker { display: none; }
  #PP-{{ section.id }} .pp-cv summary::before {
    content: '+ ';
  }
  #PP-{{ section.id }} .pp-cv[open] summary::before {
    content: '- ';
  }
  #PP-{{ section.id }} .pp-cv summary:hover { opacity: 0.8; }
  #PP-{{ section.id }} .pp-cv-block { margin-top: 1.2rem; }
  #PP-{{ section.id }} .pp-cv-block h4 {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
    color: rgba(var(--color-foreground), 0.85);
  }
  #PP-{{ section.id }} .pp-cv-text {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.65);
  }
  #PP-{{ section.id }} .pp-cv-text p { margin: 0.3rem 0; }

  /* Services */
  #PP-{{ section.id }} .pp-svc-cat { margin-bottom: 3.2rem; }
  #PP-{{ section.id }} .pp-svc-cat:last-child { margin-bottom: 0; }
  #PP-{{ section.id }} .pp-svc-cat-title {
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 1.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
  }
  #PP-{{ section.id }} .pp-svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-svc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (min-width: 990px) {
    #PP-{{ section.id }} .pp-svc-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Service card — matches DHT showcase */
  #PP-{{ section.id }} .pp-svc {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding: 2.4rem 2rem;
    text-align: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  #PP-{{ section.id }} .pp-svc:hover {
    box-shadow: 0 0.4rem 2.4rem rgba(var(--color-foreground), 0.08);
    transform: translateY(-0.2rem);
  }
  #PP-{{ section.id }} .pp-svc__icon { font-size: 2.4rem; margin-bottom: 1.2rem; }
  #PP-{{ section.id }} .pp-svc__name {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  #PP-{{ section.id }} .pp-svc__desc {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
  }

  /* Schedule table — matches comparison table */
  #PP-{{ section.id }} .pp-schedule { max-width: 72rem; margin: 0 auto; }
  #PP-{{ section.id }} .pp-schedule table {
    width: 100%;
    border-collapse: collapse;
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
  }
  #PP-{{ section.id }} .pp-schedule thead {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
  }
  #PP-{{ section.id }} .pp-schedule th {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    padding: 1.2rem 1.6rem;
    text-align: left;
  }
  #PP-{{ section.id }} .pp-schedule td {
    font-size: 1.3rem;
    padding: 1rem 1.6rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
  }
  #PP-{{ section.id }} .pp-schedule tr:last-child td { border-bottom: none; }
  #PP-{{ section.id }} .pp-day { font-weight: 600; min-width: 9rem; }
  #PP-{{ section.id }} .pp-akut {
    display: inline-block;
    padding: 0.2rem 0.8rem;
    background: rgba(var(--color-button), 0.08);
    color: rgb(var(--color-button));
    font-size: 1.15rem;
    font-weight: 500;
  }
  #PP-{{ section.id }} .pp-schedule-note {
    text-align: center;
    margin-top: 1.6rem;
    padding: 1rem 1.6rem;
    background: rgba(var(--color-button), 0.06);
    border-left: 0.3rem solid rgb(var(--color-button));
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.75);
  }
  @media screen and (max-width: 749px) {
    #PP-{{ section.id }} .pp-schedule thead { display: none; }
    #PP-{{ section.id }} .pp-schedule table,
    #PP-{{ section.id }} .pp-schedule tbody,
    #PP-{{ section.id }} .pp-schedule tr,
    #PP-{{ section.id }} .pp-schedule td { display: block; width: 100%; }
    #PP-{{ section.id }} .pp-schedule tr {
      padding: 1rem 1.4rem;
      border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
    }
    #PP-{{ section.id }} .pp-schedule td { padding: 0.15rem 0; border-bottom: none; }
    #PP-{{ section.id }} .pp-day {
      font-size: 1.5rem;
      color: rgb(var(--color-button));
    }
    #PP-{{ section.id }} .pp-schedule td:before {
      content: attr(data-label);
      font-weight: 500;
      font-size: 1.1rem;
      color: rgba(var(--color-foreground), 0.5);
      display: block;
    }
    #PP-{{ section.id }} .pp-schedule td.pp-day:before { display: none; }
  }

  /* Info cards */
  #PP-{{ section.id }} .pp-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    margin-top: 2.4rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-info-grid { grid-template-columns: repeat(2, 1fr); }
  }
  #PP-{{ section.id }} .pp-info-card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding: 2rem;
  }
  #PP-{{ section.id }} .pp-info-card h4 {
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
  }
  #PP-{{ section.id }} .pp-info-text {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
  }
  #PP-{{ section.id }} .pp-info-text p { margin: 0.3rem 0; }
  #PP-{{ section.id }} .pp-info-text ul { padding-left: 1.6rem; margin: 0.3rem 0; }
  #PP-{{ section.id }} .pp-info-text li { margin-bottom: 0.2rem; }

  /* Contact */
  #PP-{{ section.id }} .pp-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }
  @media screen and (min-width: 750px) {
    #PP-{{ section.id }} .pp-contact-grid { grid-template-columns: 1fr 1fr; }
  }
  #PP-{{ section.id }} .pp-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }
  #PP-{{ section.id }} .pp-contact-icon {
    flex-shrink: 0;
    width: 3.6rem;
    height: 3.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-button), 0.08);
  }
  #PP-{{ section.id }} .pp-contact-icon svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: rgb(var(--color-button));
  }
  #PP-{{ section.id }} .pp-contact-label {
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 0.15rem;
  }
  #PP-{{ section.id }} .pp-contact-value {
    font-size: 1.4rem;
    line-height: 1.5;
  }
  #PP-{{ section.id }} .pp-contact-value a {
    color: rgb(var(--color-button));
    text-decoration: none;
  }
  #PP-{{ section.id }} .pp-contact-value a:hover { text-decoration: underline; }
  #PP-{{ section.id }} .pp-doctolib-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.6rem;
    padding: 1.2rem 2.4rem;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.05rem;
    transition: opacity 0.3s ease, transform 0.2s ease;
  }
  #PP-{{ section.id }} .pp-doctolib-btn:hover {
    opacity: 0.9;
    transform: translateY(-0.1rem);
  }
  #PP-{{ section.id }} .pp-doctolib-btn svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
  }

  /* Map */
  #PP-{{ section.id }} .pp-map-wrapper {
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    overflow: hidden;
    min-height: 32rem;
    background: rgba(var(--color-foreground), 0.03);
  }
  #PP-{{ section.id }} .pp-map-wrapper iframe {
    width: 100%; height: 100%; min-height: 32rem; border: none;
  }
  #PP-{{ section.id }} .pp-map-consent {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 32rem; padding: 2.8rem; text-align: center;
  }
  #PP-{{ section.id }} .pp-map-consent svg {
    width: 4rem; height: 4rem; fill: rgba(var(--color-foreground), 0.2); margin-bottom: 1.2rem;
  }
  #PP-{{ section.id }} .pp-map-consent p {
    font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin-bottom: 1.2rem; max-width: 32rem;
  }
  #PP-{{ section.id }} .pp-map-btn {
    padding: 0.8rem 2rem;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-size: 1.3rem; font-weight: 500;
    border: none; cursor: pointer;
    transition: opacity 0.3s ease;
  }
  #PP-{{ section.id }} .pp-map-btn:hover { opacity: 0.9; }
{%- endstyle -%}

{%- comment -%} Only render on dedicated page, not on homepage (Shopify rendering instance workaround) {%- endcomment -%}
{%- if template.name == 'index' -%}{%- break -%}{%- endif -%}

{%- assign doctors = section.blocks | where: "type", "doctor" -%}
{%- assign services = section.blocks | where: "type", "service" -%}
{%- assign infos = section.blocks | where: "type", "schedule_info" -%}
{%- assign is_full = false -%}
{%- if doctors.size > 0 -%}{%- assign is_full = true -%}{%- endif -%}

<div id="PP-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">

    {%- comment -%} HEADER {%- endcomment -%}
    <div class="pp-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="pp-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="pp-subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="pp-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
      {%- if section.settings.languages != blank -%}
        <div class="pp-langs">
          {%- assign langs = section.settings.languages | split: ',' -%}
          {%- for lang in langs -%}
            <span class="pp-lang">{{ lang | strip | escape }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if is_full == false and section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="pp-header-cta">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>

    {%- if is_full -%}

      {%- comment -%} TEAM {%- endcomment -%}
      <div class="pp-sub">
        <h3 class="pp-sub-title">Unser Team</h3>
        <p class="pp-sub-desc">Erfahrene Fach&auml;rzte mit internationaler Kompetenz</p>
      </div>
      <div class="pp-team">
        {%- for block in doctors -%}
          <div class="pp-doc" {{ block.shopify_attributes }}>
            <h4 class="pp-doc__name">{{ block.settings.name | escape }}</h4>
            {%- if block.settings.title != blank -%}
              <p class="pp-doc__title">{{ block.settings.title | escape }}</p>
            {%- endif -%}
            {%- if block.settings.qualifications != blank -%}
              <p class="pp-doc__quals">{{ block.settings.qualifications | escape }}</p>
            {%- endif -%}
            {%- if block.settings.bio != blank -%}
              <p class="pp-doc__bio">{{ block.settings.bio | escape }}</p>
            {%- endif -%}
            {%- if block.settings.career != blank or block.settings.education != blank -%}
              <details class="pp-cv">
                <summary>Vollst&auml;ndiger Lebenslauf</summary>
                {%- if block.settings.career != blank -%}
                  <div class="pp-cv-block">
                    <h4>Berufliche Erfahrung</h4>
                    <div class="pp-cv-text">{{ block.settings.career }}</div>
                  </div>
                {%- endif -%}
                {%- if block.settings.education != blank -%}
                  <div class="pp-cv-block">
                    <h4>Ausbildung</h4>
                    <div class="pp-cv-text">{{ block.settings.education }}</div>
                  </div>
                {%- endif -%}
              </details>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} SERVICES {%- endcomment -%}
      {%- if services.size > 0 -%}
        <div class="pp-sub">
          <h3 class="pp-sub-title">Unsere Leistungen</h3>
          <p class="pp-sub-desc">Umfassende haus&auml;rztliche und internistische Versorgung mit modernster Diagnostik</p>
        </div>
        {%- assign categories = "" -%}
        {%- for block in services -%}
          {%- unless categories contains block.settings.category -%}
            {%- if categories != "" -%}{%- assign categories = categories | append: "|||" -%}{%- endif -%}
            {%- assign categories = categories | append: block.settings.category -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign cat_list = categories | split: "|||" -%}
        {%- for cat in cat_list -%}
          <div class="pp-svc-cat">
            {%- if cat != blank -%}
              <h4 class="pp-svc-cat-title">{{ cat | escape }}</h4>
            {%- endif -%}
            <div class="pp-svc-grid">
              {%- for block in services -%}
                {%- if block.settings.category == cat -%}
                  <div class="pp-svc" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <div class="pp-svc__icon">{{ block.settings.icon }}</div>
                    {%- endif -%}
                    <h5 class="pp-svc__name">{{ block.settings.name | escape }}</h5>
                    {%- if block.settings.description != blank -%}
                      <p class="pp-svc__desc">{{ block.settings.description | escape }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} SCHEDULE {%- endcomment -%}
      <div class="pp-sub">
        <h3 class="pp-sub-title">Sprechzeiten</h3>
      </div>
      <div class="pp-schedule">
        <table>
          <thead><tr><th>Tag</th><th>Sprechstunde</th><th>Akut</th></tr></thead>
          <tbody>
            <tr>
              <td class="pp-day">Montag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.mo_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.mo_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Dienstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.di_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.di_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Mittwoch</td>
              <td data-label="Sprechstunde: ">{{ section.settings.mi_hours | default: "08:00–11:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.mi_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Donnerstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.do_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.do_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Freitag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.fr_hours | default: "08:00–11:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.fr_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Samstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.sa_hours | default: "09:00–13:00" }}</td>
              <td data-label="">nur nach Vereinbarung</td>
            </tr>
          </tbody>
        </table>

        {%- if section.settings.schedule_note != blank -%}
          <div class="pp-schedule-note">{{ section.settings.schedule_note | escape }}</div>
        {%- endif -%}

        {%- if infos.size > 0 -%}
          <div class="pp-info-grid">
            {%- for block in infos -%}
              <div class="pp-info-card" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4>{{ block.settings.title | escape }}</h4>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="pp-info-text">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} CONTACT {%- endcomment -%}
      <div class="pp-sub">
        <h3 class="pp-sub-title">Kontakt &amp; Anfahrt</h3>
      </div>
      <div class="pp-contact-grid">
        <div>
          {%- if section.settings.address != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg></div>
              <div>
                <div class="pp-contact-label">Adresse</div>
                <div class="pp-contact-value">{{ section.settings.address | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
              <div>
                <div class="pp-contact-label">Telefon</div>
                <div class="pp-contact-value"><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone | escape }}</a></div>
                {%- if section.settings.phone_private != blank -%}
                  <div class="pp-contact-label" style="margin-top:0.6rem;">Privatpatienten</div>
                  <div class="pp-contact-value"><a href="tel:{{ section.settings.phone_private | remove: ' ' | remove: '-' }}">{{ section.settings.phone_private | escape }}</a></div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.fax != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg></div>
              <div>
                <div class="pp-contact-label">Fax</div>
                <div class="pp-contact-value">{{ section.settings.fax | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
              <div>
                <div class="pp-contact-label">E-Mail</div>
                <div class="pp-contact-value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a></div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.website != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95a15.65 15.65 0 00-1.38-3.56A8.03 8.03 0 0118.92 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 015.08 16zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/></svg></div>
              <div>
                <div class="pp-contact-label">Website</div>
                <div class="pp-contact-value"><a href="{{ section.settings.website }}" target="_blank" rel="noopener noreferrer">{{ section.settings.website | remove: 'https://' | remove: 'http://' | remove_last: '/' }}</a></div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.doctolib_url != blank -%}
            <a href="{{ section.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="pp-doctolib-btn">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z"/></svg>
              Online-Termin buchen
            </a>
          {%- endif -%}
        </div>
        <div class="pp-map-wrapper">
          {%- if section.settings.maps_embed_url != blank -%}
            <div id="pp-map-consent-{{ section.id }}" class="pp-map-consent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              <p>Zum Anzeigen der Karte wird eine Verbindung zu Google Maps hergestellt.</p>
              <button class="pp-map-btn" onclick="document.getElementById('pp-map-consent-{{ section.id }}').style.display='none';document.getElementById('pp-map-frame-{{ section.id }}').innerHTML='<iframe src=&quot;{{ section.settings.maps_embed_url }}&quot; allowfullscreen loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>';">Karte laden</button>
            </div>
            <div id="pp-map-frame-{{ section.id }}"></div>
          {%- else -%}
            <div class="pp-map-consent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              <p>Google Maps Embed-URL in den Einstellungen hinterlegen.</p>
            </div>
          {%- endif -%}
        </div>
      </div>

    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Juvantis Partnerpraxis",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "default": "GP Medical Center Westend", "label": "Praxisname" },
    { "type": "text", "id": "subtitle", "default": "Praxis Dr. Stracke & Kollegen", "label": "Untertitel" },
    { "type": "textarea", "id": "description", "label": "Beschreibung" },
    { "type": "text", "id": "address", "default": "Grüneburgweg 12, 60322 Frankfurt am Main", "label": "Adresse" },
    { "type": "text", "id": "languages", "default": "DE, EN, FR, ES", "label": "Sprachen (kommagetrennt)" },
    { "type": "text", "id": "button_label", "default": "Termin buchen", "label": "Button Text" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Sprechzeiten" },
    { "type": "text", "id": "mo_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Montag" },
    { "type": "text", "id": "mo_akut", "default": "11:00–12:00", "label": "Montag Akut" },
    { "type": "text", "id": "di_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Dienstag" },
    { "type": "text", "id": "di_akut", "default": "11:00–12:00", "label": "Dienstag Akut" },
    { "type": "text", "id": "mi_hours", "default": "08:00–11:00", "label": "Mittwoch" },
    { "type": "text", "id": "mi_akut", "default": "11:00–12:00", "label": "Mittwoch Akut" },
    { "type": "text", "id": "do_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Donnerstag" },
    { "type": "text", "id": "do_akut", "default": "11:00–12:00", "label": "Donnerstag Akut" },
    { "type": "text", "id": "fr_hours", "default": "08:00–11:00", "label": "Freitag" },
    { "type": "text", "id": "fr_akut", "default": "11:00–12:00", "label": "Freitag Akut" },
    { "type": "text", "id": "sa_hours", "default": "09:00–13:00", "label": "Samstag" },
    { "type": "textarea", "id": "schedule_note", "default": "Akutsprechstunde täglich Mo–Fr 11:00–12:00 Uhr (ohne Termin)", "label": "Sprechzeiten-Hinweis" },
    { "type": "header", "content": "Kontakt" },
    { "type": "text", "id": "phone", "default": "069-247 574 523", "label": "Telefon" },
    { "type": "text", "id": "phone_private", "default": "069-247 574 526", "label": "Privatpatienten" },
    { "type": "text", "id": "fax", "default": "069-97206408", "label": "Fax" },
    { "type": "text", "id": "email", "default": "praxis@westend-hausarzt.de", "label": "E-Mail" },
    { "type": "url", "id": "website", "label": "Website" },
    { "type": "url", "id": "doctolib_url", "label": "Doctolib" },
    { "type": "text", "id": "maps_embed_url", "label": "Google Maps Embed-URL" },
    { "type": "select", "id": "color_scheme", "options": [
      { "value": "accent-1", "label": "Akzent 1" },
      { "value": "accent-2", "label": "Akzent 2" },
      { "value": "background-1", "label": "Hintergrund 1" },
      { "value": "background-2", "label": "Hintergrund 2" },
      { "value": "inverse", "label": "Invertiert" }
    ], "default": "background-2", "label": "Farbschema" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand oben", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand unten", "default": 52 }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Arzt / Ärztin",
      "settings": [
        { "type": "text", "id": "name", "default": "Dr. med.", "label": "Name" },
        { "type": "text", "id": "title", "label": "Fachbezeichnung" },
        { "type": "textarea", "id": "qualifications", "label": "Qualifikationen" },
        { "type": "textarea", "id": "bio", "label": "Biografie" },
        { "type": "richtext", "id": "career", "label": "Berufliche Erfahrung" },
        { "type": "richtext", "id": "education", "label": "Ausbildung" }
      ]
    },
    {
      "type": "service",
      "name": "Leistung",
      "settings": [
        { "type": "text", "id": "icon", "default": "🩺", "label": "Icon" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "description", "label": "Beschreibung" },
        { "type": "text", "id": "category", "default": "Weitere Leistungen", "label": "Kategorie" }
      ]
    },
    {
      "type": "schedule_info",
      "name": "Sprechzeiten-Info",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "richtext", "id": "content", "label": "Inhalt" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis Partnerpraxis" }]
}
{% endschema %}
