{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Hero */
  #PartnerPraxis-{{ section.id }} .pp-hero {
    position: relative;
    overflow: hidden;
    min-height: 40rem;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, rgba(78, 161, 217, 0.88) 0%, rgba(115, 194, 94, 0.72) 100%);
    margin-bottom: 4rem;
    border-radius: 0.8rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 76rem;
    margin: 0 auto;
    padding: 4rem 2rem;
    color: #fff;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 0.6rem;
    color: #fff;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-hero__heading { font-size: 4.8rem; }
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__subtitle {
    font-size: 1.8rem;
    margin-bottom: 1.2rem;
    color: rgba(255,255,255,0.92);
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__desc {
    font-size: 1.5rem;
    line-height: 1.65;
    margin-bottom: 2rem;
    color: rgba(255,255,255,0.88);
    max-width: 62rem;
    margin-left: auto;
    margin-right: auto;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__langs {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__lang {
    padding: 0.35rem 1rem;
    border: 0.1rem solid rgba(255,255,255,0.5);
    border-radius: 2rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    background: rgba(255,255,255,0.12);
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__addr {
    font-size: 1.35rem;
    color: rgba(255,255,255,0.82);
    margin-bottom: 2rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__cta {
    display: inline-block;
    padding: 1.2rem 3.2rem;
    background: #fff;
    color: #4ea1d9;
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.4rem;
    transition: background 0.3s, transform 0.2s;
  }
  #PartnerPraxis-{{ section.id }} .pp-hero__cta:hover {
    background: #f0f0f0;
    transform: translateY(-0.15rem);
  }

  /* Sub-section headings */
  #PartnerPraxis-{{ section.id }} .pp-section-title {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 1rem;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-section-title { font-size: 3.6rem; }
  }
  #PartnerPraxis-{{ section.id }} .pp-section-desc {
    text-align: center;
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.7);
    margin-bottom: 3rem;
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
  }
  #PartnerPraxis-{{ section.id }} .pp-subsection {
    margin-bottom: 5rem;
  }

  /* Team */
  #PartnerPraxis-{{ section.id }} .pp-team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.8rem;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-team-grid { grid-template-columns: repeat(2, 1fr); }
  }
  #PartnerPraxis-{{ section.id }} .pp-doc {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    padding: 2.4rem;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc:hover {
    box-shadow: 0 0.6rem 2.4rem rgba(var(--color-foreground), 0.07);
    transform: translateY(-0.15rem);
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__name {
    font-family: var(--font-heading-family);
    font-size: 1.9rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__title {
    font-size: 1.35rem;
    font-weight: 500;
    color: #4ea1d9;
    margin-bottom: 0.6rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__quals {
    font-size: 1.25rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.6);
    margin-bottom: 1.2rem;
    white-space: pre-line;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__bio {
    font-size: 1.35rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.75);
    margin-bottom: 1.2rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__cv {
    margin-top: 1.2rem;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    padding-top: 1rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__cv summary {
    cursor: pointer;
    font-size: 1.35rem;
    font-weight: 600;
    color: #4ea1d9;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__cv summary::-webkit-details-marker { display: none; }
  #PartnerPraxis-{{ section.id }} .pp-doc__cv summary::after {
    content: '\25B8';
    transition: transform 0.2s;
  }
  #PartnerPraxis-{{ section.id }} .pp-doc__cv[open] summary::after {
    transform: rotate(90deg);
  }
  #PartnerPraxis-{{ section.id }} .pp-cv-block {
    margin-top: 1.2rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-cv-block h4 {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
    color: rgba(var(--color-foreground), 0.85);
  }
  #PartnerPraxis-{{ section.id }} .pp-cv-block .pp-cv-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.65);
  }
  #PartnerPraxis-{{ section.id }} .pp-cv-text p { margin: 0.3rem 0; }

  /* Services */
  #PartnerPraxis-{{ section.id }} .pp-svc-cat {
    margin-bottom: 2.4rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-cat__title {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 0.2rem solid #4ea1d9;
    color: #4ea1d9;
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-svc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (min-width: 990px) {
    #PartnerPraxis-{{ section.id }} .pp-svc-grid { grid-template-columns: repeat(3, 1fr); }
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    padding: 2rem 1.6rem;
    transition: box-shadow 0.3s, transform 0.3s, border-color 0.3s;
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-card:hover {
    box-shadow: 0 0.3rem 1.6rem rgba(var(--color-foreground), 0.06);
    transform: translateY(-0.15rem);
    border-color: #4ea1d9;
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-card__icon { font-size: 2.8rem; margin-bottom: 0.8rem; }
  #PartnerPraxis-{{ section.id }} .pp-svc-card__name {
    font-family: var(--font-heading-family);
    font-size: 1.45rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-svc-card__desc {
    font-size: 1.25rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* Schedule */
  #PartnerPraxis-{{ section.id }} .pp-schedule {
    max-width: 72rem;
    margin: 0 auto;
  }
  #PartnerPraxis-{{ section.id }} .pp-schedule table {
    width: 100%;
    border-collapse: collapse;
    background: rgb(var(--color-background));
    border-radius: 0.8rem;
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
  }
  #PartnerPraxis-{{ section.id }} .pp-schedule thead {
    background: #4ea1d9;
    color: #fff;
  }
  #PartnerPraxis-{{ section.id }} .pp-schedule th {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    padding: 1.2rem 1.4rem;
    text-align: left;
  }
  #PartnerPraxis-{{ section.id }} .pp-schedule td {
    font-size: 1.3rem;
    padding: 1rem 1.4rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
  }
  #PartnerPraxis-{{ section.id }} .pp-schedule tr:last-child td { border-bottom: none; }
  #PartnerPraxis-{{ section.id }} .pp-schedule .pp-day { font-weight: 600; min-width: 9rem; }
  #PartnerPraxis-{{ section.id }} .pp-schedule .pp-akut {
    display: inline-block;
    padding: 0.15rem 0.7rem;
    background: rgba(115,194,94,0.12);
    color: #4a8c3a;
    border-radius: 0.4rem;
    font-size: 1.15rem;
    font-weight: 500;
  }
  #PartnerPraxis-{{ section.id }} .pp-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin-top: 2rem;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-info-grid { grid-template-columns: repeat(2, 1fr); }
  }
  #PartnerPraxis-{{ section.id }} .pp-info-card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    padding: 1.6rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-info-card h4 {
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-info-card .pp-info-text {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
  }
  #PartnerPraxis-{{ section.id }} .pp-info-card .pp-info-text p { margin: 0.3rem 0; }
  #PartnerPraxis-{{ section.id }} .pp-info-card .pp-info-text ul { padding-left: 1.4rem; margin: 0.3rem 0; }
  #PartnerPraxis-{{ section.id }} .pp-info-card .pp-info-text li { margin-bottom: 0.2rem; }
  @media screen and (max-width: 749px) {
    #PartnerPraxis-{{ section.id }} .pp-schedule thead { display: none; }
    #PartnerPraxis-{{ section.id }} .pp-schedule table,
    #PartnerPraxis-{{ section.id }} .pp-schedule tbody,
    #PartnerPraxis-{{ section.id }} .pp-schedule tr,
    #PartnerPraxis-{{ section.id }} .pp-schedule td { display: block; width: 100%; }
    #PartnerPraxis-{{ section.id }} .pp-schedule tr { padding: 1rem 1.4rem; border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06); }
    #PartnerPraxis-{{ section.id }} .pp-schedule td { padding: 0.15rem 0; border-bottom: none; }
    #PartnerPraxis-{{ section.id }} .pp-schedule .pp-day { font-size: 1.5rem; color: #4ea1d9; }
    #PartnerPraxis-{{ section.id }} .pp-schedule td:before { content: attr(data-label); font-weight: 500; font-size: 1.1rem; color: rgba(var(--color-foreground), 0.5); display: block; }
    #PartnerPraxis-{{ section.id }} .pp-schedule td.pp-day:before { display: none; }
  }

  /* Contact */
  #PartnerPraxis-{{ section.id }} .pp-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.8rem;
  }
  @media screen and (min-width: 750px) {
    #PartnerPraxis-{{ section.id }} .pp-contact-grid { grid-template-columns: 1fr 1fr; }
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-icon {
    flex-shrink: 0;
    width: 3.6rem;
    height: 3.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(78,161,217,0.1);
    border-radius: 0.6rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-icon svg { width: 1.8rem; height: 1.8rem; fill: #4ea1d9; }
  #PartnerPraxis-{{ section.id }} .pp-contact-label {
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 0.15rem;
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-value {
    font-size: 1.4rem;
    line-height: 1.5;
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-value a {
    color: #4ea1d9;
    text-decoration: none;
  }
  #PartnerPraxis-{{ section.id }} .pp-contact-value a:hover { color: #73c25e; }
  #PartnerPraxis-{{ section.id }} .pp-doctolib-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1rem;
    padding: 1rem 2.4rem;
    background: #4ea1d9;
    color: #fff;
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.4rem;
    transition: background 0.3s;
  }
  #PartnerPraxis-{{ section.id }} .pp-doctolib-btn:hover { background: #3d8ec4; }
  #PartnerPraxis-{{ section.id }} .pp-doctolib-btn svg { width: 1.6rem; height: 1.6rem; fill: currentColor; }
  #PartnerPraxis-{{ section.id }} .pp-map-wrapper {
    border-radius: 0.8rem;
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    min-height: 32rem;
    background: rgba(var(--color-foreground), 0.03);
  }
  #PartnerPraxis-{{ section.id }} .pp-map-wrapper iframe {
    width: 100%; height: 100%; min-height: 32rem; border: none;
  }
  #PartnerPraxis-{{ section.id }} .pp-map-consent {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 32rem; padding: 2.8rem; text-align: center;
  }
  #PartnerPraxis-{{ section.id }} .pp-map-consent svg { width: 4rem; height: 4rem; fill: rgba(var(--color-foreground), 0.2); margin-bottom: 1.2rem; }
  #PartnerPraxis-{{ section.id }} .pp-map-consent p { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6); margin-bottom: 1.2rem; max-width: 32rem; }
  #PartnerPraxis-{{ section.id }} .pp-map-btn {
    padding: 0.8rem 2rem; background: #4ea1d9; color: #fff; font-size: 1.3rem; font-weight: 500;
    border: none; border-radius: 0.4rem; cursor: pointer;
  }
  #PartnerPraxis-{{ section.id }} .pp-map-btn:hover { background: #3d8ec4; }
{%- endstyle -%}

<div id="PartnerPraxis-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">

    {%- comment -%} HERO {%- endcomment -%}
    <div class="pp-hero">
      <div class="pp-hero__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="pp-hero__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="pp-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="pp-hero__desc">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        {%- if section.settings.languages != blank -%}
          <div class="pp-hero__langs">
            {%- assign langs = section.settings.languages | split: ',' -%}
            {%- for lang in langs -%}
              <span class="pp-hero__lang">{{ lang | strip | escape }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <p class="pp-hero__addr">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="width:1.4rem;height:1.4rem;vertical-align:middle;fill:currentColor;margin-right:0.3rem;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
            {{ section.settings.address | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" target="_blank" rel="noopener noreferrer" class="pp-hero__cta">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} TEAM {%- endcomment -%}
    {%- assign doctors = section.blocks | where: "type", "doctor" -%}
    {%- if doctors.size > 0 -%}
      <div class="pp-subsection">
        <h3 class="pp-section-title">Unser Team</h3>
        <p class="pp-section-desc">Erfahrene Fach&auml;rzte mit internationaler Kompetenz</p>
        <div class="pp-team-grid">
          {%- for block in doctors -%}
            <div class="pp-doc" {{ block.shopify_attributes }}>
              <h4 class="pp-doc__name">{{ block.settings.name | escape }}</h4>
              {%- if block.settings.title != blank -%}
                <p class="pp-doc__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
              {%- if block.settings.qualifications != blank -%}
                <p class="pp-doc__quals">{{ block.settings.qualifications | escape }}</p>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="pp-doc__bio">{{ block.settings.bio | escape }}</p>
              {%- endif -%}
              {%- if block.settings.career != blank or block.settings.education != blank -%}
                <details class="pp-doc__cv">
                  <summary>Vollst&auml;ndiger Lebenslauf</summary>
                  {%- if block.settings.career != blank -%}
                    <div class="pp-cv-block">
                      <h4>Berufliche Erfahrung</h4>
                      <div class="pp-cv-text">{{ block.settings.career }}</div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.education != blank -%}
                    <div class="pp-cv-block">
                      <h4>Ausbildung</h4>
                      <div class="pp-cv-text">{{ block.settings.education }}</div>
                    </div>
                  {%- endif -%}
                </details>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} SERVICES {%- endcomment -%}
    {%- assign services = section.blocks | where: "type", "service" -%}
    {%- if services.size > 0 -%}
      <div class="pp-subsection">
        <h3 class="pp-section-title">Unsere Leistungen</h3>
        <p class="pp-section-desc">Umfassende haus&auml;rztliche und internistische Versorgung mit modernster Diagnostik</p>
        {%- assign categories = "" -%}
        {%- for block in services -%}
          {%- unless categories contains block.settings.category -%}
            {%- if categories != "" -%}{%- assign categories = categories | append: "|||" -%}{%- endif -%}
            {%- assign categories = categories | append: block.settings.category -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign cat_list = categories | split: "|||" -%}
        {%- for cat in cat_list -%}
          <div class="pp-svc-cat">
            {%- if cat != blank -%}
              <h4 class="pp-svc-cat__title">{{ cat | escape }}</h4>
            {%- endif -%}
            <div class="pp-svc-grid">
              {%- for block in services -%}
                {%- if block.settings.category == cat -%}
                  <div class="pp-svc-card" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <div class="pp-svc-card__icon">{{ block.settings.icon }}</div>
                    {%- endif -%}
                    <h5 class="pp-svc-card__name">{{ block.settings.name | escape }}</h5>
                    {%- if block.settings.description != blank -%}
                      <p class="pp-svc-card__desc">{{ block.settings.description | escape }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} SCHEDULE {%- endcomment -%}
    <div class="pp-subsection">
      <h3 class="pp-section-title">Sprechzeiten</h3>
      <div class="pp-schedule">
        <table>
          <thead><tr><th>Tag</th><th>Sprechstunde</th><th>Akut</th></tr></thead>
          <tbody>
            <tr>
              <td class="pp-day">Montag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.mo_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.mo_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Dienstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.di_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.di_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Mittwoch</td>
              <td data-label="Sprechstunde: ">{{ section.settings.mi_hours | default: "08:00–11:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.mi_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Donnerstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.do_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.do_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Freitag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.fr_hours | default: "08:00–11:00" }}</td>
              <td data-label="Akut: "><span class="pp-akut">{{ section.settings.fr_akut | default: "11:00–12:00" }}</span></td>
            </tr>
            <tr>
              <td class="pp-day">Samstag</td>
              <td data-label="Sprechstunde: ">{{ section.settings.sa_hours | default: "09:00–13:00" }}</td>
              <td data-label="">nur nach Vereinbarung</td>
            </tr>
          </tbody>
        </table>

        {%- if section.settings.schedule_note != blank -%}
          <div style="text-align:center;margin-top:1.6rem;padding:1.2rem 1.6rem;background:rgba(115,194,94,0.08);border-left:0.3rem solid #73c25e;border-radius:0.4rem;font-size:1.3rem;color:rgba(var(--color-foreground),0.75);">
            {{ section.settings.schedule_note | escape }}
          </div>
        {%- endif -%}

        {%- assign infos = section.blocks | where: "type", "schedule_info" -%}
        {%- if infos.size > 0 -%}
          <div class="pp-info-grid">
            {%- for block in infos -%}
              <div class="pp-info-card" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4>{{ block.settings.title | escape }}</h4>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="pp-info-text">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} CONTACT {%- endcomment -%}
    <div class="pp-subsection">
      <h3 class="pp-section-title">Kontakt &amp; Anfahrt</h3>
      <div class="pp-contact-grid">
        <div>
          {%- if section.settings.address != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg></div>
              <div>
                <div class="pp-contact-label">Adresse</div>
                <div class="pp-contact-value">{{ section.settings.address | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
              <div>
                <div class="pp-contact-label">Telefon</div>
                <div class="pp-contact-value"><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone | escape }}</a></div>
                {%- if section.settings.phone_private != blank -%}
                  <div class="pp-contact-label" style="margin-top:0.6rem;">Privatpatienten</div>
                  <div class="pp-contact-value"><a href="tel:{{ section.settings.phone_private | remove: ' ' | remove: '-' }}">{{ section.settings.phone_private | escape }}</a></div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.fax != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg></div>
              <div>
                <div class="pp-contact-label">Fax</div>
                <div class="pp-contact-value">{{ section.settings.fax | escape }}</div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
              <div>
                <div class="pp-contact-label">E-Mail</div>
                <div class="pp-contact-value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a></div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.website != blank -%}
            <div class="pp-contact-item">
              <div class="pp-contact-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95a15.65 15.65 0 00-1.38-3.56A8.03 8.03 0 0118.92 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 015.08 16zm2.95-8H5.08a7.987 7.987 0 014.33-3.56A15.65 15.65 0 008.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/></svg></div>
              <div>
                <div class="pp-contact-label">Website</div>
                <div class="pp-contact-value"><a href="{{ section.settings.website }}" target="_blank" rel="noopener noreferrer">{{ section.settings.website | remove: 'https://' | remove: 'http://' | remove_last: '/' }}</a></div>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.doctolib_url != blank -%}
            <a href="{{ section.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="pp-doctolib-btn">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm-7 5h5v5h-5v-5z"/></svg>
              Online-Termin buchen
            </a>
          {%- endif -%}
        </div>
        <div class="pp-map-wrapper">
          {%- if section.settings.maps_embed_url != blank -%}
            <div id="pp-map-consent-{{ section.id }}" class="pp-map-consent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              <p>Zum Anzeigen der Karte wird eine Verbindung zu Google Maps hergestellt.</p>
              <button class="pp-map-btn" onclick="document.getElementById('pp-map-consent-{{ section.id }}').style.display='none';document.getElementById('pp-map-frame-{{ section.id }}').innerHTML='<iframe src=&quot;{{ section.settings.maps_embed_url }}&quot; allowfullscreen loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>';">Karte laden</button>
            </div>
            <div id="pp-map-frame-{{ section.id }}"></div>
          {%- else -%}
            <div class="pp-map-consent">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
              <p>Google Maps Embed-URL in den Einstellungen hinterlegen.</p>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Juvantis Partnerpraxis",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "default": "GP Medical Center Westend", "label": "Praxisname" },
    { "type": "text", "id": "subtitle", "default": "Praxis Dr. Stracke & Kollegen", "label": "Untertitel" },
    { "type": "textarea", "id": "description", "label": "Beschreibung" },
    { "type": "text", "id": "address", "default": "Grüneburgweg 12, 60322 Frankfurt am Main", "label": "Adresse" },
    { "type": "text", "id": "languages", "default": "DE, EN, FR, ES", "label": "Sprachen (kommagetrennt)" },
    { "type": "text", "id": "button_label", "default": "Termin buchen", "label": "Hero Button Text" },
    { "type": "url", "id": "button_link", "label": "Hero Button Link" },
    { "type": "header", "content": "Sprechzeiten" },
    { "type": "text", "id": "mo_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Montag" },
    { "type": "text", "id": "mo_akut", "default": "11:00–12:00", "label": "Montag Akut" },
    { "type": "text", "id": "di_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Dienstag" },
    { "type": "text", "id": "di_akut", "default": "11:00–12:00", "label": "Dienstag Akut" },
    { "type": "text", "id": "mi_hours", "default": "08:00–11:00", "label": "Mittwoch" },
    { "type": "text", "id": "mi_akut", "default": "11:00–12:00", "label": "Mittwoch Akut" },
    { "type": "text", "id": "do_hours", "default": "08:00–11:00, 12:30–16:00", "label": "Donnerstag" },
    { "type": "text", "id": "do_akut", "default": "11:00–12:00", "label": "Donnerstag Akut" },
    { "type": "text", "id": "fr_hours", "default": "08:00–11:00", "label": "Freitag" },
    { "type": "text", "id": "fr_akut", "default": "11:00–12:00", "label": "Freitag Akut" },
    { "type": "text", "id": "sa_hours", "default": "09:00–13:00", "label": "Samstag" },
    { "type": "textarea", "id": "schedule_note", "default": "Akutsprechstunde täglich Mo–Fr 11:00–12:00 Uhr (ohne Termin)", "label": "Sprechzeiten-Hinweis" },
    { "type": "header", "content": "Kontakt" },
    { "type": "text", "id": "phone", "default": "069-247 574 523", "label": "Telefon" },
    { "type": "text", "id": "phone_private", "default": "069-247 574 526", "label": "Privatpatienten" },
    { "type": "text", "id": "fax", "default": "069-97206408", "label": "Fax" },
    { "type": "text", "id": "email", "default": "praxis@westend-hausarzt.de", "label": "E-Mail" },
    { "type": "url", "id": "website", "label": "Website" },
    { "type": "url", "id": "doctolib_url", "label": "Doctolib" },
    { "type": "text", "id": "maps_embed_url", "label": "Google Maps Embed-URL" },
    { "type": "select", "id": "color_scheme", "options": [
      { "value": "accent-1", "label": "Akzent 1" },
      { "value": "accent-2", "label": "Akzent 2" },
      { "value": "background-1", "label": "Hintergrund 1" },
      { "value": "background-2", "label": "Hintergrund 2" },
      { "value": "inverse", "label": "Invertiert" }
    ], "default": "background-2", "label": "Farbschema" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand oben", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand unten", "default": 52 }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Arzt / Ärztin",
      "settings": [
        { "type": "text", "id": "name", "default": "Dr. med.", "label": "Name" },
        { "type": "text", "id": "title", "label": "Fachbezeichnung" },
        { "type": "textarea", "id": "qualifications", "label": "Qualifikationen" },
        { "type": "textarea", "id": "bio", "label": "Biografie" },
        { "type": "richtext", "id": "career", "label": "Berufliche Erfahrung" },
        { "type": "richtext", "id": "education", "label": "Ausbildung" }
      ]
    },
    {
      "type": "service",
      "name": "Leistung",
      "settings": [
        { "type": "text", "id": "icon", "default": "🩺", "label": "Icon" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "description", "label": "Beschreibung" },
        { "type": "text", "id": "category", "default": "Weitere Leistungen", "label": "Kategorie" }
      ]
    },
    {
      "type": "schedule_info",
      "name": "Sprechzeiten-Info",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "richtext", "id": "content", "label": "Inhalt" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis Partnerpraxis" }]
}
{% endschema %}
