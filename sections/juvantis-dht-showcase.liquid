{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__header {
    text-align: center;
    max-width: 80rem;
    margin: 0 auto 4rem;
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__heading {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    line-height: 1.2;
    margin-bottom: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    #DHTShowcase-{{ section.id }} .dht-showcase__heading {
      font-size: 4.8rem;
    }
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 64rem;
    margin: 0 auto;
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }

  @media screen and (min-width: 750px) {
    #DHTShowcase-{{ section.id }} .dht-showcase__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    #DHTShowcase-{{ section.id }} .dht-showcase__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__feature {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding: 3.2rem 2.4rem;
    text-align: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__feature:hover {
    box-shadow: 0 0.4rem 2.4rem rgba(var(--color-foreground), 0.08);
    transform: translateY(-0.2rem);
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__feature-icon {
    font-size: 3.6rem;
    margin-bottom: 1.6rem;
    display: block;
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__feature-title {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__feature-text {
    font-size: 1.4rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
  }

  #DHTShowcase-{{ section.id }} .dht-showcase__cta {
    text-align: center;
    margin-top: 4rem;
  }
{%- endstyle -%}

<div
  id="DHTShowcase-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="dht-showcase__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="dht-showcase__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="dht-showcase__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="dht-showcase__grid">
        {%- for block in section.blocks -%}
          <div class="dht-showcase__feature" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="dht-showcase__feature-icon">{{ block.settings.icon }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="dht-showcase__feature-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="dht-showcase__feature-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="dht-showcase__cta">
        <a
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
          class="button button--primary"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Juvantis DHT Showcase",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Dein Digital Health Twin",
      "label": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Ein personalisierter 3D-Avatar, der deine Gesundheitsdaten visualisiert. Sieh auf einen Blick, wie es deinem Körper wirklich geht — basierend auf echten Laborwerten, Vitalzeichen und medizinischen Check-ups.",
      "label": "Beschreibung"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Starte deinen DHT",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-1",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "default": "🧬",
          "label": "Icon (Emoji)"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Feature",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Beschreibung des Features",
          "label": "Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis DHT Showcase",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "🧴",
            "title": "Haut & Äußeres",
            "text": "Dein Avatar spiegelt Hautgesundheit, Haare und äußere Anzeichen von Nährstoffmangel wider."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🫀",
            "title": "Organe & Systeme",
            "text": "Leber, Niere, Schilddrüse — visualisiert anhand deiner Laborwerte und Ultraschall-Befunde."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💓",
            "title": "Vitalwerte",
            "text": "Blutdruck, Ruhepuls, HRV und Sauerstoffsättigung in Echtzeit aus deinem Wearable."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🔬",
            "title": "Biomarker",
            "text": "80+ Blutwerte — von Vitamin D bis Testosteron — wissenschaftlich analysiert und visualisiert."
          }
        }
      ]
    }
  ]
}
{% endschema %}

