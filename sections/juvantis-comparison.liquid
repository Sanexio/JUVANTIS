          "settings": {
            "feature": "Infusionstherapie",
            "juvantis": "yes",
            "blood_test": "no",
            "lifestyle": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Gamification & Quests",
            "juvantis": "yes",
            "blood_test": "no",
            "lifestyle": "no"
          }
        },
        {
          "type": "row",
