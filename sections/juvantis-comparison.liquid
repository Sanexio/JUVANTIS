      "name": "Vergleichszeile",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "default": "Feature-Name",
          "label": "Feature"
        },
        {
          "type": "select",
          "id": "juvantis",
          "options": [
            { "value": "yes", "label": "Ja" },
            { "value": "no", "label": "Nein" },
            { "value": "partial", "label": "Teilweise" }
          ],
          "default": "yes",
          "label": "Juvantis"
        },
        {
          "type": "select",
          "id": "blood_test",
          "options": [
            { "value": "yes", "label": "Ja" },
            { "value": "no", "label": "Nein" },
            { "value": "partial", "label": "Teilweise" }
          ],
          "default": "no",
          "label": "Bluttest-Anbieter"
        },
        {
          "type": "select",
          "id": "lifestyle",
          "options": [
            { "value": "yes", "label": "Ja" },
            { "value": "no", "label": "Nein" },
            { "value": "partial", "label": "Teilweise" }
          ],
          "default": "no",
          "label": "Lifestyle-Apps"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis Vergleich",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Labor-Bluttests (80+ Biomarker)",
            "juvantis": "yes",
            "blood_test": "yes",
            "lifestyle": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "3D Digital Health Twin",
            "juvantis": "yes",
            "blood_test": "no",
            "lifestyle": "no"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Body Check-ups (Ultraschall)",
            "juvantis": "yes",
            "blood_test": "no",
            "lifestyle": "no"
          }
        },
        {
