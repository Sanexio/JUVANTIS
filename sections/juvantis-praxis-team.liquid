{%- style -%}
  /* Apple Design System Override */
  #PraxisTeam-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 6rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: praxisTeamFadeIn-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.1s forwards;
  }

  @keyframes praxisTeamFadeIn-{{ section.id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__heading {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 1.2rem;
    color: var(--apple-text);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__description {
    font-size: 1.7rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisTeam-{{ section.id }} .praxis-team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: praxisTeamFadeIn-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.3s forwards;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:nth-child(2) {
    animation-delay: 0.45s;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:nth-child(3) {
    animation-delay: 0.6s;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:nth-child(4) {
    animation-delay: 0.75s;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0, 0, 0, 0.08);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__image {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #e8e8ed;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:hover .praxis-team__image img {
    transform: scale(1.03);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e8ed;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__placeholder svg {
    width: 8rem;
    height: 8rem;
    opacity: 0.2;
    fill: var(--apple-text-tertiary);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__info {
    padding: 2.8rem 2.4rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__bio {
    flex: 1;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__name {
    font-family: var(--apple-font);
    font-size: clamp(2.4rem, 2.5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
    color: var(--apple-text);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__title {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--apple-link);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__qualifications {
    font-size: 1.4rem;
    line-height: 1.53;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.6rem;
    white-space: pre-line;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__bio {
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    margin-bottom: 1.6rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__links {
    display: flex;
    gap: 1.6rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--apple-link);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link:hover {
    color: #0077ed;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details {
    margin-top: 1.6rem;
    border-top: 0.1rem solid rgba(0, 0, 0, 0.06);
    padding-top: 1.2rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary {
    cursor: pointer;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--apple-link);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    user-select: none;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary:hover {
    color: #0077ed;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary::-webkit-details-marker {
    display: none;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary::after {
    content: '\25B8';
    transition: transform 0.2s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details[open] summary::after {
    transform: rotate(90deg);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-section {
    margin-top: 1.6rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-title {
    font-family: var(--apple-font);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.8rem;
    color: var(--apple-text);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content {
    font-size: 1.4rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content ul {
    padding-left: 1.6rem;
    margin: 0.4rem 0;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content li {
    margin-bottom: 0.4rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content p {
    margin: 0.4rem 0;
  }
{%- endstyle -%}

<div
  id="PraxisTeam-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-team__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-team__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="praxis-team__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="praxis-team__grid">
        {%- for block in section.blocks -%}
          <div class="praxis-team__card" {{ block.shopify_attributes }}>
            <div class="praxis-team__image">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    widths: '375, 550, 750, 800'
                }}
              {%- elsif block.settings.asset_image != blank -%}
                <img src="{{ block.settings.asset_image | asset_url }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="800" height="800" style="width:100%;height:100%;object-fit:cover;">
              {%- else -%}
                <div class="praxis-team__placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                </div>
              {%- endif -%}
            </div>

            <div class="praxis-team__info">
              {%- if block.settings.name != blank -%}
                <h3 class="praxis-team__name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <p class="praxis-team__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}

              {%- if block.settings.qualifications != blank -%}
                <p class="praxis-team__qualifications">{{ block.settings.qualifications | escape }}</p>
              {%- endif -%}

              {%- if block.settings.bio != blank -%}
                <p class="praxis-team__bio">{{ block.settings.bio | escape }}</p>
              {%- endif -%}

              <div class="praxis-team__links">
                {%- if block.settings.doctolib_url != blank -%}
                  <a href="{{ block.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="praxis-team__link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
                    Doctolib
                  </a>
                {%- endif -%}
                {%- if block.settings.linkedin_url != blank -%}
                  <a href="{{ block.settings.linkedin_url }}" target="_blank" rel="noopener noreferrer" class="praxis-team__link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                    LinkedIn
                  </a>
                {%- endif -%}
              </div>

              {%- if block.settings.education != blank or block.settings.career != blank -%}
                <details class="praxis-team__details">
                  <summary>Vollst&auml;ndiger Lebenslauf</summary>
                  {%- if block.settings.career != blank -%}
                    <div class="praxis-team__cv-section">
                      <h4 class="praxis-team__cv-title">Berufliche Erfahrung</h4>
                      <div class="praxis-team__cv-content">{{ block.settings.career }}</div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.education != blank -%}
                    <div class="praxis-team__cv-section">
                      <h4 class="praxis-team__cv-title">Ausbildung</h4>
                      <div class="praxis-team__cv-content">{{ block.settings.education }}</div>
                    </div>
                  {%- endif -%}
                </details>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Praxis Team",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Unser Team",
      "label": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Erfahrene Fachärzte mit internationaler Kompetenz",
      "label": "Beschreibung"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-2",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Arzt / Ärztin",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Profilbild"
        },
        {
          "type": "text",
          "id": "asset_image",
          "label": "Bild-Dateiname (Theme-Asset, z.B. dr-stracke.jpg)"
        },
        {
          "type": "text",
          "id": "name",
          "default": "Dr. med. Vorname Nachname",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Facharzt/Fachärztin für ...",
          "label": "Fachbezeichnung"
        },
        {
          "type": "textarea",
          "id": "qualifications",
          "default": "Weitere Qualifikationen",
          "label": "Qualifikationen (eine pro Zeile)"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biografie"
        },
        {
          "type": "url",
          "id": "doctolib_url",
          "label": "Doctolib Profil"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn Profil"
        },
        {
          "type": "richtext",
          "id": "career",
          "label": "Berufliche Erfahrung"
        },
        {
          "type": "richtext",
          "id": "education",
          "label": "Ausbildung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Praxis Team",
      "blocks": [
        {
          "type": "doctor",
          "settings": {
            "name": "Dr. med. Siegbert Stracke, MBA",
            "title": "Facharzt Innere Medizin, Notfall- und Intensivmedizin",
            "qualifications": "Gesundheitsökonom, MBA Healthcare Management\nCEO Sanexio GmbH",
            "bio": "Der Überzeugung folgend, dass zur Bewältigung zukünftiger Herausforderungen im Gesundheitswesen neue Wege der Organisation von Informationen nötig sein werden, bringt Siegbert Stracke seine Expertise aus langjähriger klinischer Erfahrung und Kenntnissen aus dem informationstechnischen Bereich in die Praxis ein."
          }
        },
        {
          "type": "doctor",
          "settings": {
            "name": "Docteur en méd. Sonja Saul",
            "title": "Fachärztin für Allgemeinmedizin",
            "qualifications": "Sprachen: Deutsch, Englisch, Französisch, Spanisch",
            "bio": "Nach einer Kindheit zwischen Deutschland, Frankreich und Belgien, Abitur an der Europaschule in Brüssel mit anschließendem Medizinstudium ist für Sonja Saul eine Anamnese in vier Sprachen kein Problem. Zuletzt war sie als leitende Oberärztin in Spanien tätig."
          }
        }
      ]
    }
  ]
}
{% endschema %}
