{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 4rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisTeam-{{ section.id }} .praxis-team__heading {
      font-size: 4rem;
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisTeam-{{ section.id }} .praxis-team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__card:hover {
    box-shadow: 0 0.8rem 3.2rem rgba(var(--color-foreground), 0.08);
    transform: translateY(-0.2rem);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__image {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(78, 161, 217, 0.1) 0%, rgba(115, 194, 94, 0.1) 100%);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__placeholder svg {
    width: 8rem;
    height: 8rem;
    opacity: 0.3;
    fill: rgba(var(--color-foreground), 0.5);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__info {
    padding: 2.4rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__name {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.4rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__title {
    font-size: 1.4rem;
    font-weight: 500;
    color: #4ea1d9;
    margin-bottom: 0.8rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__qualifications {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.6);
    margin-bottom: 1.6rem;
    white-space: pre-line;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__bio {
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.75);
    margin-bottom: 1.6rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__links {
    display: flex;
    gap: 1.2rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.3rem;
    font-weight: 500;
    color: #4ea1d9;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link:hover {
    color: #73c25e;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__link svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details {
    margin-top: 1.6rem;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    padding-top: 1.2rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary {
    cursor: pointer;
    font-size: 1.4rem;
    font-weight: 600;
    color: #4ea1d9;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    user-select: none;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary::-webkit-details-marker {
    display: none;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details summary::after {
    content: '\25B8';
    transition: transform 0.2s ease;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__details[open] summary::after {
    transform: rotate(90deg);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-section {
    margin-top: 1.6rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-title {
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
    color: rgba(var(--color-foreground), 0.85);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content {
    font-size: 1.3rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content ul {
    padding-left: 1.6rem;
    margin: 0.4rem 0;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content li {
    margin-bottom: 0.4rem;
  }

  #PraxisTeam-{{ section.id }} .praxis-team__cv-content p {
    margin: 0.4rem 0;
  }
{%- endstyle -%}

<div
  id="PraxisTeam-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-team__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-team__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="praxis-team__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="praxis-team__grid">
        {%- for block in section.blocks -%}
          <div class="praxis-team__card" {{ block.shopify_attributes }}>
            <div class="praxis-team__image">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    widths: '375, 550, 750, 800'
                }}
              {%- else -%}
                <div class="praxis-team__placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                </div>
              {%- endif -%}
            </div>

            <div class="praxis-team__info">
              {%- if block.settings.name != blank -%}
                <h3 class="praxis-team__name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <p class="praxis-team__title">{{ block.settings.title | escape }}</p>
              {%- endif -%}

              {%- if block.settings.qualifications != blank -%}
                <p class="praxis-team__qualifications">{{ block.settings.qualifications | escape }}</p>
              {%- endif -%}

              {%- if block.settings.bio != blank -%}
                <p class="praxis-team__bio">{{ block.settings.bio | escape }}</p>
              {%- endif -%}

              <div class="praxis-team__links">
                {%- if block.settings.doctolib_url != blank -%}
                  <a href="{{ block.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="praxis-team__link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
                    Doctolib
                  </a>
                {%- endif -%}
                {%- if block.settings.linkedin_url != blank -%}
                  <a href="{{ block.settings.linkedin_url }}" target="_blank" rel="noopener noreferrer" class="praxis-team__link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                    LinkedIn
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Praxis Team",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Unser Team",
      "label": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Erfahrene Fachärzte mit internationaler Kompetenz",
      "label": "Beschreibung"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-2",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "doctor",
      "name": "Arzt / Ärztin",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Profilbild"
        },
        {
          "type": "text",
          "id": "name",
          "default": "Dr. med. Vorname Nachname",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Facharzt/Fachärztin für ...",
          "label": "Fachbezeichnung"
        },
        {
          "type": "textarea",
          "id": "qualifications",
          "default": "Weitere Qualifikationen",
          "label": "Qualifikationen (eine pro Zeile)"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biografie"
        },
        {
          "type": "url",
          "id": "doctolib_url",
          "label": "Doctolib Profil"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn Profil"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Praxis Team",
      "blocks": [
        {
          "type": "doctor",
          "settings": {
            "name": "Dr. med. Siegbert Stracke, MBA",
            "title": "Facharzt Innere Medizin, Notfall- und Intensivmedizin",
            "qualifications": "Gesundheitsökonom, MBA Healthcare Management\nCEO Sanexio GmbH",
            "bio": "Der Überzeugung folgend, dass zur Bewältigung zukünftiger Herausforderungen im Gesundheitswesen neue Wege der Organisation von Informationen nötig sein werden, bringt Siegbert Stracke seine Expertise aus langjähriger klinischer Erfahrung und Kenntnissen aus dem informationstechnischen Bereich in die Praxis ein."
          }
        },
        {
          "type": "doctor",
          "settings": {
            "name": "Docteur en méd. Sonja Saul",
            "title": "Fachärztin für Allgemeinmedizin",
            "qualifications": "Sprachen: Deutsch, Englisch, Französisch, Spanisch",
            "bio": "Nach einer Kindheit zwischen Deutschland, Frankreich und Belgien, Abitur an der Europaschule in Brüssel mit anschließendem Medizinstudium ist für Sonja Saul eine Anamnese in vier Sprachen kein Problem. Zuletzt war sie als leitende Oberärztin in Spanien tätig."
          }
        }
      ]
    }
  ]
}
{% endschema %}

