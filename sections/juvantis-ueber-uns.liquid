{%- comment -%}
  Juvantis Section: Über uns
  Zweck: Team, Mission, Werte — Kernseite für Vertrauen
  Design: Apple-inspired design system
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- style -%}
  #UeberUns-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #UeberUns-{{ section.id }} .about-container {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  #UeberUns-{{ section.id }} .about-hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  #UeberUns-{{ section.id }} .about-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.2rem;
  }

  #UeberUns-{{ section.id }} .about-hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.6rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-hero p {
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.53;
  }

  /* ── Mission ── */
  #UeberUns-{{ section.id }} .about-mission {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 3.6rem 3rem;
    margin: 0 0 4rem;
    text-align: center;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: aboutFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #UeberUns-{{ section.id }} .about-mission h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 1.2rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-mission p {
    color: var(--apple-text-secondary);
    max-width: 48rem;
    margin: 0 auto;
    line-height: 1.53;
    font-size: 1.7rem;
  }

  /* ── Team Grid ── */
  #UeberUns-{{ section.id }} .about-team-heading {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 750px) {
    #UeberUns-{{ section.id }} .about-team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.4rem;
    }
  }

  #UeberUns-{{ section.id }} .about-team-card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    overflow: hidden;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: aboutFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #UeberUns-{{ section.id }} .about-team-card:nth-child(2) { animation-delay: 0.12s; }
  #UeberUns-{{ section.id }} .about-team-card:nth-child(3) { animation-delay: 0.24s; }
  #UeberUns-{{ section.id }} .about-team-card:nth-child(4) { animation-delay: 0.36s; }

  #UeberUns-{{ section.id }} .about-team-card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #UeberUns-{{ section.id }} .about-team-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  #UeberUns-{{ section.id }} .about-team-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--apple-bg-white);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--apple-text-tertiary);
  }

  #UeberUns-{{ section.id }} .about-team-img-placeholder svg {
    width: 4.8rem;
    height: 4.8rem;
    stroke: var(--apple-text-tertiary);
  }

  #UeberUns-{{ section.id }} .about-team-body {
    padding: 2rem;
  }

  #UeberUns-{{ section.id }} .about-team-name {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.3rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-team-role {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--apple-link);
    margin: 0 0 1rem;
    line-height: 1.53;
  }

  #UeberUns-{{ section.id }} .about-team-qualifications {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  #UeberUns-{{ section.id }} .about-pill {
    background: var(--apple-bg-white);
    border: none;
    border-radius: 2rem;
    padding: 0.3rem 1rem;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--apple-text-secondary);
    letter-spacing: 0.01em;
  }

  #UeberUns-{{ section.id }} .about-team-text {
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    margin: 0;
  }

  /* ── History ── */
  #UeberUns-{{ section.id }} .about-history {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 3.6rem 3rem;
    margin: 0 0 4rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: aboutFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.1s forwards;
  }

  #UeberUns-{{ section.id }} .about-history h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 1.2rem;
    text-align: center;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-history p {
    color: var(--apple-text-secondary);
    line-height: 1.53;
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    font-size: 1.7rem;
  }

  /* ── Values Grid ── */
  #UeberUns-{{ section.id }} .about-values-heading {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 750px) {
    #UeberUns-{{ section.id }} .about-values-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.4rem;
    }
  }

  @media (min-width: 990px) {
    #UeberUns-{{ section.id }} .about-values-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2.4rem;
    }
  }

  #UeberUns-{{ section.id }} .about-value-card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 2.4rem 2rem;
    text-align: center;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: aboutFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #UeberUns-{{ section.id }} .about-value-card:nth-child(1) { animation-delay: 0s; }
  #UeberUns-{{ section.id }} .about-value-card:nth-child(2) { animation-delay: 0.12s; }
  #UeberUns-{{ section.id }} .about-value-card:nth-child(3) { animation-delay: 0.24s; }
  #UeberUns-{{ section.id }} .about-value-card:nth-child(4) { animation-delay: 0.36s; }

  #UeberUns-{{ section.id }} .about-value-card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #UeberUns-{{ section.id }} .about-value-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
    color: var(--apple-link);
  }

  #UeberUns-{{ section.id }} .about-value-icon svg {
    width: 3.2rem;
    height: 3.2rem;
  }

  #UeberUns-{{ section.id }} .about-value-title {
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.7rem;
    margin: 0 0 0.6rem;
    color: var(--apple-text);
  }

  #UeberUns-{{ section.id }} .about-value-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0;
  }

  /* ── CTA ── */
  #UeberUns-{{ section.id }} .about-cta {
    text-align: center;
    padding: 2rem 0 1rem;
  }

  #UeberUns-{{ section.id }} .about-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.8rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #UeberUns-{{ section.id }} .about-cta-btn:hover {
    background: #0077ed;
    transform: scale(1.04);
    box-shadow: 0 0.8rem 2.4rem rgba(0,113,227,0.3);
    color: #fff;
  }

  /* ── Animation ── */
  @keyframes aboutFadeUp-{{ section.id }} {
    from { opacity: 0; transform: translateY(1.6rem); }
    to { opacity: 1; transform: none; }
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 749px) {
    #UeberUns-{{ section.id }} .about-container {
      padding: 0 1.5rem;
    }
    #UeberUns-{{ section.id }} .about-mission,
    #UeberUns-{{ section.id }} .about-history {
      padding: 2.4rem 2rem;
    }
    #UeberUns-{{ section.id }} .about-team-body {
      padding: 1.6rem;
    }
  }
{%- endstyle -%}

<section
  id="UeberUns-{{ section.id }}"
  style="
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  "
>
  <div class="page-width about-container">

    <!-- Hero -->
    <header class="about-hero">
      <span class="about-label">Über uns</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.description }}</p>
    </header>

    <!-- Mission -->
    <div class="about-mission">
      <h2>{{ section.settings.mission_heading }}</h2>
      <p>{{ section.settings.mission_text }}</p>
    </div>

    <!-- Team -->
    <h2 class="about-team-heading">{{ section.settings.team_heading }}</h2>
    <div class="about-team-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'team_member' -%}
          <div class="about-team-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                class="about-team-img"
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.name }}"
                width="800"
                height="600"
                loading="lazy"
              >
            {%- elsif block.settings.asset_image != blank -%}
              <img
                class="about-team-img"
                src="{{ block.settings.asset_image | asset_url }}"
                alt="{{ block.settings.name }}"
                width="800"
                height="600"
                loading="lazy"
              >
            {%- else -%}
              <div class="about-team-img-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256" fill="currentColor"><path d="M64.12,147.8a4,4,0,0,1-4,4.2H16a8,8,0,0,1-7.8-6.17,8.35,8.35,0,0,1,1.62-6.93A67.79,67.79,0,0,1,37,117.51a40,40,0,1,1,66.46-35.8,3.94,3.94,0,0,1-2.27,4.18A64.08,64.08,0,0,0,64,144C64,145.28,64,146.54,64.12,147.8Zm182-8.91A67.76,67.76,0,0,0,219,117.51a40,40,0,1,0-66.46-35.8,3.94,3.94,0,0,0,2.27,4.18A64.08,64.08,0,0,1,192,144c0,1.28,0,2.54-.12,3.8a4,4,0,0,0,4,4.2H240a8,8,0,0,0,7.8-6.17A8.33,8.33,0,0,0,246.17,138.89Zm-89,43.18a48,48,0,1,0-58.37,0A72.13,72.13,0,0,0,65.07,212,8,8,0,0,0,72,224H184a8,8,0,0,0,6.93-12A72.15,72.15,0,0,0,157.19,182.07Z"/></svg>
              </div>
            {%- endif -%}
            <div class="about-team-body">
              <h3 class="about-team-name">{{ block.settings.name }}</h3>
              <p class="about-team-role">{{ block.settings.role }}</p>
              {%- if block.settings.qualifications != blank -%}
                <div class="about-team-qualifications">
                  {%- assign quals = block.settings.qualifications | split: ',' -%}
                  {%- for q in quals -%}
                    <span class="about-pill">{{ q | strip }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="about-team-text">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- History -->
    {%- if section.settings.history_heading != blank -%}
      <div class="about-history">
        <h2>{{ section.settings.history_heading }}</h2>
        <p>{{ section.settings.history_text }}</p>
      </div>
    {%- endif -%}

    <!-- Values -->
    <h2 class="about-values-heading">{{ section.settings.values_heading }}</h2>
    <div class="about-values-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="about-value-card" {{ block.shopify_attributes }}>
            <span class="about-value-icon">
              {%- case block.settings.title -%}
                {%- when 'Evidenzbasiert' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23Zm-90.08-42.91c-15.91-8.05-31.05-12.32-45.22-12.81l24.47-40.8A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167C171.4,169.34,154.29,168.34,131.61,156.86Z"/></svg>
                {%- when 'Transparent' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M247.31,124.76c-.35-.79-8.82-19.58-27.65-38.41C194.57,61.26,162.88,48,128,48S61.43,61.26,36.34,86.35C17.51,105.18,9,124,8.69,124.76a8,8,0,0,0,0,6.5c.35.79,8.82,19.57,27.65,38.4C61.43,194.74,93.12,208,128,208s66.57-13.26,91.66-38.34c18.83-18.83,27.3-37.61,27.65-38.4A8,8,0,0,0,247.31,124.76ZM128,168a40,40,0,1,1,40-40A40,40,0,0,1,128,168Z"/></svg>
                {%- when 'Patientenzentriert' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M64.12,147.8a4,4,0,0,1-4,4.2H16a8,8,0,0,1-7.8-6.17,8.35,8.35,0,0,1,1.62-6.93A67.79,67.79,0,0,1,37,117.51a40,40,0,1,1,66.46-35.8,3.94,3.94,0,0,1-2.27,4.18A64.08,64.08,0,0,0,64,144C64,145.28,64,146.54,64.12,147.8Zm182-8.91A67.76,67.76,0,0,0,219,117.51a40,40,0,1,0-66.46-35.8,3.94,3.94,0,0,0,2.27,4.18A64.08,64.08,0,0,1,192,144c0,1.28,0,2.54-.12,3.8a4,4,0,0,0,4,4.2H240a8,8,0,0,0,7.8-6.17A8.33,8.33,0,0,0,246.17,138.89Zm-89,43.18a48,48,0,1,0-58.37,0A72.13,72.13,0,0,0,65.07,212,8,8,0,0,0,72,224H184a8,8,0,0,0,6.93-12A72.15,72.15,0,0,0,157.19,182.07Z"/></svg>
                {%- when 'Innovativ' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M101.85,191.14C97.34,201,82.29,224,40,224a8,8,0,0,1-8-8c0-42.29,23-57.34,32.86-61.85a8,8,0,0,1,6.64,14.56c-6.43,2.93-20.62,12.36-23.12,38.91,26.55-2.5,36-16.69,38.91-23.12a8,8,0,1,1,14.56,6.64Zm122-144a16,16,0,0,0-15-15c-12.58-.75-44.73.4-71.4,27.07h0L88,108.7A8,8,0,0,1,76.67,97.39l26.56-26.57A4,4,0,0,0,100.41,64H74.35A15.9,15.9,0,0,0,63,68.68L28.7,103a16,16,0,0,0,9.07,27.16l38.47,5.37,44.21,44.21,5.37,38.49a15.94,15.94,0,0,0,10.78,12.92,16.11,16.11,0,0,0,5.1.83A15.91,15.91,0,0,0,153,227.3L187.32,193A16,16,0,0,0,192,181.65V155.59a4,4,0,0,0-6.83-2.82l-26.57,26.56a8,8,0,0,1-11.71-.42,8.2,8.2,0,0,1,.6-11.1l49.27-49.27h0C223.45,91.86,224.6,59.71,223.85,47.12Z"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M197.58,129.06l-51.61-19-19-51.65a15.92,15.92,0,0,0-29.88,0L78.07,110l-51.65,19a15.92,15.92,0,0,0,0,29.88L78,178l19.03,51.69a15.92,15.92,0,0,0,29.88,0l19-51.61,51.65-19.03a15.92,15.92,0,0,0,0-29.88ZM140.39,163a15.87,15.87,0,0,0-9.43,9.43l-19,51.46L93,172.39A15.87,15.87,0,0,0,83.61,163l-51.46-19,51.46-19A15.87,15.87,0,0,0,93,115.61l19-51.46,19,51.46a15.87,15.87,0,0,0,9.43,9.43l51.46,19ZM144,40a8,8,0,0,1,8-8h16V16a8,8,0,0,1,16,0V32h16a8,8,0,0,1,0,16H184V64a8,8,0,0,1-16,0V48H152A8,8,0,0,1,144,40ZM248,88a8,8,0,0,1-8,8h-8v8a8,8,0,0,1-16,0V96h-8a8,8,0,0,1,0-16h8V72a8,8,0,0,1,16,0v8h8A8,8,0,0,1,248,88Z"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="about-value-title">{{ block.settings.title }}</h3>
            <p class="about-value-text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- CTA -->
    {%- if section.settings.cta_label != blank -%}
      <div class="about-cta">
        <a href="{{ section.settings.cta_link }}" class="about-cta-btn">
          {{ section.settings.cta_label }} &rarr;
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Juvantis: Über uns",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die Menschen hinter Juvantis"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Einleitung",
