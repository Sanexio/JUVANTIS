{%- comment -%}
  Juvantis Section: FAQ mit FAQPage Schema
  Zweck: Haeufige Fragen mit Accordion + Google Structured Data
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- if template.suffix == 'faq' -%}

{%- style -%}
  .jv-faq {
    --jv-teal: #028090;
    --jv-teal-light: #00A896;
    --jv-gradient: linear-gradient(135deg, #4ea1d9, #73c25e);
    --jv-text: #1a1a1a;
    --jv-text-sec: #555;
    --jv-bg: #ffffff;
    --jv-bg-subtle: #f8fafa;
    --jv-border: #e8ecec;
    --jv-radius: 1.4rem;
    font-family: var(--font-body-family, 'Anonymous Pro', monospace);
    -webkit-font-smoothing: antialiased;
    color: var(--jv-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  .jv-faq__container { max-width: 52rem; margin: 0 auto; padding: 0 1.5rem; }

  .jv-faq__hero { text-align: center; padding: 3rem 0 2.5rem; }

  .jv-faq__badge {
    display: inline-flex;
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: 2rem;
    padding: 0.35rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--jv-teal);
    margin-bottom: 1.2rem;
  }

  .jv-faq__hero h1 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 0.8rem;
  }

  .jv-faq__hero p {
    color: var(--jv-text-sec);
    font-size: 1.05rem;
    margin: 0;
  }

  /* Category label */
  .jv-faq__cat {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--jv-teal);
    margin: 2.5rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--jv-border);
  }

  .jv-faq__cat:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }

  /* Accordion */
  .jv-faq__item {
    border-bottom: 1px solid var(--jv-border);
  }

  .jv-faq__q {
    width: 100%;
    background: none;
    border: none;
    padding: 1.1rem 0;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--jv-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    line-height: 1.4;
  }

  .jv-faq__q::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--jv-teal);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .jv-faq__item.is-open .jv-faq__q::after {
    transform: rotate(45deg);
  }

  .jv-faq__a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .jv-faq__item.is-open .jv-faq__a {
    max-height: 30rem;
  }

  .jv-faq__a-inner {
    padding: 0 0 1.2rem;
    font-size: 0.92rem;
    color: var(--jv-text-sec);
    line-height: 1.7;
  }

  .jv-faq__a-inner p { margin: 0 0 0.6rem; }
  .jv-faq__a-inner p:last-child { margin: 0; }

  /* CTA */
  .jv-faq__cta {
    text-align: center;
    padding: 2.5rem 0 0;
    margin-top: 2rem;
    border-top: 1px solid var(--jv-border);
  }

  .jv-faq__cta p {
    color: var(--jv-text-sec);
    margin: 0 0 1rem;
  }

  .jv-faq__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--jv-gradient);
    color: #fff;
    font-weight: 600;
    padding: 0.9rem 2rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .jv-faq__cta-btn:hover {
    transform: translateY(-2px);
    color: #fff;
  }
{%- endstyle -%}

<section class="jv-faq" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="jv-faq__container">

    <header class="jv-faq__hero">
      <span class="jv-faq__badge">Hilfe</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtitle }}</p>
    </header>

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <h2 class="jv-faq__cat" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
      {%- endif -%}

      {%- if block.type == 'question' -%}
        <div class="jv-faq__item" {{ block.shopify_attributes }}>
          <button class="jv-faq__q" onclick="this.parentElement.classList.toggle('is-open')">
            {{ block.settings.question }}
          </button>
          <div class="jv-faq__a">
            <div class="jv-faq__a-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="jv-faq__cta">
        <p>{{ section.settings.cta_text }}</p>
        <a href="{{ section.settings.cta_link }}" class="jv-faq__cta-btn">{{ section.settings.cta_label }} &rarr;</a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment -%} FAQPage Schema fuer Google {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'question' -%}
        {%- unless faq_first -%},{%- endunless -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
        {%- assign faq_first = false -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: FAQ",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Haeufige Fragen" },
    { "type": "text", "id": "subtitle", "label": "Unterzeile", "default": "Alles, was du ueber Juvantis wissen musst." },
    { "type": "text", "id": "cta_text", "label": "CTA-Einleitung", "default": "Deine Frage war nicht dabei?" },
    { "type": "text", "id": "cta_label", "label": "CTA-Text", "default": "Kontaktiere uns" },
    { "type": "url", "id": "cta_link", "label": "CTA-Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    { "type": "category", "name": "Kategorie", "settings": [
      { "type": "text", "id": "title", "label": "Kategorie-Name" }
    ]},
    { "type": "question", "name": "Frage & Antwort", "settings": [
      { "type": "text", "id": "question", "label": "Frage" },
      { "type": "richtext", "id": "answer", "label": "Antwort" }
    ]}
  ],
  "presets": [{ "name": "Juvantis: FAQ" }]
}
{% endschema %}
