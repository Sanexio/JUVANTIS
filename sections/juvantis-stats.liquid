{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #Stats-{{ section.id }} .stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    #Stats-{{ section.id }} .stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #Stats-{{ section.id }} .stats__item {
    padding: 2rem 1.6rem;
  }

  #Stats-{{ section.id }} .stats__value {
    font-family: var(--font-heading-family);
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    color: rgb(var(--color-button));
    margin-bottom: 0.8rem;
  }

  @media screen and (min-width: 750px) {
    #Stats-{{ section.id }} .stats__value {
      font-size: 5.2rem;
    }
  }

  #Stats-{{ section.id }} .stats__label {
    font-size: 1.4rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
    font-weight: 500;
  }
{%- endstyle -%}

<div
  id="Stats-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    {%- if section.settings.heading != blank -%}
      <div style="text-align: center; margin-bottom: 3.2rem;">
        <h2 style="font-family: var(--font-heading-family); font-size: 3.6rem;">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="stats__grid">
        {%- for block in section.blocks -%}
          <div class="stats__item" {{ block.shopify_attributes }}>
            <div class="stats__value">{{ block.settings.value | escape }}</div>
            <div class="stats__label">{{ block.settings.label | escape }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Juvantis Statistiken",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (optional)"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-2",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistik",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "default": "100+",
          "label": "Wert"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Beschreibung",
          "label": "Beschriftung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis Statistiken",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "80+",
            "label": "Biomarker"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "2",
            "label": "Standorte Frankfurt"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "3D",
            "label": "Digital Health Twin"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "100%",
            "label": "DSGVO-konform"
          }
        }
      ]
    }
  ]
}
{% endschema %}
