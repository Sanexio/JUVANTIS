{%- comment -%}
  Juvantis Section: Zielgruppen-Seite (wiederverwendbar)
  Zweck: Fuer Sportler, Fuer Unternehmen, Fuer Praxen
  Design: Apple-inspired design system
{%- endcomment -%}

{%- assign zg_pages = 'fuer-sportler,fuer-unternehmen,fuer-praxen' | split: ',' -%}
{%- assign is_zg = false -%}
{%- for p in zg_pages -%}
  {%- if template.suffix == p -%}{%- assign is_zg = true -%}{%- endif -%}
{%- endfor -%}

{%- if is_zg -%}

{%- style -%}
  #JvZielgruppe-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    color: var(--apple-text);
    font-size: 1.7rem;
    line-height: 1.53;
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #JvZielgruppe-{{ section.id }} .jv-zg__container {
    max-width: 98rem;
    margin: 0 auto;
    padding: 0 2.4rem;
  }

  /* Hero */
  #JvZielgruppe-{{ section.id }} .jv-zg__hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__badge {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.6rem;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 2rem;
    color: var(--apple-text);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__hero-text {
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.53;
  }

  /* USP highlight box */
  #JvZielgruppe-{{ section.id }} .jv-zg__usp {
    background: var(--apple-text);
    color: #fff;
    border-radius: 2rem;
    padding: 4rem 4.8rem;
    text-align: center;
    margin-bottom: 6rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: jvZgReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__usp h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 1.2rem;
    color: #fff;
    line-height: 1.08;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__usp p {
    margin: 0;
    opacity: 0.85;
    line-height: 1.53;
    font-size: 1.7rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Benefits section */
  #JvZielgruppe-{{ section.id }} .jv-zg__section-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 3.2rem;
    color: var(--apple-text);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin-bottom: 6rem;
  }

  @media (min-width: 750px) {
    #JvZielgruppe-{{ section.id }} .jv-zg__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 2.8rem;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(1.6rem);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.8rem;
    height: 4.8rem;
    background: rgba(0, 0, 0, 0.02);
    border-radius: 1.4rem;
    margin-bottom: 1.6rem;
    font-size: 2.4rem;
    line-height: 1;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.8rem;
    color: var(--apple-text);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0;
  }

  /* Testimonial */
  #JvZielgruppe-{{ section.id }} .jv-zg__proof {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 4rem 4.8rem;
    margin-bottom: 4rem;
    text-align: center;
    opacity: 0;
    transform: translateY(1.6rem);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__proof-text {
    font-size: 2.4rem;
    font-style: italic;
    font-weight: 500;
    color: var(--apple-text);
    line-height: 1.4;
    margin: 0 0 1.6rem;
    max-width: 52rem;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: -0.015em;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__proof-author {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    font-weight: 600;
  }

  /* Content section */
  #JvZielgruppe-{{ section.id }} .jv-zg__content {
    max-width: 64rem;
    margin: 0 auto 3.2rem;
    line-height: 1.53;
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__content h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--apple-text);
    margin: 4rem 0 1.6rem;
    line-height: 1.08;
  }

  /* CTA */
  #JvZielgruppe-{{ section.id }} .jv-zg__cta {
    text-align: center;
    padding: 2rem 0 0;
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--apple-link);
    color: #fff;
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.4rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__cta-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 8px 24px rgba(0, 113, 227, 0.3);
    color: #fff;
  }

  /* Animations */
  @keyframes jvZgReveal {
    from { opacity: 0; transform: translateY(1.6rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  #JvZielgruppe-{{ section.id }} .jv-zg__card.jv-zg--visible,
  #JvZielgruppe-{{ section.id }} .jv-zg__proof.jv-zg--visible {
    animation: jvZgReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  /* Mobile padding scale */
  @media (max-width: 749px) {
    #JvZielgruppe-{{ section.id }} .jv-zg__hero { padding: 4rem 0 3rem; }
    #JvZielgruppe-{{ section.id }} .jv-zg__usp { padding: 3rem 2rem; }
    #JvZielgruppe-{{ section.id }} .jv-zg__proof { padding: 3rem 2rem; }
    #JvZielgruppe-{{ section.id }} .jv-zg__container { padding: 0 1.6rem; }
  }
{%- endstyle -%}

<section id="JvZielgruppe-{{ section.id }}" class="jv-zg" style="padding-top:{{ section.settings.padding_top | times: 0.75 }}px;padding-bottom:{{ section.settings.padding_bottom | times: 0.75 }}px;">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="jv-zg__container">

      <header class="jv-zg__hero">
        {%- if section.settings.badge != blank -%}
          <span class="jv-zg__badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <h1>{{ section.settings.heading }}</h1>
        {%- if section.settings.intro != blank -%}
          <p class="jv-zg__hero-text">{{ section.settings.intro }}</p>
        {%- endif -%}
      </header>

      {%- if section.settings.usp_heading != blank -%}
        <div class="jv-zg__usp">
          <h2>{{ section.settings.usp_heading }}</h2>
          {%- if section.settings.usp_text != blank -%}
            <p>{{ section.settings.usp_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- assign has_cards = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit' -%}{%- assign has_cards = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_cards -%}
        <h2 class="jv-zg__section-title">{{ section.settings.benefits_heading }}</h2>
        <div class="jv-zg__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <div class="jv-zg__card" {{ block.shopify_attributes }}>
                <span class="jv-zg__card-icon">{{ block.settings.icon }}</span>
                <h3 class="jv-zg__card-title">{{ block.settings.title }}</h3>
                <p class="jv-zg__card-text">{{ block.settings.text }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="jv-zg__proof" {{ block.shopify_attributes }}>
            <p class="jv-zg__proof-text">&ldquo;{{ block.settings.quote }}&rdquo;</p>
            <span class="jv-zg__proof-author">{{ block.settings.author }}</span>
          </div>
        {%- endif -%}
        {%- if block.type == 'content' -%}
          <div class="jv-zg__content" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}<h2>{{ block.settings.title }}</h2>{%- endif -%}
            {{ block.settings.text }}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.cta_label != blank -%}
        <div class="jv-zg__cta">
          <a href="{{ section.settings.cta_link }}" class="jv-zg__cta-btn">{{ section.settings.cta_label }}</a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('JvZielgruppe-{{ section.id }}');
    if (!section) return;
    var els = section.querySelectorAll('.jv-zg__card, .jv-zg__proof');
    if (!els.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var idx = Array.prototype.indexOf.call(els, entry.target);
          var delay = idx * 120;
          entry.target.style.animationDelay = delay + 'ms';
          entry.target.classList.add('jv-zg--visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function(el) { observer.observe(el); });
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Zielgruppe",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge" },
    { "type": "text", "id": "heading", "label": "H1" },
    { "type": "textarea", "id": "intro", "label": "Einleitung" },
    { "type": "text", "id": "usp_heading", "label": "USP-Ueberschrift" },
    { "type": "textarea", "id": "usp_text", "label": "USP-Text" },
    { "type": "text", "id": "benefits_heading", "label": "Benefits-Ueberschrift", "default": "Deine Vorteile" },
    { "type": "text", "id": "cta_label", "label": "CTA-Text" },
    { "type": "url", "id": "cta_link", "label": "CTA-Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    { "type": "benefit", "name": "Vorteil", "settings": [
      { "type": "text", "id": "icon", "label": "Icon", "default": "🏃" },
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]},
    { "type": "testimonial", "name": "Testimonial", "settings": [
      { "type": "textarea", "id": "quote", "label": "Zitat" },
      { "type": "text", "id": "author", "label": "Autor" }
    ]},
    { "type": "content", "name": "Textabschnitt", "settings": [
      { "type": "text", "id": "title", "label": "Ueberschrift" },
      { "type": "richtext", "id": "text", "label": "Inhalt" }
    ]}
  ],
  "presets": [{ "name": "Juvantis: Zielgruppe" }]
}
{% endschema %}
