{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 3.2rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisKontakt-{{ section.id }} .praxis-kontakt__heading {
      font-size: 4rem;
    }
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisKontakt-{{ section.id }} .praxis-kontakt__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__icon {
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(78, 161, 217, 0.1);
    border-radius: 0.8rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__icon svg {
    width: 2rem;
    height: 2rem;
    fill: #4ea1d9;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__label {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 0.2rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__value {
    font-size: 1.5rem;
    line-height: 1.5;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__value a {
    color: #4ea1d9;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__value a:hover {
    color: #73c25e;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__doctolib {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: 1.2rem;
    padding: 1.2rem 2.8rem;
    background: #4ea1d9;
    color: #fff;
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.4rem;
    transition: background 0.3s ease, transform 0.2s ease;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__doctolib:hover {
    background: #3d8ec4;
    transform: translateY(-0.1rem);
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__doctolib svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: currentColor;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-wrapper {
    border-radius: 0.8rem;
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    min-height: 36rem;
    background: rgba(var(--color-foreground), 0.04);
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-wrapper iframe {
    width: 100%;
    height: 100%;
    min-height: 36rem;
    border: none;
    display: block;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-consent {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 36rem;
    padding: 3.2rem;
    text-align: center;
    background: rgba(var(--color-foreground), 0.02);
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-consent svg {
    width: 4.8rem;
    height: 4.8rem;
    fill: rgba(var(--color-foreground), 0.2);
    margin-bottom: 1.6rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-consent p {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.6);
    margin-bottom: 1.6rem;
    max-width: 36rem;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-consent-btn {
    display: inline-block;
    padding: 1rem 2.4rem;
    background: #4ea1d9;
    color: #fff;
    font-size: 1.4rem;
    font-weight: 500;
    border: none;
    border-radius: 0.4rem;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  #PraxisKontakt-{{ section.id }} .praxis-kontakt__map-consent-btn:hover {
    background: #3d8ec4;
  }
{%- endstyle -%}

<div
  id="PraxisKontakt-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-kontakt__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-kontakt__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="praxis-kontakt__grid">
      <div class="praxis-kontakt__info">
        {%- if section.settings.address != blank -%}
          <div class="praxis-kontakt__item">
            <div class="praxis-kontakt__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
            </div>
            <div>
              <div class="praxis-kontakt__label">Adresse</div>
              <div class="praxis-kontakt__value">{{ section.settings.address | escape }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.phone_general != blank -%}
          <div class="praxis-kontakt__item">
            <div class="praxis-kontakt__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            </div>
            <div>
              <div class="praxis-kontakt__label">Telefon Allgemein</div>
              <div class="praxis-kontakt__value">
                <a href="tel:{{ section.settings.phone_general | remove: ' ' | remove: '-' }}">{{ section.settings.phone_general | escape }}</a>
              </div>
              {%- if section.settings.phone_private != blank -%}
                <div class="praxis-kontakt__label" style="margin-top: 0.8rem;">Privatpatienten</div>
                <div class="praxis-kontakt__value">
                  <a href="tel:{{ section.settings.phone_private | remove: ' ' | remove: '-' }}">{{ section.settings.phone_private | escape }}</a>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.fax != blank -%}
          <div class="praxis-kontakt__item">
            <div class="praxis-kontakt__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg>
            </div>
            <div>
              <div class="praxis-kontakt__label">Fax</div>
              <div class="praxis-kontakt__value">{{ section.settings.fax | escape }}</div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
          <div class="praxis-kontakt__item">
            <div class="praxis-kontakt__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </div>
            <div>
              <div class="praxis-kontakt__label">E-Mail</div>
              <div class="praxis-kontakt__value">
                <a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.website_url != blank -%}
          <div class="praxis-kontakt__item">
            <div class="praxis-kontakt__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95a15.65 15.65 0 0 0-1.38-3.56A8.03 8.03 0 0 1 18.92 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zM5.08 16h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 0 1 5.08 16zm2.95-8H5.08a7.987 7.987 0 0 1 4.33-3.56A15.65 15.65 0 0 0 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/></svg>
            </div>
            <div>
              <div class="praxis-kontakt__label">Website</div>
              <div class="praxis-kontakt__value">
                <a href="{{ section.settings.website_url }}" target="_blank" rel="noopener noreferrer">{{ section.settings.website_url | remove: 'https://' | remove: 'http://' | remove_last: '/' }}</a>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.doctolib_url != blank -%}
          <a href="{{ section.settings.doctolib_url }}" target="_blank" rel="noopener noreferrer" class="praxis-kontakt__doctolib">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zm-7 5h5v5h-5v-5z"/></svg>
            Online-Termin buchen
          </a>
        {%- endif -%}
      </div>

      <div class="praxis-kontakt__map-wrapper">
        {%- if section.settings.maps_embed_url != blank -%}
          <div
            id="praxis-map-consent-{{ section.id }}"
            class="praxis-kontakt__map-consent"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
            <p>
              Zum Anzeigen der Karte wird eine Verbindung zu Google Maps hergestellt.
              Dabei werden Daten an Google übertragen.
              <a href="/policies/privacy-policy" style="color: #4ea1d9;">Datenschutzerklärung</a>
            </p>
            <button
              class="praxis-kontakt__map-consent-btn"
              onclick="document.getElementById('praxis-map-consent-{{ section.id }}').style.display='none';document.getElementById('praxis-map-frame-{{ section.id }}').innerHTML='<iframe src=&quot;{{ section.settings.maps_embed_url }}&quot; allowfullscreen loading=&quot;lazy&quot; referrerpolicy=&quot;no-referrer-when-downgrade&quot;></iframe>';"
            >
              Karte laden
            </button>
          </div>
          <div id="praxis-map-frame-{{ section.id }}"></div>
        {%- else -%}
          <div class="praxis-kontakt__map-consent">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
            <p>Bitte hinterlegen Sie eine Google Maps Embed-URL in den Einstellungen.</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Praxis Kontakt",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Kontakt & Anfahrt",
      "label": "Überschrift"
    },
    {
      "type": "header",
      "content": "Kontaktdaten"
    },
    {
      "type": "text",
      "id": "address",
      "default": "Grüneburgweg 12, 60322 Frankfurt am Main",
      "label": "Adresse"
    },
    {
      "type": "text",
      "id": "phone_general",
      "default": "069-247 574 523",
      "label": "Telefon Allgemein"
    },
    {
      "type": "text",
      "id": "phone_private",
      "default": "069-247 574 526",
      "label": "Telefon Privatpatienten"
    },
    {
      "type": "text",
      "id": "fax",
      "default": "069-97206408",
      "label": "Fax"
    },
    {
      "type": "text",
      "id": "email",
      "default": "praxis@westend-hausarzt.de",
      "label": "E-Mail"
    },
    {
      "type": "url",
      "id": "website_url",
      "label": "Praxis-Website"
    },
    {
      "type": "url",
      "id": "doctolib_url",
      "label": "Doctolib-Link"
    },
    {
      "type": "header",
      "content": "Karte"
    },
    {
      "type": "text",
      "id": "maps_embed_url",
      "label": "Google Maps Embed-URL",
      "info": "Die Karte wird erst nach Einwilligung des Nutzers geladen (DSGVO)."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-1",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Praxis Kontakt"
    }
  ]
}
{% endschema %}

