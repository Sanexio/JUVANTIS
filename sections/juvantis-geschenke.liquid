{%- comment -%}
  Juvantis Section: Geschenkgutscheine
  Zweck: "Schenke Gesundheit" — Gutscheine fuer Check-ups
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- if template.suffix == 'geschenke' -%}

{%- style -%}
  .jv-gift {
    --jv-teal: #028090;
    --jv-teal-light: #00A896;
    --jv-gradient: linear-gradient(135deg, #4ea1d9, #73c25e);
    --jv-text: #1a1a1a;
    --jv-text-sec: #555;
    --jv-bg: #ffffff;
    --jv-bg-subtle: #f8fafa;
    --jv-border: #e8ecec;
    --jv-radius: 1.4rem;
    font-family: var(--font-body-family, 'Anonymous Pro', monospace);
    -webkit-font-smoothing: antialiased;
    color: var(--jv-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  .jv-gift__container { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  .jv-gift__hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
  }

  .jv-gift__badge {
    display: inline-flex;
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: 2rem;
    padding: 0.35rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--jv-teal);
    margin-bottom: 1.2rem;
  }

  .jv-gift__hero h1 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .jv-gift__hero-text {
    font-size: clamp(1rem, 2vw, 1.12rem);
    color: var(--jv-text-sec);
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Gift cards grid */
  .jv-gift__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 750px) {
    .jv-gift__grid {
      grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr));
    }
  }

  .jv-gift__card {
    background: var(--jv-bg);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 2rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .jv-gift__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .jv-gift__card--featured {
    border-color: var(--jv-teal);
    background: var(--jv-bg-subtle);
  }

  .jv-gift__card-icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }

  .jv-gift__card-title {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }

  .jv-gift__card-price {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--jv-teal);
    margin: 0.5rem 0;
  }

  .jv-gift__card-text {
    font-size: 0.88rem;
    color: var(--jv-text-sec);
    line-height: 1.6;
    margin: 0 0 1.2rem;
  }

  .jv-gift__card-btn {
    display: inline-flex;
    padding: 0.7rem 1.5rem;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: transform 0.2s;
    background: var(--jv-gradient);
    color: #fff;
  }

  .jv-gift__card-btn:hover { transform: translateY(-2px); color: #fff; }

  /* How it works */
  .jv-gift__how {
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .jv-gift__how h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .jv-gift__how-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 750px) {
    .jv-gift__how-steps { grid-template-columns: repeat(3, 1fr); }
  }

  .jv-gift__how-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--jv-gradient);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .jv-gift__how-step-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0 0 0.3rem;
  }

  .jv-gift__how-step-text {
    font-size: 0.85rem;
    color: var(--jv-text-sec);
    margin: 0;
  }

  /* Occasions */
  .jv-gift__occasions {
    text-align: center;
    margin-bottom: 2rem;
  }

  .jv-gift__occasions h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .jv-gift__occasion-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .jv-gift__occasion-pill {
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: 2rem;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
  }

  @supports (animation-timeline: view()) {
    .jv-gift__card, .jv-gift__how {
      animation: jvGiftFade 0.6s ease both;
      animation-timeline: view();
      animation-range: entry 10% entry 40%;
    }
  }

  @keyframes jvGiftFade {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }
{%- endstyle -%}

<section class="jv-gift" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="jv-gift__container">

    <header class="jv-gift__hero">
      <span class="jv-gift__badge">Geschenke</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="jv-gift__hero-text">{{ section.settings.intro }}</p>
    </header>

    <div class="jv-gift__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gift' -%}
          <div class="jv-gift__card{% if block.settings.featured %} jv-gift__card--featured{% endif %}" {{ block.shopify_attributes }}>
            <span class="jv-gift__card-icon">{{ block.settings.icon }}</span>
            <h3 class="jv-gift__card-title">{{ block.settings.title }}</h3>
            <div class="jv-gift__card-price">{{ block.settings.price }}</div>
            <p class="jv-gift__card-text">{{ block.settings.description }}</p>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="jv-gift__card-btn">{{ block.settings.button_label }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="jv-gift__how">
      <h2>{{ section.settings.how_heading }}</h2>
      <div class="jv-gift__how-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div {{ block.shopify_attributes }}>
              <span class="jv-gift__how-step-num">{{ block.settings.number }}</span>
              <h3 class="jv-gift__how-step-title">{{ block.settings.title }}</h3>
              <p class="jv-gift__how-step-text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.occasions != blank -%}
      <div class="jv-gift__occasions">
        <h2>{{ section.settings.occasions_heading }}</h2>
        <div class="jv-gift__occasion-pills">
          {%- assign occs = section.settings.occasions | split: ',' -%}
          {%- for o in occs -%}
            <span class="jv-gift__occasion-pill">{{ o | strip }}</span>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Geschenke",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Schenke Gesundheit." },
    { "type": "textarea", "id": "intro", "label": "Einleitung" },
    { "type": "text", "id": "how_heading", "label": "So-gehts-Ueberschrift", "default": "So funktioniert es" },
    { "type": "text", "id": "occasions_heading", "label": "Anlaesse-Ueberschrift", "default": "Perfekt fuer jeden Anlass" },
    { "type": "text", "id": "occasions", "label": "Anlaesse (kommagetrennt)", "default": "Geburtstag, Weihnachten, Vatertag, Muttertag, Valentinstag, Firmenevent" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    { "type": "gift", "name": "Gutschein", "settings": [
      { "type": "text", "id": "icon", "label": "Icon", "default": "🎁" },
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "text", "id": "price", "label": "Preis" },
      { "type": "textarea", "id": "description", "label": "Beschreibung" },
      { "type": "checkbox", "id": "featured", "label": "Hervorgehoben", "default": false },
      { "type": "text", "id": "button_label", "label": "Button-Text", "default": "Jetzt schenken" },
      { "type": "url", "id": "button_link", "label": "Button-Link" }
    ]},
    { "type": "step", "name": "So-gehts Schritt", "settings": [
      { "type": "text", "id": "number", "label": "Nummer", "default": "1" },
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]}
  ],
  "presets": [{ "name": "Juvantis: Geschenke" }]
}
{% endschema %}
