{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 3.2rem;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__heading {
      font-size: 4rem;
    }
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__wrapper {
    max-width: 72rem;
    margin: 0 auto;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table {
    width: 100%;
    border-collapse: collapse;
    background: rgb(var(--color-background));
    border-radius: 0.8rem;
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table thead {
    background: #4ea1d9;
    color: #fff;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table th {
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    font-weight: 600;
    padding: 1.4rem 1.6rem;
    text-align: left;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table td {
    font-size: 1.4rem;
    padding: 1.2rem 1.6rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
    vertical-align: middle;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table tr:last-child td {
    border-bottom: none;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__table tbody tr:hover {
    background: rgba(78, 161, 217, 0.04);
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__day {
    font-weight: 600;
    min-width: 10rem;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__time {
    white-space: nowrap;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__akut {
    display: inline-block;
    padding: 0.2rem 0.8rem;
    background: rgba(115, 194, 94, 0.12);
    color: #4a8c3a;
    border-radius: 0.4rem;
    font-size: 1.2rem;
    font-weight: 500;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__vereinbarung {
    display: inline-block;
    padding: 0.2rem 0.8rem;
    background: rgba(78, 161, 217, 0.12);
    color: #4ea1d9;
    border-radius: 0.4rem;
    font-size: 1.2rem;
    font-weight: 500;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__note {
    text-align: center;
    margin-top: 2rem;
    padding: 1.6rem 2rem;
    background: rgba(115, 194, 94, 0.08);
    border-left: 0.3rem solid #73c25e;
    border-radius: 0.4rem;
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.75);
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extras {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin-top: 2.4rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__extras {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    padding: 2rem;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-content {
    font-size: 1.3rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-content p {
    margin: 0.4rem 0;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-content ul {
    padding-left: 1.6rem;
    margin: 0.4rem 0;
  }

  #PraxisZeiten-{{ section.id }} .praxis-zeiten__extra-content li {
    margin-bottom: 0.3rem;
  }

  /* Mobile: stack table into cards */
  @media screen and (max-width: 749px) {
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table thead {
      display: none;
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table,
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table tbody,
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table tr,
    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table td {
      display: block;
      width: 100%;
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table tr {
      padding: 1.2rem 1.6rem;
      border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.06);
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table td {
      padding: 0.2rem 0;
      border-bottom: none;
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__day {
      font-size: 1.6rem;
      color: #4ea1d9;
      margin-bottom: 0.4rem;
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table td:before {
      content: attr(data-label);
      font-weight: 500;
      font-size: 1.2rem;
      color: rgba(var(--color-foreground), 0.5);
      display: block;
    }

    #PraxisZeiten-{{ section.id }} .praxis-zeiten__table td.praxis-zeiten__day:before {
      display: none;
    }
  }
{%- endstyle -%}

<div
  id="PraxisZeiten-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-zeiten__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-zeiten__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="praxis-zeiten__wrapper">
      <table class="praxis-zeiten__table">
        <thead>
          <tr>
            <th>Tag</th>
            <th>Sprechstunde</th>
            <th>Akutsprechstunde</th>
            <th>Hinweis</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.mo_label | default: "Montag" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.mo_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
            <td data-label="Akut: "><span class="praxis-zeiten__akut">{{ section.settings.mo_akut | default: "11:00–12:00" }}</span></td>
            <td data-label="">{{ section.settings.mo_note }}</td>
          </tr>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.di_label | default: "Dienstag" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.di_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
            <td data-label="Akut: "><span class="praxis-zeiten__akut">{{ section.settings.di_akut | default: "11:00–12:00" }}</span></td>
            <td data-label="">{{ section.settings.di_note }}</td>
          </tr>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.mi_label | default: "Mittwoch" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.mi_hours | default: "08:00–11:00" }}</td>
            <td data-label="Akut: "><span class="praxis-zeiten__akut">{{ section.settings.mi_akut | default: "11:00–12:00" }}</span></td>
            <td data-label="">{{ section.settings.mi_note }}</td>
          </tr>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.do_label | default: "Donnerstag" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.do_hours | default: "08:00–11:00, 12:30–16:00" }}</td>
            <td data-label="Akut: "><span class="praxis-zeiten__akut">{{ section.settings.do_akut | default: "11:00–12:00" }}</span></td>
            <td data-label="">{{ section.settings.do_note }}</td>
          </tr>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.fr_label | default: "Freitag" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.fr_hours | default: "08:00–11:00" }}</td>
            <td data-label="Akut: "><span class="praxis-zeiten__akut">{{ section.settings.fr_akut | default: "11:00–12:00" }}</span></td>
            <td data-label="">{{ section.settings.fr_note }}</td>
          </tr>
          <tr>
            <td class="praxis-zeiten__day" data-label="">{{ section.settings.sa_label | default: "Samstag" }}</td>
            <td class="praxis-zeiten__time" data-label="Sprechstunde: ">{{ section.settings.sa_hours | default: "09:00–13:00" }}</td>
            <td data-label="Akut: ">—</td>
            <td data-label=""><span class="praxis-zeiten__vereinbarung">{{ section.settings.sa_note | default: "nur nach Vereinbarung" }}</span></td>
          </tr>
        </tbody>
      </table>

      {%- if section.settings.note != blank -%}
        <div class="praxis-zeiten__note">
          {{ section.settings.note | escape }}
        </div>
      {%- endif -%}

      {%- if section.settings.blutentnahme_info != blank or section.settings.akut_rules != blank or section.settings.infekt_info != blank or section.settings.abend_info != blank -%}
        <div class="praxis-zeiten__extras">
          {%- if section.settings.blutentnahme_info != blank -%}
            <div class="praxis-zeiten__extra-card">
              <h3 class="praxis-zeiten__extra-title">&#129656; Blutentnahme</h3>
              <div class="praxis-zeiten__extra-content">{{ section.settings.blutentnahme_info }}</div>
            </div>
          {%- endif -%}
          {%- if section.settings.akut_rules != blank -%}
            <div class="praxis-zeiten__extra-card">
              <h3 class="praxis-zeiten__extra-title">&#9888;&#65039; Akutsprechstunde</h3>
              <div class="praxis-zeiten__extra-content">{{ section.settings.akut_rules }}</div>
            </div>
          {%- endif -%}
          {%- if section.settings.infekt_info != blank -%}
            <div class="praxis-zeiten__extra-card">
              <h3 class="praxis-zeiten__extra-title">&#129440; Infektionssprechstunde</h3>
              <div class="praxis-zeiten__extra-content">{{ section.settings.infekt_info }}</div>
            </div>
          {%- endif -%}
          {%- if section.settings.abend_info != blank -%}
            <div class="praxis-zeiten__extra-card">
              <h3 class="praxis-zeiten__extra-title">&#127769; Abend- &amp; Samstagssprechstunde</h3>
              <div class="praxis-zeiten__extra-content">{{ section.settings.abend_info }}</div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

