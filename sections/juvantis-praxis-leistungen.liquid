{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 4rem;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__heading {
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisLeistungen-{{ section.id }} .praxis-leistungen__heading {
      font-size: 4rem;
    }
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__category {
    margin-bottom: 3.2rem;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__category:last-child {
    margin-bottom: 0;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__category-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 0.2rem solid #4ea1d9;
    color: #4ea1d9;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    #PraxisLeistungen-{{ section.id }} .praxis-leistungen__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    #PraxisLeistungen-{{ section.id }} .praxis-leistungen__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    #PraxisLeistungen-{{ section.id }} .praxis-leistungen__grid--four {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__card {
    background: rgb(var(--color-background));
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    border-radius: 0.8rem;
    padding: 2.4rem 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__card:hover {
    box-shadow: 0 0.4rem 2rem rgba(var(--color-foreground), 0.06);
    transform: translateY(-0.2rem);
    border-color: #4ea1d9;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__icon {
    font-size: 3.2rem;
    margin-bottom: 1.2rem;
    display: block;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__name {
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  #PraxisLeistungen-{{ section.id }} .praxis-leistungen__text {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.65);
  }
{%- endstyle -%}

<div
  id="PraxisLeistungen-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-leistungen__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-leistungen__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="praxis-leistungen__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      {%- assign categories = "" -%}
      {%- for block in section.blocks -%}
        {%- unless categories contains block.settings.category -%}
          {%- if categories != "" -%}
            {%- assign categories = categories | append: "|||" -%}
          {%- endif -%}
          {%- assign categories = categories | append: block.settings.category -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- assign category_list = categories | split: "|||" -%}

      {%- for category in category_list -%}
        <div class="praxis-leistungen__category">
          {%- if category != blank -%}
            <h3 class="praxis-leistungen__category-title">{{ category | escape }}</h3>
          {%- endif -%}

          <div class="praxis-leistungen__grid">
            {%- for block in section.blocks -%}
              {%- if block.settings.category == category -%}
                <div class="praxis-leistungen__card" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="praxis-leistungen__icon">{{ block.settings.icon }}</span>
                  {%- endif -%}
                  {%- if block.settings.name != blank -%}
                    <h4 class="praxis-leistungen__name">{{ block.settings.name | escape }}</h4>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="praxis-leistungen__text">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Praxis Leistungen",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Unsere Leistungen",
      "label": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Umfassende hausärztliche und internistische Versorgung mit modernster Diagnostik",
      "label": "Beschreibung"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-1",
      "label": "Farbschema"
    },
    {
      "type": "header",
      "content": "Abstandseinstellungen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Leistung",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "default": "🩺",
          "label": "Icon (Emoji)"
        },
        {
          "type": "text",
          "id": "name",
          "default": "Leistung",
          "label": "Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "Beschreibung der Leistung",
          "label": "Beschreibung"
        },
        {
          "type": "text",
          "id": "category",
          "default": "Weitere Leistungen",
          "label": "Kategorie"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Praxis Leistungen",
      "blocks": [
        { "type": "service", "settings": { "icon": "🫀", "name": "Cardio Check-Up", "description": "Umfassende Herzkreislauf-Diagnostik mit EKG, Belastungs-EKG und Echokardiographie", "category": "Gesundheits Check-Ups" } },
        { "type": "service", "settings": { "icon": "🩸", "name": "Angio Check-Up", "description": "Gefäßdiagnostik mit Ultraschall der Hals- und Beingefäße", "category": "Gesundheits Check-Ups" } },
        { "type": "service", "settings": { "icon": "🔬", "name": "Tumorscreening", "description": "Vorsorgeuntersuchungen zur Früherkennung von Tumorerkrankungen", "category": "Gesundheits Check-Ups" } },
        { "type": "service", "settings": { "icon": "💓", "name": "Echokardiographie", "description": "Ultraschalluntersuchung des Herzens zur Beurteilung von Struktur und Funktion", "category": "Ultraschalldiagnostik" } },
        { "type": "service", "settings": { "icon": "🔍", "name": "Carotis Duplex", "description": "Ultraschall der Halsschlagadern zur Schlaganfall-Prävention", "category": "Ultraschalldiagnostik" } },
        { "type": "service", "settings": { "icon": "🦋", "name": "Schilddrüsen-Sonographie", "description": "Ultraschalldiagnostik der Schilddrüse bei Über-/Unterfunktion und Knotenbildung", "category": "Ultraschalldiagnostik" } },
        { "type": "service", "settings": { "icon": "🦵", "name": "Ultraschall Beingefäße", "description": "Diagnostik der Beinvenen und -arterien bei Thrombose-Verdacht und Durchblutungsstörungen", "category": "Ultraschalldiagnostik" } },
        { "type": "service", "settings": { "icon": "🏃", "name": "Belastungs-EKG", "description": "EKG unter körperlicher Belastung zur Erkennung von Durchblutungsstörungen des Herzens", "category": "Weitere Leistungen" } },
        { "type": "service", "settings": { "icon": "🫁", "name": "Lungenfunktion", "description": "Spirometrie zur Diagnostik von Asthma, COPD und anderen Lungenerkrankungen", "category": "Weitere Leistungen" } },
        { "type": "service", "settings": { "icon": "🧪", "name": "Labordiagnostik", "description": "Umfassende Blutuntersuchungen und Laboranalysen für präzise Diagnosen", "category": "Weitere Leistungen" } },
        { "type": "service", "settings": { "icon": "💉", "name": "Impfungen", "description": "Schutzimpfungen nach STIKO-Empfehlung inkl. Reisemedizinische Beratung", "category": "Weitere Leistungen" } }
      ]
    }
  ]
}
{% endschema %}
