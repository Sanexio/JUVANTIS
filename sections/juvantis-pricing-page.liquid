{%- comment -%}
  Juvantis Section: Pricing Page (Full)
  Zweck: Detaillierte Preisseite mit Abo-Plaenen + Einzelpreisen + FAQ
  Design: Apple-inspired Design System
{%- endcomment -%}

{%- if template.suffix == 'preise' -%}

{%- style -%}
  #PricingPage-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #PricingPage-{{ section.id }} .pricing__container {
    max-width: 120rem;
    margin: 0 auto;
    padding: 0 2.4rem;
  }

  /* Hero */
  #PricingPage-{{ section.id }} .pricing__hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  #PricingPage-{{ section.id }} .pricing__badge {
    display: inline-block;
    background: var(--apple-bg-gray);
    border-radius: 98rem;
    padding: 0.5rem 1.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-secondary);
    margin-bottom: 2rem;
  }

  #PricingPage-{{ section.id }} .pricing__hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.2rem;
    color: var(--apple-text);
  }

  #PricingPage-{{ section.id }} .pricing__hero p {
    color: var(--apple-text-secondary);
    font-size: 1.7rem;
    line-height: 1.53;
    margin: 0;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Plans Grid */
  #PricingPage-{{ section.id }} .pricing__plans {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 6rem;
    max-width: 84rem;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 990px) {
    #PricingPage-{{ section.id }} .pricing__plans {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.4rem;
    }
  }

  #PricingPage-{{ section.id }} .pricing__plan {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 3.2rem 2.8rem;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(2.4rem);
    animation: pricingFadeIn 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #PricingPage-{{ section.id }} .pricing__plan:nth-child(1) { animation-delay: 0s; }
  #PricingPage-{{ section.id }} .pricing__plan:nth-child(2) { animation-delay: 0.12s; }
  #PricingPage-{{ section.id }} .pricing__plan:nth-child(3) { animation-delay: 0.24s; }

  #PricingPage-{{ section.id }} .pricing__plan:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #PricingPage-{{ section.id }} .pricing__plan--featured {
    background: var(--apple-text);
    color: #fff;
  }

  #PricingPage-{{ section.id }} .pricing__plan-badge {
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--apple-link);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 0.4rem 1.6rem;
    border-radius: 98rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  #PricingPage-{{ section.id }} .pricing__plan-name {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.8rem;
  }

  #PricingPage-{{ section.id }} .pricing__plan-price {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin: 0;
  }

  #PricingPage-{{ section.id }} .pricing__plan-period {
    font-size: 1.5rem;
    line-height: 1.53;
    font-weight: 400;
    opacity: 0.6;
  }

  #PricingPage-{{ section.id }} .pricing__plan-desc {
    font-size: 1.5rem;
    line-height: 1.53;
    margin: 0.8rem 0 2rem;
    opacity: 0.7;
  }

  #PricingPage-{{ section.id }} .pricing__plan--featured .pricing__plan-desc,
  #PricingPage-{{ section.id }} .pricing__plan--featured .pricing__plan-period {
    color: rgba(255,255,255,0.7);
  }

  #PricingPage-{{ section.id }} .pricing__plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2.8rem;
    flex: 1;
  }

  #PricingPage-{{ section.id }} .pricing__plan-features li {
    font-size: 1.5rem;
    line-height: 1.53;
    padding: 0.6rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }

  #PricingPage-{{ section.id }} .pricing__plan-features li::before {
    content: '\2713';
    color: var(--apple-link);
    font-weight: 700;
    flex-shrink: 0;
  }

  #PricingPage-{{ section.id }} .pricing__plan--featured .pricing__plan-features li {
    color: rgba(255,255,255,0.85);
  }

  #PricingPage-{{ section.id }} .pricing__plan--featured .pricing__plan-features li::before {
    color: #fff;
  }

  #PricingPage-{{ section.id }} .pricing__plan-btn {
    display: block;
    text-align: center;
    padding: 1.2rem 2.4rem;
    border-radius: 98rem;
    font-weight: 600;
    font-size: 1.7rem;
    text-decoration: none;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    cursor: pointer;
  }

  #PricingPage-{{ section.id }} .pricing__plan-btn:hover {
    opacity: 0.85;
    transform: scale(1.02);
  }

  #PricingPage-{{ section.id }} .pricing__plan-btn--primary {
    background: var(--apple-link);
    color: #fff;
  }

  #PricingPage-{{ section.id }} .pricing__plan-btn--featured {
    background: #fff;
    color: var(--apple-text);
  }

  /* Einzelpreise Table */
  #PricingPage-{{ section.id }} .pricing__singles-heading {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 3rem;
    color: var(--apple-text);
  }

  #PricingPage-{{ section.id }} .pricing__table-wrap {
    overflow-x: auto;
    margin-bottom: 6rem;
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
    border-radius: 2rem;
    overflow: hidden;
  }

  #PricingPage-{{ section.id }} .pricing__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 28rem;
  }

  #PricingPage-{{ section.id }} .pricing__table th,
  #PricingPage-{{ section.id }} .pricing__table td {
    padding: 1.2rem 2rem;
    text-align: left;
    font-size: 1.5rem;
    line-height: 1.53;
  }

  #PricingPage-{{ section.id }} .pricing__table th {
    font-weight: 600;
    color: #fff;
    background: var(--apple-text);
  }

  #PricingPage-{{ section.id }} .pricing__table tr {
    transition: background 0.2s ease;
  }

  #PricingPage-{{ section.id }} .pricing__table tbody tr:hover {
    background: rgba(0,0,0,0.02);
  }

  #PricingPage-{{ section.id }} .pricing__table td {
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--apple-text-secondary);
  }

  #PricingPage-{{ section.id }} .pricing__table td:last-child {
    font-weight: 600;
    color: var(--apple-text);
    white-space: nowrap;
  }

  /* FAQ Accordion */
  #PricingPage-{{ section.id }} .pricing__faq-heading {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 3rem;
    color: var(--apple-text);
  }

  #PricingPage-{{ section.id }} .pricing__faq {
    max-width: 56rem;
    margin: 0 auto 4rem;
  }

  #PricingPage-{{ section.id }} .pricing__faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  #PricingPage-{{ section.id }} .pricing__faq-q {
    width: 100%;
    background: none;
    border: none;
    padding: 1.6rem 0;
    text-align: left;
    cursor: pointer;
    font-family: var(--apple-font);
    font-size: 1.7rem;
    font-weight: 600;
    color: var(--apple-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.6rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  #PricingPage-{{ section.id }} .pricing__faq-q:hover {
    color: var(--apple-link);
  }

  #PricingPage-{{ section.id }} .pricing__faq-icon {
    width: 2.4rem;
    height: 2.4rem;
    flex-shrink: 0;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #PricingPage-{{ section.id }} .pricing__faq-icon::before,
  #PricingPage-{{ section.id }} .pricing__faq-icon::after {
    content: '';
    position: absolute;
    background: var(--apple-text-secondary);
    border-radius: 1px;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), background 0.2s ease;
  }

  #PricingPage-{{ section.id }} .pricing__faq-icon::before {
    width: 1.6rem;
    height: 0.2rem;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  #PricingPage-{{ section.id }} .pricing__faq-icon::after {
    width: 0.2rem;
    height: 1.6rem;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  #PricingPage-{{ section.id }} .pricing__faq-item.is-open .pricing__faq-icon {
    transform: rotate(45deg);
  }

  #PricingPage-{{ section.id }} .pricing__faq-q:hover .pricing__faq-icon::before,
  #PricingPage-{{ section.id }} .pricing__faq-q:hover .pricing__faq-icon::after {
    background: var(--apple-link);
  }

  #PricingPage-{{ section.id }} .pricing__faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #PricingPage-{{ section.id }} .pricing__faq-item.is-open .pricing__faq-a {
    max-height: 30rem;
  }

  #PricingPage-{{ section.id }} .pricing__faq-a p {
    padding: 0 0 1.6rem;
    margin: 0;
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    max-width: 48rem;
  }

  /* Responsive */
  @media (max-width: 989px) {
    #PricingPage-{{ section.id }} .pricing__hero {
      padding: 4rem 0 3rem;
    }
  }

  @keyframes pricingFadeIn {
    from { opacity: 0; transform: translateY(2.4rem); }
    to { opacity: 1; transform: translateY(0); }
  }
{%- endstyle -%}

<section
  id="PricingPage-{{ section.id }}"
  class="section-{{ section.id }}-padding"
  style="
    padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
  "
>
  <div class="page-width">
    <div class="pricing__container">

      <header class="pricing__hero">
        <span class="pricing__badge">Preise</span>
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subtitle }}</p>
      </header>

      <!-- Abo-Plaene -->
      <div class="pricing__plans">
        {%- for block in section.blocks -%}
          {%- if block.type == 'plan' -%}
            <div class="pricing__plan{% if block.settings.featured %} pricing__plan--featured{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.badge != blank -%}
                <span class="pricing__plan-badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              <h3 class="pricing__plan-name">{{ block.settings.name }}</h3>
              <p class="pricing__plan-price">{{ block.settings.price }}<span class="pricing__plan-period"> {{ block.settings.period }}</span></p>
              <p class="pricing__plan-desc">{{ block.settings.description }}</p>
              {%- if block.settings.features != blank -%}
                <ul class="pricing__plan-features">
                  {%- assign feats = block.settings.features | split: '|' -%}
                  {%- for f in feats -%}
                    <li>{{ f | strip }}</li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
              <a href="{{ block.settings.button_link }}" class="pricing__plan-btn {% if block.settings.featured %}pricing__plan-btn--featured{% else %}pricing__plan-btn--primary{% endif %}">
                {{ block.settings.button_label }}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Einzelpreise -->
      {%- assign has_singles = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'single_price' -%}
          {%- assign has_singles = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_singles -%}
        <h2 class="pricing__singles-heading">{{ section.settings.singles_heading }}</h2>
        <div class="pricing__table-wrap">
          <table class="pricing__table">
            <thead>
              <tr>
                <th>Untersuchung</th>
                <th>Preis</th>
              </tr>
            </thead>
            <tbody>
              {%- for block in section.blocks -%}
                {%- if block.type == 'single_price' -%}
                  <tr {{ block.shopify_attributes }}>
                    <td>{{ block.settings.name }}</td>
                    <td>{{ block.settings.price }}</td>
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {%- endif -%}

      <!-- FAQ -->
      {%- assign has_faq = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          {%- assign has_faq = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_faq -%}
        <h2 class="pricing__faq-heading">{{ section.settings.faq_heading }}</h2>
        <div class="pricing__faq">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <div class="pricing__faq-item" {{ block.shopify_attributes }}>
                <button class="pricing__faq-q" onclick="this.parentElement.classList.toggle('is-open')">
                  {{ block.settings.question }}
                  <span class="pricing__faq-icon"></span>
                </button>
                <div class="pricing__faq-a">
                  <p>{{ block.settings.answer }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Preise",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Transparent. Fair. Flexibel." },
    { "type": "text", "id": "subtitle", "label": "Unterzeile", "default": "Starte kostenlos und upgrade, wenn du bereit bist. Keine versteckten Kosten." },
    { "type": "text", "id": "singles_heading", "label": "Einzelpreise-Ueberschrift", "default": "Einzeluntersuchungen" },
    { "type": "text", "id": "faq_heading", "label": "FAQ-Ueberschrift", "default": "Haeufige Fragen zu unseren Preisen" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Abo-Plan",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Premium" },
        { "type": "text", "id": "price", "label": "Preis", "default": "14,99 EUR" },
        { "type": "text", "id": "period", "label": "Zeitraum", "default": "/Monat" },
        { "type": "textarea", "id": "description", "label": "Beschreibung" },
        { "type": "textarea", "id": "features", "label": "Features (| getrennt)", "default": "Feature 1|Feature 2|Feature 3" },
        { "type": "checkbox", "id": "featured", "label": "Hervorgehoben", "default": false },
        { "type": "text", "id": "badge", "label": "Badge-Text" },
        { "type": "text", "id": "button_label", "label": "Button-Text", "default": "Starten" },
        { "type": "url", "id": "button_link", "label": "Button-Link" }
      ]
    },
    {
      "type": "single_price",
      "name": "Einzelpreis",
      "settings": [
        { "type": "text", "id": "name", "label": "Untersuchung" },
        { "type": "text", "id": "price", "label": "Preis" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage" },
        { "type": "textarea", "id": "answer", "label": "Antwort" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis: Preise" }]
}
{% endschema %}
