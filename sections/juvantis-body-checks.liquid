{%- comment -%}
  Juvantis Section: Body Checks
  Apple-inspired design system rewrite
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- style -%}
  #BodyChecks-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .main-page-title.page-title { display: none !important; }

  #BodyChecks-{{ section.id }} .bc__container {
    max-width: 100rem;
    margin: 0 auto;
    padding: 0 2.4rem;
  }

  /* Hero */
  #BodyChecks-{{ section.id }} .bc__hero {
    text-align: center;
    padding: 6rem 0 4rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BodyChecks-{{ section.id }} .bc__label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.6rem;
  }

  #BodyChecks-{{ section.id }} .bc__hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin: 0 0 2rem;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .bc__hero-text {
    font-size: 1.7rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    max-width: 56rem;
    margin: 0 auto;
  }

  /* USP Box — dark */
  #BodyChecks-{{ section.id }} .bc__usp {
    background: var(--apple-text);
    color: #fff;
    border-radius: 2rem;
    padding: 4rem 3.2rem;
    text-align: center;
    margin-bottom: 6rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.12s forwards;
  }

  #BodyChecks-{{ section.id }} .bc__usp h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 1.2rem;
    color: #fff;
  }

  #BodyChecks-{{ section.id }} .bc__usp p {
    margin: 0;
    font-size: 1.7rem;
    line-height: 1.53;
    opacity: 0.8;
    max-width: 50rem;
    margin: 0 auto;
  }

  /* Section title */
  #BodyChecks-{{ section.id }} .bc__section-title {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 4rem;
    color: var(--apple-text);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.24s forwards;
  }

  /* Bento Grid */
  #BodyChecks-{{ section.id }} .bc__bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin-bottom: 6rem;
  }

  @media (min-width: 750px) {
    #BodyChecks-{{ section.id }} .bc__bento {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    #BodyChecks-{{ section.id }} .bc__bento {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #BodyChecks-{{ section.id }} .bc__card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 2.8rem;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BodyChecks-{{ section.id }} .bc__card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #BodyChecks-{{ section.id }} .bc__card-icon {
    width: 4.8rem;
    height: 4.8rem;
    background: rgba(0,0,0,0.02);
    border-radius: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.6rem;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .bc__card-icon svg {
    width: 2.4rem;
    height: 2.4rem;
  }

  #BodyChecks-{{ section.id }} .bc__card-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.8rem;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .bc__card-text {
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    margin: 0;
  }

  /* Timeline */
  #BodyChecks-{{ section.id }} .bc__timeline {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 4.8rem 3.2rem;
    margin-bottom: 6rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BodyChecks-{{ section.id }} .bc__timeline h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 4rem;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .bc__timeline-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }

  @media (min-width: 750px) {
    #BodyChecks-{{ section.id }} .bc__timeline-steps {
      grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    }
  }

  #BodyChecks-{{ section.id }} .bc__tl-step {
    text-align: center;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BodyChecks-{{ section.id }} .bc__tl-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    background: var(--apple-text);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.7rem;
    margin-bottom: 1.2rem;
  }

  #BodyChecks-{{ section.id }} .bc__tl-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    color: var(--apple-text);
  }

  #BodyChecks-{{ section.id }} .bc__tl-text {
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    margin: 0;
  }

  /* CTA */
  #BodyChecks-{{ section.id }} .bc__cta {
    text-align: center;
    padding: 2rem 0 0;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bcReveal 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BodyChecks-{{ section.id }} .bc__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.4rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #BodyChecks-{{ section.id }} .bc__cta-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,113,227,0.2);
    color: #fff;
  }

  /* Mobile padding multiplier */
  @media (max-width: 749px) {
    #BodyChecks-{{ section.id }} .bc__hero { padding: 4.5rem 0 3rem; }
    #BodyChecks-{{ section.id }} .bc__usp { padding: 3rem 2.4rem; margin-bottom: 4.5rem; }
    #BodyChecks-{{ section.id }} .bc__section-title { margin-bottom: 3rem; }
    #BodyChecks-{{ section.id }} .bc__bento { margin-bottom: 4.5rem; }
    #BodyChecks-{{ section.id }} .bc__timeline { padding: 3.6rem 2.4rem; margin-bottom: 4.5rem; }
  }

  @keyframes bcReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{%- endstyle -%}

<section
  id="BodyChecks-{{ section.id }}"
  class="section-{{ section.id }}-padding"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width bc__container">

    <header class="bc__hero">
      <span class="bc__label">Apparative Diagnostik</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="bc__hero-text">{{ section.settings.intro }}</p>
    </header>

    <div class="bc__usp">
      <h2>{{ section.settings.usp_heading }}</h2>
      <p>{{ section.settings.usp_text }}</p>
    </div>

    <h2 class="bc__section-title">{{ section.settings.checks_heading }}</h2>
    <div class="bc__bento">
      {%- assign check_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'check' -%}
          <div class="bc__card" style="animation-delay: {{ check_index | times: 0.12 | plus: 0.36 }}s;" {{ block.shopify_attributes }}>
            <div class="bc__card-icon">
              {%- case block.settings.icon -%}
                {%- when 'sono' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M220,160a12,12,0,1,1-12-12A12,12,0,0,1,220,160Zm12,0a36,36,0,0,1-24,33.94V200a56,56,0,0,1-56,56H144a56,56,0,0,1-56-56v-9.73a88.07,88.07,0,0,1-80-87.59V64a16,16,0,0,1,32,0v38.68a56.09,56.09,0,0,0,48,55.43V200a24,24,0,0,0,24,24h8a24,24,0,0,0,24-24v-6.06A36,36,0,0,1,232,160ZM168,64a16,16,0,0,1,32,0v38.68a56,56,0,0,1-32,50.64V64Z"/></svg>
                {%- when 'schilddruese' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M240,102c0,70-103.79,126.66-108.21,129a8,8,0,0,1-7.58,0C119.79,228.66,16,172,16,102A62.07,62.07,0,0,1,78,40c20.65,0,38.73,8.88,50,23.89C139.27,48.88,157.35,40,178,40A62.07,62.07,0,0,1,240,102Z"/></svg>
                {%- when 'echo' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M240,102c0,70-103.79,126.66-108.21,129a8,8,0,0,1-7.58,0C119.79,228.66,16,172,16,102A62.07,62.07,0,0,1,78,40c20.65,0,38.73,8.88,50,23.89C139.27,48.88,157.35,40,178,40A62.07,62.07,0,0,1,240,102Z"/></svg>
                {%- when 'carotis' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm-8,88H187.31l-18.64-24.84a8,8,0,0,0-13.16.46L128.31,144H112a8,8,0,0,0-6.4,3.2L91.2,168H48a8,8,0,0,0,0,16H96a8,8,0,0,0,6.4-3.2L116.8,160h17.51a8,8,0,0,0,6.69-3.6l22.1-33.83L178.65,144h29.35a8,8,0,0,0,0-16Z"/></svg>
                {%- when 'ekg' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm-8,88H187.31l-18.64-24.84a8,8,0,0,0-13.16.46L128.31,144H112a8,8,0,0,0-6.4,3.2L91.2,168H48a8,8,0,0,0,0,16H96a8,8,0,0,0,6.4-3.2L116.8,160h17.51a8,8,0,0,0,6.69-3.6l22.1-33.83L178.65,144h29.35a8,8,0,0,0,0-16Z"/></svg>
                {%- when 'ergo' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M213.85,125.46l-112,120a8,8,0,0,1-13.69-7l14.66-73.33L45.19,143.49a8,8,0,0,1-3-13l112-120a8,8,0,0,1,13.69,7L153.18,90.9l57.63,21.61a8,8,0,0,1,3,12.95Z"/></svg>
                {%- when 'lufu' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.12,104.12,0,0,0,128,24Zm88,104a87.61,87.61,0,0,1-3.33,24H174.16a157.44,157.44,0,0,0,0-48h38.51A87.61,87.61,0,0,1,216,128ZM102,168h52a115.11,115.11,0,0,1-26,45A115.27,115.27,0,0,1,102,168Zm-3.9-16a140.84,140.84,0,0,1,0-48h59.88a140.84,140.84,0,0,1,0,48ZM40,128a87.61,87.61,0,0,1,3.33-24H81.84a157.44,157.44,0,0,0,0,48H43.33A87.61,87.61,0,0,1,40,128ZM154,88H102a115.11,115.11,0,0,1,26-45A115.27,115.27,0,0,1,154,88Zm73.56-16H192.9a143.27,143.27,0,0,0-20.79-32.51A88.19,88.19,0,0,1,227.56,72ZM83.89,39.49A143.27,143.27,0,0,0,63.1,72H28.44A88.19,88.19,0,0,1,83.89,39.49ZM28.44,184H63.1a143.27,143.27,0,0,0,20.79,32.51A88.19,88.19,0,0,1,28.44,184Zm143.67,32.51A143.27,143.27,0,0,0,192.9,184h34.66A88.19,88.19,0,0,1,172.11,216.51Z"/></svg>
                {%- when 'diving' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.12,104.12,0,0,0,128,24Zm88,104a87.61,87.61,0,0,1-3.33,24H174.16a157.44,157.44,0,0,0,0-48h38.51A87.61,87.61,0,0,1,216,128ZM102,168h52a115.11,115.11,0,0,1-26,45A115.27,115.27,0,0,1,102,168Zm-3.9-16a140.84,140.84,0,0,1,0-48h59.88a140.84,140.84,0,0,1,0,48ZM40,128a87.61,87.61,0,0,1,3.33-24H81.84a157.44,157.44,0,0,0,0,48H43.33A87.61,87.61,0,0,1,40,128ZM154,88H102a115.11,115.11,0,0,1,26-45A115.27,115.27,0,0,1,154,88Zm73.56-16H192.9a143.27,143.27,0,0,0-20.79-32.51A88.19,88.19,0,0,1,227.56,72ZM83.89,39.49A143.27,143.27,0,0,0,63.1,72H28.44A88.19,88.19,0,0,1,83.89,39.49ZM28.44,184H63.1a143.27,143.27,0,0,0,20.79,32.51A88.19,88.19,0,0,1,28.44,184Zm143.67,32.51A143.27,143.27,0,0,0,192.9,184h34.66A88.19,88.19,0,0,1,172.11,216.51Z"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23Zm-90.08-42.91c-15.91-8.05-31.05-12.32-45.22-12.81l24.47-40.8A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167C171.4,169.34,154.29,168.34,131.61,156.86Z"/></svg>
              {%- endcase -%}
            </div>
            <h3 class="bc__card-title">{{ block.settings.title }}</h3>
            <p class="bc__card-text">{{ block.settings.description }}</p>
          </div>
          {%- assign check_index = check_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="bc__timeline" style="animation-delay: {{ check_index | times: 0.12 | plus: 0.48 }}s;">
      <h2>{{ section.settings.timeline_heading }}</h2>
      <div class="bc__timeline-steps">
        {%- assign step_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'timeline_step' -%}
            <div class="bc__tl-step" style="animation-delay: {{ step_index | times: 0.12 | plus: 0.6 }}s;" {{ block.shopify_attributes }}>
              <span class="bc__tl-num">{{ block.settings.number }}</span>
              <h3 class="bc__tl-title">{{ block.settings.title }}</h3>
              <p class="bc__tl-text">{{ block.settings.text }}</p>
            </div>
            {%- assign step_index = step_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="bc__cta" style="animation-delay: {{ step_index | times: 0.12 | plus: 0.72 }}s;">
      <a href="{{ section.settings.cta_link }}" class="bc__cta-btn">
        {{ section.settings.cta_label }}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Juvantis: Body Checks",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Du bist mehr als die Summe deiner Teile."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitung"
    },
    {
      "type": "text",
      "id": "usp_heading",
      "label": "USP-Ueberschrift",
      "default": "Was uns unterscheidet"
    },
    {
      "type": "textarea",
      "id": "usp_text",
      "label": "USP-Text",
      "default": "Wir schauen nicht nur ins Blut, sondern in deinen Koerper. Ultraschall, EKG, Lungenfunktion — apparative Diagnostik und Labormedizin unter einem Dach."
    },
    {
      "type": "text",
      "id": "checks_heading",
      "label": "Untersuchungen-Ueberschrift",
      "default": "Unsere Untersuchungen"
    },
    {
      "type": "text",
      "id": "timeline_heading",
      "label": "Ablauf-Ueberschrift",
      "default": "So laeuft dein Body Check ab"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-Text",
      "default": "Jetzt Body Check buchen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA-Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "label": "Abstand oben"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Abstand unten"
    }
  ],
  "blocks": [
    {
      "type": "check",
      "name": "Untersuchung",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "🔊"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung"
        }
      ]
    },
    {
      "type": "timeline_step",
      "name": "Ablauf-Schritt",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Nummer",
          "default": "1"
        },
