{%- style -%}
  #PraxisFAQ-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-family: var(--apple-font);
    color: var(--apple-text);
    background: var(--apple-bg-white);
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 6rem;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__heading {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    line-height: 1.07;
    letter-spacing: -0.035em;
    color: var(--apple-text);
    margin-bottom: 1.6rem;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__description {
    font-family: var(--apple-font);
    font-size: 1.7rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    max-width: 50rem;
    margin: 0 auto;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__wrap {
    max-width: 80rem;
    margin: 0 auto;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__category {
    margin-bottom: 4.8rem;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__category:last-child {
    margin-bottom: 0;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__category-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--apple-text);
    margin-bottom: 2rem;
    padding-bottom: 0;
    border-bottom: none;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item {
    border-bottom: 1px solid rgba(29, 29, 31, 0.08);
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item:last-child {
    border-bottom: none;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 0;
    font-family: var(--apple-font);
    font-size: 1.7rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    cursor: pointer;
    list-style: none;
    color: var(--apple-text);
    transition: color 0.25s ease;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item summary::marker,
  #PraxisFAQ-{{ section.id }} .praxis-faq__item summary::-webkit-details-marker {
    display: none;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item summary:hover {
    color: var(--apple-link);
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item summary svg {
    width: 1.8rem;
    height: 1.8rem;
    flex-shrink: 0;
    fill: var(--apple-text-tertiary);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__item[open] summary svg {
    transform: rotate(45deg);
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer {
    padding: 0 0 2.4rem;
    font-family: var(--apple-font);
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    max-width: 72rem;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer p {
    margin: 0 0 1rem;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer p:last-child {
    margin-bottom: 0;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer ul {
    padding-left: 2rem;
    margin: 0.6rem 0;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer li {
    margin-bottom: 0.4rem;
    line-height: 1.53;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer a {
    color: var(--apple-link);
    font-weight: 400;
    text-decoration: none;
  }

  #PraxisFAQ-{{ section.id }} .praxis-faq__answer a:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<div id="PraxisFAQ-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="praxis-faq__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="praxis-faq__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="praxis-faq__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      {%- assign categories = "" -%}
      {%- for block in section.blocks -%}
        {%- unless categories contains block.settings.category -%}
          {%- if categories != "" -%}{%- assign categories = categories | append: "|||" -%}{%- endif -%}
          {%- assign categories = categories | append: block.settings.category -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- assign cat_list = categories | split: "|||" -%}

      <div class="praxis-faq__wrap">
        {%- for cat in cat_list -%}
          <div class="praxis-faq__category">
            {%- if cat != blank -%}
              <h3 class="praxis-faq__category-title">{{ cat | escape }}</h3>
            {%- endif -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.category == cat -%}
                <details class="praxis-faq__item" {{ block.shopify_attributes }}>
                  <summary>
                    {{ block.settings.question | escape }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                  </summary>
                  <div class="praxis-faq__answer">{{ block.settings.answer }}</div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Praxis FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "default": "Häufige Fragen", "label": "Überschrift" },
    { "type": "textarea", "id": "description", "label": "Beschreibung" },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Akzent 1" },
        { "value": "accent-2", "label": "Akzent 2" },
        { "value": "background-1", "label": "Hintergrund 1" },
        { "value": "background-2", "label": "Hintergrund 2" },
        { "value": "inverse", "label": "Invertiert" }
      ],
      "default": "background-1",
      "label": "Farbschema"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand oben", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Abstand unten", "default": 40 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ-Eintrag",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage" },
        { "type": "richtext", "id": "answer", "label": "Antwort" },
        { "type": "text", "id": "category", "default": "Allgemein", "label": "Kategorie" }
      ]
    }
  ],
  "presets": [{ "name": "Praxis FAQ" }]
}
{% endschema %}
