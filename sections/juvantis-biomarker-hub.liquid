{%- comment -%}
  Juvantis Section: Biomarker-Lexikon Hub
  Zweck: Uebersichtsseite aller Biomarker mit Suche und Kategorien
  Design: Apple-inspired Design System
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- if template.suffix == 'biomarker' -%}

{%- style -%}
  #BioHub-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #BioHub-{{ section.id }} .hub-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  #BioHub-{{ section.id }} .hub-hero {
    text-align: center;
    padding: 4rem 0 2.4rem;
  }

  #BioHub-{{ section.id }} .hub-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.6rem;
  }

  #BioHub-{{ section.id }} .hub-hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.6rem;
    color: var(--apple-text);
  }

  #BioHub-{{ section.id }} .hub-hero p {
    color: var(--apple-text-secondary);
    max-width: 48rem;
    margin: 0 auto;
    font-size: 1.7rem;
    line-height: 1.53;
  }

  /* Search */
  #BioHub-{{ section.id }} .hub-search {
    max-width: 36rem;
    margin: 0 auto 3.2rem;
    position: relative;
  }

  #BioHub-{{ section.id }} .hub-search-input {
    width: 100%;
    padding: 1.2rem 1.6rem 1.2rem 4rem;
    border: none;
    border-radius: 2rem;
    font-family: var(--apple-font);
    font-size: 1.7rem;
    background: var(--apple-bg-gray);
    color: var(--apple-text);
    outline: none;
    transition: box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #BioHub-{{ section.id }} .hub-search-input:focus {
    box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.3);
  }

  #BioHub-{{ section.id }} .hub-search-input::placeholder {
    color: var(--apple-text-tertiary);
  }

  #BioHub-{{ section.id }} .hub-search-icon {
    position: absolute;
    left: 1.4rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--apple-text-tertiary);
  }

  #BioHub-{{ section.id }} .hub-search-icon svg {
    width: 2rem;
    height: 2rem;
    display: block;
  }

  /* Category grid */
  #BioHub-{{ section.id }} .hub-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 750px) {
    #BioHub-{{ section.id }} .hub-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    #BioHub-{{ section.id }} .hub-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(22rem, 100%), 1fr));
    }
  }

  #BioHub-{{ section.id }} .hub-cat {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 2.4rem;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(1.6rem);
    animation: hubFadeIn-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #BioHub-{{ section.id }} .hub-cat:nth-child(1) { animation-delay: 0s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(2) { animation-delay: 0.12s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(3) { animation-delay: 0.24s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(4) { animation-delay: 0.36s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(5) { animation-delay: 0.48s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(6) { animation-delay: 0.60s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(7) { animation-delay: 0.72s; }
  #BioHub-{{ section.id }} .hub-cat:nth-child(8) { animation-delay: 0.84s; }

  @keyframes hubFadeIn-{{ section.id }} {
    to { opacity: 1; transform: translateY(0); }
  }

  #BioHub-{{ section.id }} .hub-cat:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #BioHub-{{ section.id }} .hub-cat[hidden] { display: none; }

  #BioHub-{{ section.id }} .hub-cat-icon {
    width: 4.8rem;
    height: 4.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.02);
    border-radius: 1.4rem;
    margin-bottom: 1.2rem;
  }

  #BioHub-{{ section.id }} .hub-cat-icon svg {
    width: 2.4rem;
    height: 2.4rem;
    color: var(--apple-text);
  }

  #BioHub-{{ section.id }} .hub-cat-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
    color: var(--apple-text);
  }

  #BioHub-{{ section.id }} .hub-cat-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #BioHub-{{ section.id }} .hub-cat-links li {
    padding: 0.4rem 0;
  }

  #BioHub-{{ section.id }} .hub-cat-links a {
    color: var(--apple-link);
    text-decoration: none;
    font-size: 1.5rem;
    line-height: 1.53;
    transition: opacity 0.2s;
  }

  #BioHub-{{ section.id }} .hub-cat-links a:hover {
    text-decoration: underline;
  }

  #BioHub-{{ section.id }} .hub-cat-links span {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
  }

  #BioHub-{{ section.id }} .hub-no-results {
    text-align: center;
    color: var(--apple-text-secondary);
    font-size: 1.7rem;
    padding: 3rem 0;
    display: none;
  }

  /* Mobile */
  @media (max-width: 749px) {
    #BioHub-{{ section.id }} .hub-hero { padding: 3rem 0 2rem; }
    #BioHub-{{ section.id }} .hub-cat { padding: 2rem; }
  }
{%- endstyle -%}

<section
  id="BioHub-{{ section.id }}"
  class="page-width section-{{ section.id }}-padding"
  style="padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;"
>
  <div class="hub-container">

    <header class="hub-hero">
      <span class="hub-label">Wissen</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.description }}</p>
    </header>

    <div class="hub-search">
      <span class="hub-search-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </span>
      <input
        type="text"
        class="hub-search-input"
        placeholder="Biomarker suchen (z.B. Vitamin D, CRP, TSH...)"
        id="jv-bio-search-{{ section.id }}"
      >
    </div>

    <div class="hub-grid" id="jv-bio-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <div
            class="hub-cat"
            data-search="{{ block.settings.title | downcase }} {{ block.settings.markers | downcase }}"
            {{ block.shopify_attributes }}
          >
            <div class="hub-cat-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
            <h2 class="hub-cat-title">{{ block.settings.title }}</h2>
            {%- if block.settings.markers != blank -%}
              <ul class="hub-cat-links">
                {%- assign items = block.settings.markers | split: '|' -%}
                {%- for item in items -%}
                  {%- assign parts = item | split: ':' -%}
                  <li>
                    {%- if parts.size > 1 -%}
                      <a href="{{ parts[1] | strip }}">{{ parts[0] | strip }}</a>
                    {%- else -%}
                      <span>{{ parts[0] | strip }}</span>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <p class="hub-no-results" id="jv-bio-noresults-{{ section.id }}">Kein Biomarker gefunden. Versuch einen anderen Suchbegriff.</p>

  </div>
</section>

<style media="screen and (min-width: 750px)">
  #BioHub-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var input = document.getElementById('jv-bio-search-' + sectionId);
    var grid = document.getElementById('jv-bio-grid-' + sectionId);
    var noResults = document.getElementById('jv-bio-noresults-' + sectionId);
    if (!input || !grid) return;
    var cats = grid.querySelectorAll('.hub-cat');

    input.addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      var visible = 0;
      cats.forEach(function(cat) {
        var data = cat.getAttribute('data-search') || '';
        var show = !q || data.indexOf(q) !== -1;
        cat.hidden = !show;
        if (show) visible++;
      });
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Biomarker Hub",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Biomarker-Lexikon: Deine Laborwerte verstehen" },
    { "type": "textarea", "id": "description", "label": "Beschreibung", "default": "Alle wichtigen Biomarker und Laborwerte erklaert: Referenzwerte, Bedeutung bei Abweichung und was du tun kannst." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "\ud83e\ude78" },
        { "type": "text", "id": "title", "label": "Kategorie-Name" },
        { "type": "textarea", "id": "markers", "label": "Biomarker (Name:URL | getrennt)", "info": "Format: Name:/pages/slug | Name2:/pages/slug2" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis: Biomarker Hub" }]
}
{% endschema %}