{%- comment -%}
  Juvantis Section: Legal Pages
  Zweck: Wiederverwendbare Section fuer Impressum, Datenschutz, AGB, Widerruf
  Design: Apple-inspired Design System
{%- endcomment -%}

{%- comment -%} Liquid-Guard (R-012) -- nur auf Legal-Seiten rendern {%- endcomment -%}
{%- assign legal_pages = 'impressum,datenschutz,agb,widerruf' | split: ',' -%}
{%- assign is_legal = false -%}
{%- for p in legal_pages -%}
  {%- if template.suffix == p -%}
    {%- assign is_legal = true -%}
  {%- endif -%}
{%- endfor -%}

{%- if is_legal -%}

{%- style -%}
  #LegalPage-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #LegalPage-{{ section.id }} .legal__container {
    max-width: 52rem;
    margin: 0 auto;
    padding: 0 2.4rem;
  }

  /* Header */
  #LegalPage-{{ section.id }} .legal__header {
    text-align: center;
    padding: 6rem 0 3rem;
    margin-bottom: 3.2rem;
    opacity: 0;
    transform: translateY(2rem);
    animation: legalFadeIn 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #LegalPage-{{ section.id }} .legal__badge {
    display: inline-block;
    background: var(--apple-bg-gray);
    border-radius: 98rem;
    padding: 0.5rem 1.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-secondary);
    margin-bottom: 2rem;
  }

  #LegalPage-{{ section.id }} .legal__title {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--apple-text);
    margin: 0 0 1rem;
  }

  #LegalPage-{{ section.id }} .legal__subtitle {
    font-size: 1.7rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
    margin: 0;
  }

  #LegalPage-{{ section.id }} .legal__date {
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-tertiary);
    margin-top: 1.2rem;
  }

  /* Content body */
  #LegalPage-{{ section.id }} .legal__body {
    line-height: 1.53;
    font-size: 1.7rem;
    opacity: 0;
    transform: translateY(2rem);
    animation: legalFadeIn 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.12s forwards;
  }

  #LegalPage-{{ section.id }} .legal__body h2 {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--apple-text);
    margin: 3.2rem 0 1.2rem;
    padding-top: 2.4rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  #LegalPage-{{ section.id }} .legal__body h2:first-child {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  #LegalPage-{{ section.id }} .legal__body h3 {
    font-family: var(--apple-font);
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--apple-text);
    margin: 2.4rem 0 0.8rem;
  }

  #LegalPage-{{ section.id }} .legal__body p {
    margin: 0 0 1.2rem;
    color: var(--apple-text-secondary);
    font-size: 1.5rem;
    line-height: 1.53;
  }

  #LegalPage-{{ section.id }} .legal__body ul,
  #LegalPage-{{ section.id }} .legal__body ol {
    margin: 0 0 1.2rem;
    padding-left: 2rem;
    color: var(--apple-text-secondary);
    font-size: 1.5rem;
    line-height: 1.53;
  }

  #LegalPage-{{ section.id }} .legal__body li {
    margin-bottom: 0.6rem;
  }

  #LegalPage-{{ section.id }} .legal__body a {
    color: var(--apple-link);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  #LegalPage-{{ section.id }} .legal__body a:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  /* Contact card */
  #LegalPage-{{ section.id }} .legal__contact {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 2.4rem 2.8rem;
    margin: 2rem 0;
  }

  #LegalPage-{{ section.id }} .legal__contact p {
    margin: 0 0 0.4rem;
    color: var(--apple-text);
    font-size: 1.5rem;
    line-height: 1.53;
  }

  #LegalPage-{{ section.id }} .legal__contact a {
    color: var(--apple-link);
  }

  /* Info box */
  #LegalPage-{{ section.id }} .legal__info {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 2rem 2.4rem;
    margin: 2rem 0;
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
  }

  #LegalPage-{{ section.id }} .legal__info strong {
    color: var(--apple-text);
  }

  /* Table styles */
  #LegalPage-{{ section.id }} .legal__body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0 2rem;
    font-size: 1.5rem;
    border-radius: 2rem;
    overflow: hidden;
  }

  #LegalPage-{{ section.id }} .legal__body th,
  #LegalPage-{{ section.id }} .legal__body td {
    text-align: left;
    padding: 1rem 1.6rem;
  }

  #LegalPage-{{ section.id }} .legal__body th {
    font-weight: 600;
    color: #fff;
    background: var(--apple-text);
  }

  #LegalPage-{{ section.id }} .legal__body td {
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--apple-text-secondary);
  }

  #LegalPage-{{ section.id }} .legal__body tr:hover td {
    background: rgba(0,0,0,0.02);
  }

  /* Footer / back link */
  #LegalPage-{{ section.id }} .legal__footer {
    text-align: center;
    padding: 3.2rem 0 1.2rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    margin-top: 4rem;
  }

  #LegalPage-{{ section.id }} .legal__back {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--apple-link);
    text-decoration: none;
    transition: gap 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
  }

  #LegalPage-{{ section.id }} .legal__back:hover {
    gap: 1rem;
    opacity: 0.8;
  }

  /* Responsive */
  @media (min-width: 750px) {
    #LegalPage-{{ section.id }} .legal__container {
      padding: 0 2.4rem;
    }
  }

  @media (max-width: 749px) {
    #LegalPage-{{ section.id }} .legal__header {
      padding: 4rem 0 2rem;
    }
  }

  @keyframes legalFadeIn {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }
{%- endstyle -%}

<section
  id="LegalPage-{{ section.id }}"
  class="section-{{ section.id }}-padding"
  style="
    padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
  "
>
  <div class="page-width">
    <div class="legal__container">

      <!-- Header -->
      <header class="legal__header">
        <span class="legal__badge">{{ section.settings.badge_text }}</span>
        <h1 class="legal__title">{{ section.settings.heading }}</h1>
        {%- if section.settings.subtitle != blank -%}
          <p class="legal__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.show_date -%}
          <p class="legal__date">Stand: {{ section.settings.last_updated }}</p>
        {%- endif -%}
      </header>

      <!-- Content blocks -->
      <div class="legal__body">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'heading' -%}
              <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

            {%- when 'subheading' -%}
              <h3 {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>

            {%- when 'text' -%}
              <div {{ block.shopify_attributes }}>{{ block.settings.content }}</div>

            {%- when 'contact_card' -%}
              <div class="legal__contact" {{ block.shopify_attributes }}>
                {{ block.settings.content }}
              </div>

            {%- when 'info_box' -%}
              <div class="legal__info" {{ block.shopify_attributes }}>
                {{ block.settings.content }}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>

      <!-- Footer -->
      <footer class="legal__footer">
        <a href="/" class="legal__back">&larr; Zurueck zur Startseite</a>
      </footer>

    </div>
  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: Legal",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge-Text",
      "default": "Rechtliches"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "\u00dcberschrift",
      "default": "Impressum"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Untertitel"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Stand-Datum anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "last_updated",
      "label": "Stand (Datum)",
      "default": "April 2026"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "label": "Abstand oben"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Abstand unten"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "\u00dcberschrift (H2)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Unter\u00fcberschrift (H3)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "text",
      "name": "Textabschnitt",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Inhalt"
        }
      ]
    },
    {
      "type": "contact_card",
      "name": "Kontakt-Box",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Inhalt"
        }
      ]
    },
    {
      "type": "info_box",
      "name": "Info-Hinweis",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Inhalt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis: Legal"
    }
  ]
}
{% endschema %}
