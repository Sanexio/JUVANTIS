{%- comment -%}
  Juvantis Section: Digital Health Twin (Full Page)
  Zweck: Ausfuehrliche Showcase-Seite fuer das Alleinstellungsmerkmal
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- if template.suffix == 'digital-health-twin' -%}

{%- style -%}
  .jv-dht {
    --jv-teal: #028090;
    --jv-teal-light: #00A896;
    --jv-teal-bright: #02C39A;
    --jv-gradient: linear-gradient(135deg, #4ea1d9, #73c25e);
    --jv-text: #1a1a1a;
    --jv-text-sec: #555;
    --jv-bg: #ffffff;
    --jv-bg-subtle: #f8fafa;
    --jv-bg-dark: #0a1a1e;
    --jv-border: #e8ecec;
    --jv-radius: 1.4rem;
    font-family: var(--font-body-family, 'Anonymous Pro', monospace);
    -webkit-font-smoothing: antialiased;
    color: var(--jv-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  .jv-dht__container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero — dark theme */
  .jv-dht__hero {
    background: var(--jv-bg-dark);
    color: #fff;
    border-radius: var(--jv-radius);
    padding: 4rem 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
    overflow: hidden;
  }

  .jv-dht__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(2,128,144,0.15) 0%, transparent 70%),
                radial-gradient(ellipse at 70% 50%, rgba(2,195,154,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .jv-dht__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2rem;
    padding: 0.35rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--jv-teal-bright);
    margin-bottom: 1.5rem;
    position: relative;
  }

  .jv-dht__hero h1 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin: 0 0 1.2rem;
    position: relative;
  }

  .jv-dht__hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    opacity: 0.8;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.65;
    position: relative;
  }

  /* Explainer */
  .jv-dht__explainer {
    text-align: center;
    margin-bottom: 3rem;
  }

  .jv-dht__explainer h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .jv-dht__explainer p {
    color: var(--jv-text-sec);
    max-width: 40rem;
    margin: 0 auto;
    line-height: 1.7;
    font-size: 1rem;
  }

  /* Feature Bento */
  .jv-dht__features-title {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-align: center;
    margin: 0 0 2rem;
  }

  .jv-dht__bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 750px) {
    .jv-dht__bento {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .jv-dht__bento {
      grid-template-columns: repeat(3, 1fr);
    }
    .jv-dht__bento .jv-dht__feat:nth-child(1) { grid-column: 1 / 3; }
  }

  .jv-dht__feat {
    background: var(--jv-bg);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .jv-dht__feat:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .jv-dht__feat-icon {
    font-size: 2.2rem;
    margin-bottom: 0.8rem;
    display: block;
  }

  .jv-dht__feat-title {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .jv-dht__feat-text {
    font-size: 0.9rem;
    color: var(--jv-text-sec);
    line-height: 1.6;
    margin: 0;
  }

  /* How it works */
  .jv-dht__how {
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 2.5rem;
    margin-bottom: 3rem;
  }

  .jv-dht__how h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 2rem;
  }

  .jv-dht__how-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 750px) {
    .jv-dht__how-steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .jv-dht__how-step {
    text-align: center;
  }

  .jv-dht__how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--jv-gradient);
    color: #fff;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .jv-dht__how-title {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 0.3rem;
  }

  .jv-dht__how-text {
    font-size: 0.88rem;
    color: var(--jv-text-sec);
    margin: 0;
    line-height: 1.55;
  }

  /* Gamification */
  .jv-dht__gamification {
    background: var(--jv-gradient);
    color: #fff;
    border-radius: var(--jv-radius);
    padding: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .jv-dht__gamification h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 0.8rem;
  }

  .jv-dht__gamification p {
    opacity: 0.9;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* Privacy */
  .jv-dht__privacy {
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 2rem 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .jv-dht__privacy h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .jv-dht__privacy p {
    color: var(--jv-text-sec);
    margin: 0;
    line-height: 1.6;
  }

  /* CTA */
  .jv-dht__cta {
    text-align: center;
    padding: 1rem 0 0;
  }

  .jv-dht__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--jv-gradient);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.9rem 2rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .jv-dht__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(78, 161, 217, 0.3);
    color: #fff;
  }

  @supports (animation-timeline: view()) {
    .jv-dht__feat,
    .jv-dht__how,
    .jv-dht__gamification,
    .jv-dht__privacy {
      animation: jvDhtFadeUp 0.6s ease both;
      animation-timeline: view();
      animation-range: entry 10% entry 40%;
    }
  }

  @keyframes jvDhtFadeUp {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }
{%- endstyle -%}

<section
  class="jv-dht"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="jv-dht__container">

    <div class="jv-dht__hero">
      <span class="jv-dht__badge">Digital Health Twin</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="jv-dht__hero-sub">{{ section.settings.hero_sub }}</p>
    </div>

    <div class="jv-dht__explainer">
      <h2>{{ section.settings.explainer_heading }}</h2>
      <p>{{ section.settings.explainer_text }}</p>
    </div>

    <h2 class="jv-dht__features-title">{{ section.settings.features_heading }}</h2>
    <div class="jv-dht__bento">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="jv-dht__feat" {{ block.shopify_attributes }}>
            <span class="jv-dht__feat-icon">{{ block.settings.icon }}</span>
            <h3 class="jv-dht__feat-title">{{ block.settings.title }}</h3>
            <p class="jv-dht__feat-text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="jv-dht__how">
      <h2>{{ section.settings.how_heading }}</h2>
      <div class="jv-dht__how-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'how_step' -%}
            <div class="jv-dht__how-step" {{ block.shopify_attributes }}>
              <span class="jv-dht__how-num">{{ block.settings.number }}</span>
              <h3 class="jv-dht__how-title">{{ block.settings.title }}</h3>
              <p class="jv-dht__how-text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="jv-dht__gamification">
      <h2>{{ section.settings.game_heading }}</h2>
      <p>{{ section.settings.game_text }}</p>
    </div>

    <div class="jv-dht__privacy">
      <h2>{{ section.settings.privacy_heading }}</h2>
      <p>{{ section.settings.privacy_text }}</p>
    </div>

    <div class="jv-dht__cta">
      <a href="{{ section.settings.cta_link }}" class="jv-dht__cta-btn">
        {{ section.settings.cta_label }} &rarr;
      </a>
    </div>

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: DHT Page",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Hero-Ueberschrift", "default": "Dein Koerper. Digital. Verstanden." },
    { "type": "textarea", "id": "hero_sub", "label": "Hero-Unterzeile", "default": "Der weltweit erste Digital Health Twin: Ein 3D-Avatar, der deine echten Gesundheitsdaten visualisiert." },
    { "type": "text", "id": "explainer_heading", "label": "Erklaerung-Ueberschrift", "default": "Was ist der Digital Health Twin?" },
    { "type": "textarea", "id": "explainer_text", "label": "Erklaerung-Text", "default": "Stell dir vor, du haettest einen digitalen Zwilling deines Koerpers. Einen 3D-Avatar, der in Echtzeit zeigt, wie es um deine Gesundheit steht. Nicht in abstrakten Zahlen, sondern visuell: Organe, Haut, Vitalwerte — alles auf einen Blick. Das ist dein Digital Health Twin." },
    { "type": "text", "id": "features_heading", "label": "Features-Ueberschrift", "default": "Was dein DHT kann" },
    { "type": "text", "id": "how_heading", "label": "So-gehts-Ueberschrift", "default": "So funktioniert es" },
    { "type": "text", "id": "game_heading", "label": "Gamification-Ueberschrift", "default": "Gesundheit wird zum Spiel" },
    { "type": "textarea", "id": "game_text", "label": "Gamification-Text", "default": "Quests, Challenges und ein Level-System motivieren dich, dranzubleiben. Verbessere deine Werte, steige im Level auf und feiere deine Fortschritte -- Gesundheit darf Spass machen." },
    { "type": "text", "id": "privacy_heading", "label": "Datenschutz-Ueberschrift", "default": "Deine Daten gehoeren dir. 100% DSGVO-konform." },
    { "type": "textarea", "id": "privacy_text", "label": "Datenschutz-Text", "default": "Alle Daten werden in Deutschland gespeichert und verarbeitet. Du entscheidest, wer Zugriff hat. Keine Weitergabe an Dritte, keine versteckten Datennutzungen. Punkt." },
    { "type": "text", "id": "cta_label", "label": "CTA-Text", "default": "Starte deinen Digital Health Twin -- kostenlos" },
    { "type": "url", "id": "cta_link", "label": "CTA-Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "🫀" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "how_step",
      "name": "So-gehts Schritt",
      "settings": [
        { "type": "text", "id": "number", "label": "Nummer", "default": "1" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "Juvantis: DHT Page" }]
}
{% endschema %}
