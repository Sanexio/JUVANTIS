{%- comment -%}
  Juvantis Section: Bluttests / Bloody Check-ups
  Zweck: Produktkatalog der Labor-Check-ups
  Design: Apple-inspired design system
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- style -%}
  #Bluttests-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #Bluttests-{{ section.id }} .blood-container {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  #Bluttests-{{ section.id }} .blood-hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  #Bluttests-{{ section.id }} .blood-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.2rem;
  }

  #Bluttests-{{ section.id }} .blood-hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.6rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-hero-text {
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.53;
  }

  /* ── Section Title ── */
  #Bluttests-{{ section.id }} .blood-section-title {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  /* ── Bento Grid ── */
  #Bluttests-{{ section.id }} .blood-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 750px) {
    #Bluttests-{{ section.id }} .blood-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.4rem;
    }
    #Bluttests-{{ section.id }} .blood-bento .blood-card:first-child {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 990px) {
    #Bluttests-{{ section.id }} .blood-bento {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.4rem;
    }
    #Bluttests-{{ section.id }} .blood-bento .blood-card:first-child {
      grid-column: 1 / 3;
    }
  }

  #Bluttests-{{ section.id }} .blood-card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 2.4rem;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #Bluttests-{{ section.id }} .blood-card:nth-child(2) { animation-delay: 0.12s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(3) { animation-delay: 0.24s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(4) { animation-delay: 0.36s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(5) { animation-delay: 0.48s; }

  #Bluttests-{{ section.id }} .blood-card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #Bluttests-{{ section.id }} .blood-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    margin-bottom: 1.2rem;
    color: var(--apple-link);
  }

  #Bluttests-{{ section.id }} .blood-card-icon svg {
    width: 3.2rem;
    height: 3.2rem;
  }

  #Bluttests-{{ section.id }} .blood-card-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-card-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0 0 1.2rem;
  }

  #Bluttests-{{ section.id }} .blood-card-markers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  #Bluttests-{{ section.id }} .blood-marker-pill {
    background: var(--apple-bg-white);
    border: none;
    border-radius: 2rem;
    padding: 0.3rem 1rem;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--apple-text-secondary);
  }

  #Bluttests-{{ section.id }} .blood-card--featured {
    background: var(--apple-bg-gray);
  }

  #Bluttests-{{ section.id }} .blood-card--featured .blood-card-title {
    color: var(--apple-link);
  }

  /* ── Process Steps ── */
  #Bluttests-{{ section.id }} .blood-process {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 3.6rem 3rem;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.2s forwards;
  }

  #Bluttests-{{ section.id }} .blood-process h2 {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 750px) {
    #Bluttests-{{ section.id }} .blood-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 2.4rem;
    }
  }

  #Bluttests-{{ section.id }} .blood-step {
    text-align: center;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #Bluttests-{{ section.id }} .blood-step:nth-child(1) { animation-delay: 0.3s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(2) { animation-delay: 0.42s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(3) { animation-delay: 0.54s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(4) { animation-delay: 0.66s; }

  #Bluttests-{{ section.id }} .blood-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  #Bluttests-{{ section.id }} .blood-step-title {
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-step-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0;
  }

  /* ── Price Teaser ── */
  #Bluttests-{{ section.id }} .blood-price-teaser {
    text-align: center;
    margin-bottom: 2rem;
  }

  #Bluttests-{{ section.id }} .blood-price-tag {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--apple-link);
  }

  #Bluttests-{{ section.id }} .blood-price-note {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    margin-top: 0.4rem;
    line-height: 1.53;
  }

  /* ── CTA ── */
  #Bluttests-{{ section.id }} .blood-cta {
    text-align: center;
    padding: 1rem 0 0;
  }

  #Bluttests-{{ section.id }} .blood-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.8rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #Bluttests-{{ section.id }} .blood-cta-btn:hover {
    background: #0077ed;
    transform: scale(1.04);
    box-shadow: 0 0.8rem 2.4rem rgba(0,113,227,0.3);
    color: #fff;
  }

  /* ── Animation ── */
  @keyframes bloodFadeUp-{{ section.id }} {
    from { opacity: 0; transform: translateY(1.6rem); }
    to { opacity: 1; transform: none; }
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 749px) {
    #Bluttests-{{ section.id }} .blood-container {
      padding: 0 1.5rem;
    }
    #Bluttests-{{ section.id }} .blood-process {
      padding: 2.4rem 2rem;
    }
    #Bluttests-{{ section.id }} .blood-card {
      padding: 2rem;
    }
  }
{%- endstyle -%}

<section
  id="Bluttests-{{ section.id }}"
  style="
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  "
>
  <div class="page-width blood-container">

    <!-- Hero -->
    <header class="blood-hero">
      <span class="blood-label">Labordiagnostik</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="blood-hero-text">{{ section.settings.intro }}</p>
    </header>

    <!-- Check-up Bento Grid -->
    <h2 class="blood-section-title">{{ section.settings.categories_heading }}</h2>
    <div class="blood-bento">
      {%- for block in section.blocks -%}
        {%- if block.type == 'checkup' -%}
          <div class="blood-card{% if block.settings.featured %} blood-card--featured{% endif %}" {{ block.shopify_attributes }}>
            <span class="blood-card-icon">
              {%- case block.settings.title -%}
                {%- when 'Komplett-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M232,64H208V48a8,8,0,0,0-8-8H56a8,8,0,0,0-8,8V64H24A16,16,0,0,0,8,80V96a40,40,0,0,0,40,40h3.65A80.13,80.13,0,0,0,120,191.61V216H96a8,8,0,0,0,0,16h64a8,8,0,0,0,0-16H136V191.58c31.94-3.23,58.44-25.64,68.08-55.58H208a40,40,0,0,0,40-40V80A16,16,0,0,0,232,64ZM48,120A24,24,0,0,1,24,96V80H48v32q0,4,.39,8ZM232,96a24,24,0,0,1-24,24h-.5a81.81,81.81,0,0,0,.5-8.9V80h24Z"/></svg>
                {%- when 'Basis-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M174,47.75a254.19,254.19,0,0,0-41.45-38.3,8,8,0,0,0-9.18,0A254.19,254.19,0,0,0,82,47.75C54.51,79.32,40,112.6,40,144a88,88,0,0,0,176,0C216,112.6,201.49,79.32,174,47.75Zm9.85,105.59a57.6,57.6,0,0,1-46.56,46.55A8.75,8.75,0,0,1,136,200a8,8,0,0,1-1.32-15.89c16.57-2.79,30.63-16.85,33.44-33.45a8,8,0,0,1,15.78,2.68Z"/></svg>
                {%- when 'Herz-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M240,102c0,70-103.79,126.66-108.21,129a8,8,0,0,1-7.58,0C119.79,228.66,16,172,16,102A62.07,62.07,0,0,1,78,40c20.65,0,38.73,8.88,50,23.89C139.27,48.88,157.35,40,178,40A62.07,62.07,0,0,1,240,102Z"/></svg>
                {%- when 'Hormon-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M213.85,125.46l-112,120a8,8,0,0,1-13.69-7l14.66-73.33L45.19,143.49a8,8,0,0,1-3-13l112-120a8,8,0,0,1,13.69,7L153.18,90.9l57.63,21.61a8,8,0,0,1,3,12.95Z"/></svg>
                {%- when 'Sport-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M120,56a32,32,0,1,1,32,32A32,32,0,0,1,120,56Zm103.28,74.08a8,8,0,0,0-10.6-4c-.25.12-26.71,10.72-72.18-20.19-52.29-35.54-88-7.77-89.51-6.57a8,8,0,1,0,10,12.48c.26-.21,25.12-19.5,64.07,3.27-4.25,13.35-12.76,31.82-25.25,47-18.56,22.48-41.11,32.56-67,30A8,8,0,0,0,31.2,208a92.29,92.29,0,0,0,9.34.47c27.38,0,52-12.38,71.63-36.18.57-.69,1.14-1.4,1.69-2.1C133.31,175.29,168,190.3,168,232a8,8,0,0,0,16,0c0-24.65-10.08-45.35-29.15-59.86a104.29,104.29,0,0,0-31.31-15.81A169.31,169.31,0,0,0,139,124c26.14,16.09,46.84,20,60.69,20,12.18,0,19.06-3,19.67-3.28A8,8,0,0,0,223.28,130.08Z"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M221.69,199.77,160,96.92V40h8a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8V96.92L34.31,199.77A16,16,0,0,0,48,224H208a16,16,0,0,0,13.72-24.23Zm-90.08-42.91c-15.91-8.05-31.05-12.32-45.22-12.81l24.47-40.8A7.93,7.93,0,0,0,112,99.14V40h32V99.14a7.93,7.93,0,0,0,1.14,4.11L183.36,167C171.4,169.34,154.29,168.34,131.61,156.86Z"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="blood-card-title">{{ block.settings.title }}</h3>
            <p class="blood-card-text">{{ block.settings.description }}</p>
            {%- if block.settings.markers != blank -%}
              <div class="blood-card-markers">
                {%- assign markers = block.settings.markers | split: ',' -%}
                {%- for m in markers -%}
                  <span class="blood-marker-pill">{{ m | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Process -->
    <div class="blood-process">
      <h2>{{ section.settings.process_heading }}</h2>
      <div class="blood-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="blood-step" {{ block.shopify_attributes }}>
              <span class="blood-step-num">{{ block.settings.number }}</span>
              <h3 class="blood-step-title">{{ block.settings.title }}</h3>
              <p class="blood-step-text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Price + CTA -->
    <div class="blood-price-teaser">
      <div class="blood-price-tag">{{ section.settings.price_text }}</div>
      <p class="blood-price-note">{{ section.settings.price_note }}</p>
    </div>

    <div class="blood-cta">
      <a href="{{ section.settings.cta_link }}" class="blood-cta-btn">
        {{ section.settings.cta_label }} &rarr;
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Juvantis: Bluttests",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Dein Blut weiß mehr, als du denkst."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitung",
      "default": "Ein Bloody Check bei Juvantis ist mehr als ein Blutbild beim Hausarzt. Wir analysieren bis zu 80+ Biomarker und visualisieren deine Ergebnisse in deinem persönlichen Digital Health Twin — verständlich, motivierend und medizinisch fundiert."
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "Kategorien-Überschrift",
      "default": "Unsere Check-up-Kategorien"
    },
    {
      "type": "text",
      "id": "process_heading",
      "label": "Ablauf-Überschrift",
      "default": "So funktioniert dein Bloody Check"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Preis-Teaser",
      "default": "Ab 45 EUR pro Check-up"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Preis-Hinweis",
      "default": "Einzelne Checks oder als Teil deines Komplett-Pakets"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-Button Text",
      "default": "Jetzt Bloody Check buchen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA-Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "label": "Abstand oben"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Abstand unten"
    }
  ],
  "blocks": [
    {
      "type": "checkup",
      "name": "Check-up Kategorie",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "🩸"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung"
        },
        {
          "type": "text",
          "id": "markers",
          "label": "Biomarker (kommagetrennt)"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Hervorgehoben",
          "default": false
        }
      ]
    },
    {
      "type": "step",
      "name": "Ablauf-Schritt",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Schritt-Nummer",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis: Bluttests"
    }
  ]
}
{% endschema %}