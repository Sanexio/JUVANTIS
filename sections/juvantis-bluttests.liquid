{%- comment -%}
  Juvantis Section: Bluttests / Bloody Check-ups
  Zweck: Produktkatalog der Labor-Check-ups
  Design: Apple-inspired design system
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- style -%}
  #Bluttests-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #Bluttests-{{ section.id }} .blood-container {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  #Bluttests-{{ section.id }} .blood-hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  #Bluttests-{{ section.id }} .blood-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.2rem;
  }

  #Bluttests-{{ section.id }} .blood-hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.6rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-hero-text {
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
    max-width: 52rem;
    margin: 0 auto;
    line-height: 1.53;
  }

  /* ── Section Title ── */
  #Bluttests-{{ section.id }} .blood-section-title {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  /* ── Bento Grid ── */
  #Bluttests-{{ section.id }} .blood-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 750px) {
    #Bluttests-{{ section.id }} .blood-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.4rem;
    }
    #Bluttests-{{ section.id }} .blood-bento .blood-card:first-child {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 990px) {
    #Bluttests-{{ section.id }} .blood-bento {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.4rem;
    }
    #Bluttests-{{ section.id }} .blood-bento .blood-card:first-child {
      grid-column: 1 / 3;
    }
  }

  #Bluttests-{{ section.id }} .blood-card {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 2.4rem;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #Bluttests-{{ section.id }} .blood-card:nth-child(2) { animation-delay: 0.12s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(3) { animation-delay: 0.24s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(4) { animation-delay: 0.36s; }
  #Bluttests-{{ section.id }} .blood-card:nth-child(5) { animation-delay: 0.48s; }

  #Bluttests-{{ section.id }} .blood-card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #Bluttests-{{ section.id }} .blood-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    margin-bottom: 1.2rem;
    color: var(--apple-link);
  }

  #Bluttests-{{ section.id }} .blood-card-icon svg {
    width: 3.2rem;
    height: 3.2rem;
  }

  #Bluttests-{{ section.id }} .blood-card-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-card-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0 0 1.2rem;
  }

  #Bluttests-{{ section.id }} .blood-card-markers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  #Bluttests-{{ section.id }} .blood-marker-pill {
    background: var(--apple-bg-white);
    border: none;
    border-radius: 2rem;
    padding: 0.3rem 1rem;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--apple-text-secondary);
  }

  #Bluttests-{{ section.id }} .blood-card--featured {
    background: var(--apple-bg-gray);
  }

  #Bluttests-{{ section.id }} .blood-card--featured .blood-card-title {
    color: var(--apple-link);
  }

  /* ── Process Steps ── */
  #Bluttests-{{ section.id }} .blood-process {
    background: var(--apple-bg-gray);
    border: none;
    border-radius: 2rem;
    padding: 3.6rem 3rem;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.2s forwards;
  }

  #Bluttests-{{ section.id }} .blood-process h2 {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 2.4rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 750px) {
    #Bluttests-{{ section.id }} .blood-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 2.4rem;
    }
  }

  #Bluttests-{{ section.id }} .blood-step {
    text-align: center;
    opacity: 0;
    transform: translateY(1.6rem);
    animation: bloodFadeUp-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #Bluttests-{{ section.id }} .blood-step:nth-child(1) { animation-delay: 0.3s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(2) { animation-delay: 0.42s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(3) { animation-delay: 0.54s; }
  #Bluttests-{{ section.id }} .blood-step:nth-child(4) { animation-delay: 0.66s; }

  #Bluttests-{{ section.id }} .blood-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  #Bluttests-{{ section.id }} .blood-step-title {
    font-family: var(--apple-font);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
    color: var(--apple-text);
  }

  #Bluttests-{{ section.id }} .blood-step-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0;
  }

  /* ── Price Teaser ── */
  #Bluttests-{{ section.id }} .blood-price-teaser {
    text-align: center;
    margin-bottom: 2rem;
  }

  #Bluttests-{{ section.id }} .blood-price-tag {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--apple-link);
  }

  #Bluttests-{{ section.id }} .blood-price-note {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    margin-top: 0.4rem;
    line-height: 1.53;
  }

  /* ── CTA ── */
  #Bluttests-{{ section.id }} .blood-cta {
    text-align: center;
    padding: 1rem 0 0;
  }

  #Bluttests-{{ section.id }} .blood-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--apple-link);
    color: #fff;
    font-family: var(--apple-font);
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.8rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #Bluttests-{{ section.id }} .blood-cta-btn:hover {
    background: #0077ed;
    transform: scale(1.04);
    box-shadow: 0 0.8rem 2.4rem rgba(0,113,227,0.3);
    color: #fff;
  }

  /* ── Animation ── */
  @keyframes bloodFadeUp-{{ section.id }} {
    from { opacity: 0; transform: translateY(1.6rem); }
    to { opacity: 1; transform: none; }
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 749px) {
    #Bluttests-{{ section.id }} .blood-container {
      padding: 0 1.5rem;
    }
    #Bluttests-{{ section.id }} .blood-process {
      padding: 2.4rem 2rem;
    }
    #Bluttests-{{ section.id }} .blood-card {
      padding: 2rem;
    }
  }
{%- endstyle -%}

<section
  id="Bluttests-{{ section.id }}"
  style="
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  "
>
  <div class="page-width blood-container">

    <!-- Hero -->
    <header class="blood-hero">
      <span class="blood-label">Labordiagnostik</span>
      <h1>{{ section.settings.heading }}</h1>
      <p class="blood-hero-text">{{ section.settings.intro }}</p>
    </header>

    <!-- Check-up Bento Grid -->
    <h2 class="blood-section-title">{{ section.settings.categories_heading }}</h2>
    <div class="blood-bento">
      {%- for block in section.blocks -%}
        {%- if block.type == 'checkup' -%}
          <div class="blood-card{% if block.settings.featured %} blood-card--featured{% endif %}" {{ block.shopify_attributes }}>
            <span class="blood-card-icon">
              {%- case block.settings.title -%}
                {%- when 'Komplett-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-4.5A3.375 3.375 0 0 0 13.125 10.875H10.875A3.375 3.375 0 0 0 7.5 14.25v4.5m6-12V2.25M12 2.25a2.25 2.25 0 0 0-2.25 2.25v1.125c0 .621.504 1.125 1.125 1.125h2.25c.621 0 1.125-.504 1.125-1.125V4.5A2.25 2.25 0 0 0 12 2.25Z"/></svg>
                {%- when 'Basis-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a8.25 8.25 0 0 0 5.834-14.084L12 1.5 6.166 6.916A8.25 8.25 0 0 0 12 21Z"/></svg>
                {%- when 'Herz-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
                {%- when 'Hormon-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
                {%- when 'Sport-Check' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.75 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM5.07 17.07a8.354 8.354 0 0 0 3.063 2.481A8.354 8.354 0 0 0 12.75 21a8.355 8.355 0 0 0 4.617-1.449 8.354 8.354 0 0 0 3.063-2.481"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714a2.25 2.25 0 0 0 .659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.43 1.43a2.25 2.25 0 0 0 1.59 3.82h13.68a2.25 2.25 0 0 0 1.59-3.82L19 14.5"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="blood-card-title">{{ block.settings.title }}</h3>
            <p class="blood-card-text">{{ block.settings.description }}</p>
            {%- if block.settings.markers != blank -%}
              <div class="blood-card-markers">
                {%- assign markers = block.settings.markers | split: ',' -%}
                {%- for m in markers -%}
                  <span class="blood-marker-pill">{{ m | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Process -->
    <div class="blood-process">
      <h2>{{ section.settings.process_heading }}</h2>
      <div class="blood-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="blood-step" {{ block.shopify_attributes }}>
              <span class="blood-step-num">{{ block.settings.number }}</span>
              <h3 class="blood-step-title">{{ block.settings.title }}</h3>
              <p class="blood-step-text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Price + CTA -->
    <div class="blood-price-teaser">
      <div class="blood-price-tag">{{ section.settings.price_text }}</div>
      <p class="blood-price-note">{{ section.settings.price_note }}</p>
    </div>

    <div class="blood-cta">
      <a href="{{ section.settings.cta_link }}" class="blood-cta-btn">
        {{ section.settings.cta_label }} &rarr;
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Juvantis: Bluttests",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Dein Blut weiß mehr, als du denkst."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitung",
      "default": "Ein Bloody Check bei Juvantis ist mehr als ein Blutbild beim Hausarzt. Wir analysieren bis zu 80+ Biomarker und visualisieren deine Ergebnisse in deinem persönlichen Digital Health Twin — verständlich, motivierend und medizinisch fundiert."
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "Kategorien-Überschrift",
      "default": "Unsere Check-up-Kategorien"
    },
    {
      "type": "text",
      "id": "process_heading",
      "label": "Ablauf-Überschrift",
      "default": "So funktioniert dein Bloody Check"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Preis-Teaser",
      "default": "Ab 45 EUR pro Check-up"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Preis-Hinweis",
      "default": "Einzelne Checks oder als Teil deines Komplett-Pakets"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-Button Text",
      "default": "Jetzt Bloody Check buchen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA-Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "label": "Abstand oben"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "label": "Abstand unten"
    }
  ],
  "blocks": [
    {
      "type": "checkup",
      "name": "Check-up Kategorie",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "🩸"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung"
        },
        {
          "type": "text",
          "id": "markers",
          "label": "Biomarker (kommagetrennt)"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Hervorgehoben",
          "default": false
        }
      ]
    },
    {
      "type": "step",
      "name": "Ablauf-Schritt",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Schritt-Nummer",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Juvantis: Bluttests"
    }
  ]
}
{% endschema %}