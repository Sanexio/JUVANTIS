{%- comment -%}
  Juvantis Section: SEO Content Page (wiederverwendbar)
  Zweck: Flexible Content-Seite fuer SEO-Landingpages
  Verwendet fuer: Grosses Blutbild, Standort, Infusionen, Longevity
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- assign seo_pages = 'grosses-blutbild,frankfurt,infusionen,longevity' | split: ',' -%}
{%- assign is_seo = false -%}
{%- for p in seo_pages -%}
  {%- if template.suffix == p -%}{%- assign is_seo = true -%}{%- endif -%}
{%- endfor -%}

{%- if is_seo -%}

{%- style -%}
  .jv-seo {
    --jv-teal: #028090;
    --jv-teal-light: #00A896;
    --jv-gradient: linear-gradient(135deg, #4ea1d9, #73c25e);
    --jv-text: #1a1a1a;
    --jv-text-sec: #555;
    --jv-bg: #ffffff;
    --jv-bg-subtle: #f8fafa;
    --jv-border: #e8ecec;
    --jv-radius: 1.4rem;
    font-family: var(--font-body-family, 'Anonymous Pro', monospace);
    -webkit-font-smoothing: antialiased;
    color: var(--jv-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  .jv-seo__container { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  /* Hero */
  .jv-seo__hero { text-align: center; padding: 3rem 0 2.5rem; }

  .jv-seo__badge {
    display: inline-flex;
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: 2rem;
    padding: 0.35rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--jv-teal);
    margin-bottom: 1.2rem;
  }

  .jv-seo__hero h1 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .jv-seo__hero-text {
    font-size: clamp(1rem, 2vw, 1.12rem);
    color: var(--jv-text-sec);
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Content blocks */
  .jv-seo__body { margin-bottom: 2rem; }

  .jv-seo__body h2 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
  }

  .jv-seo__body h3 {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.8rem 0 0.6rem;
  }

  .jv-seo__richtext {
    line-height: 1.75;
    font-size: 0.95rem;
    color: var(--jv-text-sec);
  }

  .jv-seo__richtext p { margin: 0 0 1rem; }
  .jv-seo__richtext ul, .jv-seo__richtext ol { margin: 0 0 1rem; padding-left: 1.5rem; }
  .jv-seo__richtext li { margin-bottom: 0.4rem; }

  .jv-seo__richtext a {
    color: var(--jv-teal);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  /* Highlight box */
  .jv-seo__highlight {
    background: var(--jv-gradient);
    color: #fff;
    border-radius: var(--jv-radius);
    padding: 2rem 2.5rem;
    margin: 2rem 0;
    text-align: center;
  }

  .jv-seo__highlight h2 {
    color: #fff;
    margin-top: 0;
    border: none;
  }

  .jv-seo__highlight p { color: rgba(255,255,255,0.9); margin: 0; }

  /* Info box */
  .jv-seo__info {
    background: var(--jv-bg-subtle);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 1.5rem 2rem;
    margin: 1.5rem 0;
  }

  .jv-seo__info p { margin: 0; }
  .jv-seo__info strong { color: var(--jv-text); }

  /* Bento cards grid */
  .jv-seo__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  @media (min-width: 750px) {
    .jv-seo__cards { grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr)); }
  }

  .jv-seo__card {
    background: var(--jv-bg);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: 1.8rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .jv-seo__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .jv-seo__card-icon { font-size: 2rem; margin-bottom: 0.6rem; display: block; }

  .jv-seo__card-title {
    font-family: var(--font-heading-family, 'Avenir Next', sans-serif);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }

  .jv-seo__card-text {
    font-size: 0.88rem;
    color: var(--jv-text-sec);
    line-height: 1.6;
    margin: 0;
  }

  /* Table */
  .jv-seo__table-wrap { overflow-x: auto; margin: 1.5rem 0; }

  .jv-seo__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 24rem;
    font-size: 0.9rem;
  }

  .jv-seo__table th, .jv-seo__table td {
    padding: 0.7rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--jv-border);
  }

  .jv-seo__table th {
    font-weight: 600;
    color: var(--jv-text);
    background: var(--jv-bg-subtle);
  }

  /* CTA */
  .jv-seo__cta { text-align: center; padding: 2rem 0 0; }

  .jv-seo__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--jv-gradient);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.9rem 2rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .jv-seo__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(78,161,217,0.3);
    color: #fff;
  }

  @supports (animation-timeline: view()) {
    .jv-seo__card, .jv-seo__highlight, .jv-seo__info {
      animation: jvSeoFade 0.6s ease both;
      animation-timeline: view();
      animation-range: entry 10% entry 40%;
    }
  }

  @keyframes jvSeoFade {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }
{%- endstyle -%}

<section
  class="jv-seo"
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;"
>
  <div class="jv-seo__container">

    <header class="jv-seo__hero">
      {%- if section.settings.badge != blank -%}
        <span class="jv-seo__badge">{{ section.settings.badge }}</span>
      {%- endif -%}
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="jv-seo__hero-text">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    <div class="jv-seo__body">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'heading' -%}
            <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

          {%- when 'subheading' -%}
            <h3 {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>

          {%- when 'richtext' -%}
            <div class="jv-seo__richtext" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>

          {%- when 'highlight' -%}
            <div class="jv-seo__highlight" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}<h2>{{ block.settings.title }}</h2>{%- endif -%}
              <p>{{ block.settings.text }}</p>
            </div>

          {%- when 'info' -%}
            <div class="jv-seo__info" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>

          {%- when 'card' -%}
            {%- comment -%} Cards sammeln sich im Grid {%- endcomment -%}

          {%- when 'table_row' -%}
            {%- comment -%} Table rows sammeln sich in Tabelle {%- endcomment -%}

        {%- endcase -%}

        {%- comment -%} Card Grid: Start bei erster Card, Ende bei letzter Card {%- endcomment -%}
        {%- if block.type == 'card' -%}
          {%- assign prev_idx = forloop.index0 | minus: 1 -%}
          {%- if prev_idx < 0 or section.blocks[prev_idx].type != 'card' -%}
            <div class="jv-seo__cards">
          {%- endif -%}
          <div class="jv-seo__card" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="jv-seo__card-icon">{{ block.settings.icon }}</span>
            {%- endif -%}
            <h3 class="jv-seo__card-title">{{ block.settings.title }}</h3>
            <p class="jv-seo__card-text">{{ block.settings.description }}</p>
          </div>
          {%- assign next_idx = forloop.index -%}
          {%- if next_idx >= section.blocks.size or section.blocks[next_idx].type != 'card' -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Table: Start bei erster Row, Ende bei letzter Row {%- endcomment -%}
        {%- if block.type == 'table_row' -%}
          {%- assign prev_idx = forloop.index0 | minus: 1 -%}
          {%- if prev_idx < 0 or section.blocks[prev_idx].type != 'table_row' -%}
            <div class="jv-seo__table-wrap"><table class="jv-seo__table">
              <thead><tr>
                <th>{{ section.settings.table_col1 }}</th>
                <th>{{ section.settings.table_col2 }}</th>
                {%- if section.settings.table_col3 != blank -%}<th>{{ section.settings.table_col3 }}</th>{%- endif -%}
              </tr></thead><tbody>
          {%- endif -%}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.col1 }}</td>
            <td>{{ block.settings.col2 }}</td>
            {%- if section.settings.table_col3 != blank -%}<td>{{ block.settings.col3 }}</td>{%- endif -%}
          </tr>
          {%- assign next_idx = forloop.index -%}
          {%- if next_idx >= section.blocks.size or section.blocks[next_idx].type != 'table_row' -%}
            </tbody></table></div>
          {%- endif -%}
        {%- endif -%}

      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="jv-seo__cta">
        <a href="{{ section.settings.cta_link }}" class="jv-seo__cta-btn">{{ section.settings.cta_label }} &rarr;</a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: SEO Page",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge" },
    { "type": "text", "id": "heading", "label": "H1 Ueberschrift" },
    { "type": "textarea", "id": "intro", "label": "Einleitung" },
    { "type": "text", "id": "table_col1", "label": "Tabelle Spalte 1", "default": "Parameter" },
    { "type": "text", "id": "table_col2", "label": "Tabelle Spalte 2", "default": "Wert" },
    { "type": "text", "id": "table_col3", "label": "Tabelle Spalte 3 (optional)" },
    { "type": "text", "id": "cta_label", "label": "CTA-Text" },
    { "type": "url", "id": "cta_link", "label": "CTA-Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    { "type": "heading", "name": "Ueberschrift (H2)", "settings": [
      { "type": "text", "id": "text", "label": "Text" }
    ]},
    { "type": "subheading", "name": "Unterueberschrift (H3)", "settings": [
      { "type": "text", "id": "text", "label": "Text" }
    ]},
    { "type": "richtext", "name": "Textabschnitt", "settings": [
      { "type": "richtext", "id": "content", "label": "Inhalt" }
    ]},
    { "type": "highlight", "name": "Highlight-Box", "settings": [
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]},
    { "type": "info", "name": "Info-Hinweis", "settings": [
      { "type": "richtext", "id": "content", "label": "Inhalt" }
    ]},
    { "type": "card", "name": "Karte (Bento)", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (Emoji)" },
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "description", "label": "Text" }
    ]},
    { "type": "table_row", "name": "Tabellenzeile", "settings": [
      { "type": "text", "id": "col1", "label": "Spalte 1" },
      { "type": "text", "id": "col2", "label": "Spalte 2" },
      { "type": "text", "id": "col3", "label": "Spalte 3" }
    ]}
  ],
  "presets": [{ "name": "Juvantis: SEO Page" }]
}
{% endschema %}
