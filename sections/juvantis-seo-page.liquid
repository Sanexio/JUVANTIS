{%- comment -%}
  Juvantis Section: SEO Content Page (wiederverwendbar)
  Zweck: Flexible Content-Seite fuer SEO-Landingpages
  Verwendet fuer: Grosses Blutbild, Standort, Infusionen, Longevity
  Design: Apple-inspired Design System
  Erstellt: 2026-04-04
{%- endcomment -%}

{%- assign seo_pages = 'grosses-blutbild,frankfurt,infusionen,longevity' | split: ',' -%}
{%- assign is_seo = false -%}
{%- for p in seo_pages -%}
  {%- if template.suffix == p -%}{%- assign is_seo = true -%}{%- endif -%}
{%- endfor -%}

{%- if is_seo -%}

{%- style -%}
  #SeoPage-{{ section.id }} {
    --apple-text: #1d1d1f;
    --apple-text-secondary: #6e6e73;
    --apple-text-tertiary: #86868b;
    --apple-link: #0071e3;
    --apple-bg-gray: #f5f5f7;
    --apple-bg-white: #fff;
    --apple-font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-family: var(--apple-font);
    -webkit-font-smoothing: antialiased;
    color: var(--apple-text);
  }

  .main-page-title.page-title { display: none !important; }
  .page-width--narrow { padding: 0 !important; margin: 0 !important; max-width: none !important; }

  #SeoPage-{{ section.id }} .seo-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  #SeoPage-{{ section.id }} .seo-hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  #SeoPage-{{ section.id }} .seo-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--apple-text-tertiary);
    margin-bottom: 1.6rem;
  }

  #SeoPage-{{ section.id }} .seo-hero h1 {
    font-family: var(--apple-font);
    font-size: clamp(3.6rem, 6vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.6rem;
    color: var(--apple-text);
  }

  #SeoPage-{{ section.id }} .seo-hero-text {
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
    max-width: 48rem;
    margin: 0 auto;
    line-height: 1.53;
  }

  /* Content body */
  #SeoPage-{{ section.id }} .seo-body {
    margin-bottom: 2rem;
  }

  #SeoPage-{{ section.id }} .seo-body h2 {
    font-family: var(--apple-font);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.07;
    margin: 4rem 0 1.6rem;
    color: var(--apple-text);
  }

  #SeoPage-{{ section.id }} .seo-body h3 {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 2.4rem 0 1rem;
    color: var(--apple-text);
  }

  #SeoPage-{{ section.id }} .seo-richtext {
    line-height: 1.53;
    font-size: 1.7rem;
    color: var(--apple-text-secondary);
  }

  #SeoPage-{{ section.id }} .seo-richtext p {
    margin: 0 0 1.4rem;
  }

  #SeoPage-{{ section.id }} .seo-richtext ul,
  #SeoPage-{{ section.id }} .seo-richtext ol {
    margin: 0 0 1.4rem;
    padding-left: 2rem;
  }

  #SeoPage-{{ section.id }} .seo-richtext li {
    margin-bottom: 0.6rem;
  }

  #SeoPage-{{ section.id }} .seo-richtext a {
    color: var(--apple-link);
    text-decoration: none;
  }

  #SeoPage-{{ section.id }} .seo-richtext a:hover {
    text-decoration: underline;
  }

  /* Highlight box */
  #SeoPage-{{ section.id }} .seo-highlight {
    background: var(--apple-text);
    color: #fff;
    border-radius: 2rem;
    padding: 3.2rem 3.6rem;
    margin: 3rem 0;
    text-align: center;
  }

  #SeoPage-{{ section.id }} .seo-highlight h2 {
    color: #fff;
    margin-top: 0;
    font-size: 2.4rem;
    letter-spacing: -0.025em;
  }

  #SeoPage-{{ section.id }} .seo-highlight p {
    color: rgba(255,255,255,0.82);
    font-size: 1.7rem;
    line-height: 1.53;
    margin: 0;
  }

  /* Info box */
  #SeoPage-{{ section.id }} .seo-info {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 2.4rem 2.8rem;
    margin: 2rem 0;
    font-size: 1.5rem;
    line-height: 1.53;
    color: var(--apple-text-secondary);
  }

  #SeoPage-{{ section.id }} .seo-info p { margin: 0; }
  #SeoPage-{{ section.id }} .seo-info strong { color: var(--apple-text); }

  /* Card grid */
  #SeoPage-{{ section.id }} .seo-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin: 2.4rem 0;
  }

  @media (min-width: 750px) {
    #SeoPage-{{ section.id }} .seo-cards {
      grid-template-columns: repeat(auto-fit, minmax(min(22rem, 100%), 1fr));
    }
  }

  #SeoPage-{{ section.id }} .seo-card {
    background: var(--apple-bg-gray);
    border-radius: 2rem;
    padding: 2.4rem;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #SeoPage-{{ section.id }} .seo-card:hover {
    transform: scale(1.02);
    box-shadow: 0 1.2rem 4rem rgba(0,0,0,0.08);
  }

  #SeoPage-{{ section.id }} .seo-card-icon {
    width: 4.8rem;
    height: 4.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.02);
    border-radius: 1.4rem;
    margin-bottom: 1.2rem;
  }

  #SeoPage-{{ section.id }} .seo-card-icon svg {
    width: 2.4rem;
    height: 2.4rem;
    color: var(--apple-text);
  }

  #SeoPage-{{ section.id }} .seo-card-title {
    font-family: var(--apple-font);
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 0.6rem;
    color: var(--apple-text);
  }

  #SeoPage-{{ section.id }} .seo-card-text {
    font-size: 1.5rem;
    color: var(--apple-text-secondary);
    line-height: 1.53;
    margin: 0;
  }

  /* Table */
  #SeoPage-{{ section.id }} .seo-table-wrap {
    overflow-x: auto;
    margin: 2rem 0;
    border-radius: 2rem;
    overflow: hidden;
  }

  #SeoPage-{{ section.id }} .seo-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 28rem;
    font-size: 1.5rem;
  }

  #SeoPage-{{ section.id }} .seo-table th,
  #SeoPage-{{ section.id }} .seo-table td {
    padding: 1.2rem 1.6rem;
    text-align: left;
  }

  #SeoPage-{{ section.id }} .seo-table th {
    font-weight: 600;
    background: var(--apple-text);
    color: #fff;
    border-bottom: none;
  }

  #SeoPage-{{ section.id }} .seo-table td {
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--apple-text-secondary);
  }

  #SeoPage-{{ section.id }} .seo-table tbody tr:last-child td {
    border-bottom: none;
  }

  #SeoPage-{{ section.id }} .seo-table tbody tr:nth-child(even) {
    background: var(--apple-bg-gray);
  }

  /* CTA */
  #SeoPage-{{ section.id }} .seo-cta {
    text-align: center;
    padding: 3rem 0 0;
  }

  #SeoPage-{{ section.id }} .seo-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--apple-link);
    color: #fff;
    font-weight: 600;
    font-size: 1.7rem;
    padding: 1.2rem 2.4rem;
    border-radius: 98rem;
    text-decoration: none;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #SeoPage-{{ section.id }} .seo-cta-btn:hover {
    opacity: 0.88;
    color: #fff;
  }

  /* Animations */
  #SeoPage-{{ section.id }} .seo-animate {
    opacity: 0;
    transform: translateY(1.6rem);
    animation: seoFadeIn-{{ section.id }} 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  #SeoPage-{{ section.id }} .seo-animate:nth-child(1) { animation-delay: 0s; }
  #SeoPage-{{ section.id }} .seo-animate:nth-child(2) { animation-delay: 0.12s; }
  #SeoPage-{{ section.id }} .seo-animate:nth-child(3) { animation-delay: 0.24s; }
  #SeoPage-{{ section.id }} .seo-animate:nth-child(4) { animation-delay: 0.36s; }
  #SeoPage-{{ section.id }} .seo-animate:nth-child(5) { animation-delay: 0.48s; }
  #SeoPage-{{ section.id }} .seo-animate:nth-child(6) { animation-delay: 0.60s; }

  @keyframes seoFadeIn-{{ section.id }} {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mobile adjustments */
  @media (max-width: 749px) {
    #SeoPage-{{ section.id }} .seo-hero { padding: 3rem 0 2rem; }
    #SeoPage-{{ section.id }} .seo-highlight { padding: 2.4rem 2rem; }
    #SeoPage-{{ section.id }} .seo-card { padding: 2rem; }
  }
{%- endstyle -%}

<section
  id="SeoPage-{{ section.id }}"
  class="page-width section-{{ section.id }}-padding"
  style="padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;"
>
  <div class="seo-container">

    <header class="seo-hero">
      {%- if section.settings.badge != blank -%}
        <span class="seo-label">{{ section.settings.badge }}</span>
      {%- endif -%}
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="seo-hero-text">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    <div class="seo-body">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'heading' -%}
            <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

          {%- when 'subheading' -%}
            <h3 {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>

          {%- when 'richtext' -%}
            <div class="seo-richtext" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>

          {%- when 'highlight' -%}
            <div class="seo-highlight seo-animate" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}<h2>{{ block.settings.title }}</h2>{%- endif -%}
              <p>{{ block.settings.text }}</p>
            </div>

          {%- when 'info' -%}
            <div class="seo-info seo-animate" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>

          {%- when 'card' -%}
            {%- comment -%} Cards sammeln sich im Grid {%- endcomment -%}

          {%- when 'table_row' -%}
            {%- comment -%} Table rows sammeln sich in Tabelle {%- endcomment -%}

        {%- endcase -%}

        {%- comment -%} Card Grid: Start bei erster Card, Ende bei letzter Card {%- endcomment -%}
        {%- if block.type == 'card' -%}
          {%- assign prev_idx = forloop.index0 | minus: 1 -%}
          {%- if prev_idx < 0 or section.blocks[prev_idx].type != 'card' -%}
            <div class="seo-cards">
          {%- endif -%}
          <div class="seo-card seo-animate" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="seo-card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
            {%- endif -%}
            <h3 class="seo-card-title">{{ block.settings.title }}</h3>
            <p class="seo-card-text">{{ block.settings.description }}</p>
          </div>
          {%- assign next_idx = forloop.index -%}
          {%- if next_idx >= section.blocks.size or section.blocks[next_idx].type != 'card' -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Table: Start bei erster Row, Ende bei letzter Row {%- endcomment -%}
        {%- if block.type == 'table_row' -%}
          {%- assign prev_idx = forloop.index0 | minus: 1 -%}
          {%- if prev_idx < 0 or section.blocks[prev_idx].type != 'table_row' -%}
            <div class="seo-table-wrap"><table class="seo-table">
              <thead><tr>
                <th>{{ section.settings.table_col1 }}</th>
                <th>{{ section.settings.table_col2 }}</th>
                {%- if section.settings.table_col3 != blank -%}<th>{{ section.settings.table_col3 }}</th>{%- endif -%}
              </tr></thead><tbody>
          {%- endif -%}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.col1 }}</td>
            <td>{{ block.settings.col2 }}</td>
            {%- if section.settings.table_col3 != blank -%}<td>{{ block.settings.col3 }}</td>{%- endif -%}
          </tr>
          {%- assign next_idx = forloop.index -%}
          {%- if next_idx >= section.blocks.size or section.blocks[next_idx].type != 'table_row' -%}
            </tbody></table></div>
          {%- endif -%}
        {%- endif -%}

      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="seo-cta">
        <a href="{{ section.settings.cta_link }}" class="seo-cta-btn">{{ section.settings.cta_label }} &rarr;</a>
      </div>
    {%- endif -%}

  </div>
</section>

<style media="screen and (min-width: 750px)">
  #SeoPage-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
</style>

{%- endif -%}

{% schema %}
{
  "name": "Juvantis: SEO Page",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge" },
    { "type": "text", "id": "heading", "label": "H1 Ueberschrift" },
    { "type": "textarea", "id": "intro", "label": "Einleitung" },
    { "type": "text", "id": "table_col1", "label": "Tabelle Spalte 1", "default": "Parameter" },
    { "type": "text", "id": "table_col2", "label": "Tabelle Spalte 2", "default": "Wert" },
    { "type": "text", "id": "table_col3", "label": "Tabelle Spalte 3 (optional)" },
    { "type": "text", "id": "cta_label", "label": "CTA-Text" },
    { "type": "url", "id": "cta_link", "label": "CTA-Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "default": 0, "label": "Abstand oben" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "default": 52, "label": "Abstand unten" }
  ],
  "blocks": [
    { "type": "heading", "name": "Ueberschrift (H2)", "settings": [
      { "type": "text", "id": "text", "label": "Text" }
    ]},
    { "type": "subheading", "name": "Unterueberschrift (H3)", "settings": [
      { "type": "text", "id": "text", "label": "Text" }
    ]},
    { "type": "richtext", "name": "Textabschnitt", "settings": [
      { "type": "richtext", "id": "content", "label": "Inhalt" }
    ]},
    { "type": "highlight", "name": "Highlight-Box", "settings": [
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]},
    { "type": "info", "name": "Info-Hinweis", "settings": [
      { "type": "richtext", "id": "content", "label": "Inhalt" }
    ]},
    { "type": "card", "name": "Karte (Bento)", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (Emoji)" },
      { "type": "text", "id": "title", "label": "Titel" },
      { "type": "textarea", "id": "description", "label": "Text" }
    ]},
    { "type": "table_row", "name": "Tabellenzeile", "settings": [
      { "type": "text", "id": "col1", "label": "Spalte 1" },
      { "type": "text", "id": "col2", "label": "Spalte 2" },
      { "type": "text", "id": "col3", "label": "Spalte 3" }
    ]}
  ],
  "presets": [{ "name": "Juvantis: SEO Page" }]
}
{% endschema %}