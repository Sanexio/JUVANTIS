    "praxis_leistungen": {
      "type": "juvantis-praxis-leistungen",
      "settings": {
        "heading": "Unsere Leistungen",
        "description": "Umfassende hausärztliche und internistische Versorgung mit modernster Diagnostik. Komplette Risikoanalyse an einem Tag möglich – Dauer ca. 2–3 Stunden.",
        "color_scheme": "background-1",
        "padding_top": 40,
        "padding_bottom": 40
      },
      "blocks": {
        "svc-checkup": {
          "type": "service",
          "settings": {
            "icon": "🩺",
            "name": "Gesundheits Check-Up",
            "description": "Komplette Risikoanalyse an einem Tag (2–3 Std.): Kardio-Block, Angio-Block, Gastro-Block und Nephro-Block. Labor sollte 2 Tage vorher abgenommen werden.",
            "category": "Gesundheits Check-Ups"
          }
        },
        "svc-cardio": {
          "type": "service",
          "settings": {
            "icon": "🫀",
            "name": "Cardio Check-Up",
            "description": "Ausführliche kardiovaskuläre Analyse (ca. 2 Std.): Körperliche Untersuchung, Blutentnahme, Echokardiografie, Ergometrie und Spirometrie.",
            "category": "Gesundheits Check-Ups"
          }
        },
        "svc-angio": {
          "type": "service",
          "settings": {
            "icon": "🩸",
            "name": "Angio Check-Up",
            "description": "Gefäß-Screening: Carotis Duplex, Bauchaorten-Screening, Knöchel-Arm-Index (ABI) und Duplex der Beingefäße.",
            "category": "Gesundheits Check-Ups"
          }
        },
        "svc-tumor": {
          "type": "service",
          "settings": {
            "icon": "🔬",
            "name": "Tumorscreening",
            "description": "Umfassender als das Standard-Vorsorgeprogramm: Ultraschall von Schilddrüse und inneren Organen zur Früherkennung.",
            "category": "Gesundheits Check-Ups"
          }
        },
        "svc-echo": {
          "type": "service",
          "settings": {
            "icon": "💓",
            "name": "Echokardiographie",
            "description": "Herzultraschall zur Beurteilung von Pumpfunktion, Herzklappen und Wandbewegungsstörungen. Bei Herzgeräuschen, Infarkt-Verdacht, Herzinsuffizienz.",
            "category": "Ultraschalldiagnostik"
          }
        },
        "svc-carotis": {
          "type": "service",
          "settings": {
            "icon": "🔍",
            "name": "Carotis Duplex",
            "description": "Ultraschall der Halsschlagadern: Intima-Media-Komplex, Plaque-Darstellung. Farbkodierte Duplexsonografie zeigt Einengungen und Verschlüsse.",
            "category": "Ultraschalldiagnostik"
          }
        },
        "svc-schilddruese": {
          "type": "service",
          "settings": {
            "icon": "🦋",
            "name": "Schilddrüsen-Sonographie",
            "description": "Ultraschall der Schilddrüse: Erkennung von Struma, Knoten und bösartigen Veränderungen. Bei Bedarf Weiterleitung zu Szintigrafie oder Feinnadelpunktion.",
            "category": "Ultraschalldiagnostik"
          }
        },
        "svc-bein": {
          "type": "service",
          "settings": {
            "icon": "🦵",
            "name": "Ultraschall Beingefäße",
            "description": "ABI (Knöchel-Arm-Index) zur Erkennung der Schaufensterkrankheit. Duplex der Beingefäße bei Thrombose-Verdacht und Durchblutungsstörungen.",
            "category": "Ultraschalldiagnostik"
          }
        },
        "svc-sono": {
          "type": "service",
          "settings": {
            "icon": "📱",
            "name": "Abdominelle Sonographie",
            "description": "Ultraschall des Bauchraums: Leber, Gallenwege, Bauchspeicheldrüse, Milz, Gefäße, Darm, Nieren, Prostata/Gebärmutter sowie Bewegungsapparat.",
            "category": "Ultraschalldiagnostik"
          }
        },
        "svc-belastung": {
          "type": "service",
          "settings": {
            "icon": "🏃",
            "name": "Belastungs-EKG",
            "description": "Ergometrie: Provokation einer Minderdurchblutung unter Belastung zur Erkennung von Verkalkungen der Herzkranzgefäße im EKG.",
            "category": "Weitere Leistungen"
          }
        },
        "svc-lunge": {
          "type": "service",
          "settings": {
            "icon": "🫁",
            "name": "Lungenfunktion",
            "description": "Spirometrie bei Atemwegserkrankungen (COPD, Asthma), chronischem Husten, präoperativ und arbeitsmedizinisch. Teil des großen Check-Up.",
            "category": "Weitere Leistungen"
          }
        },
        "svc-labor": {
          "type": "service",
          "settings": {
            "icon": "🧪",
            "name": "Labordiagnostik",
            "description": "Blutbild, Nierenfunktion, Leberwerte, Schilddrüse, Herzenzyme, Cholesterin, HbA1C, Tumormarker, Borrelien, Rheumafaktoren, Impfstatus und vieles mehr.",
            "category": "Weitere Leistungen"
          }
        },
        "svc-impfung": {
          "type": "service",
          "settings": {
            "icon": "💉",
            "name": "Impfungen",
            "description": "Impfbuch-Check per Zusendung, individueller Impfplan mit automatischer Terminerinnerung. Influenza, Pneumokokken, FSME, Hepatitis, Reiseimpfungen.",
            "category": "Weitere Leistungen"
          }
        }
      },
      "block_order": [
