ap = document.createElement(\"div\");\n    wrap.style.borderRadius = \"14px\";\n    wrap.style.overflow = \"hidden\";\n    wrap.appendChild(iframe);\n\n    card.innerHTML = \"\";\n    card.appendChild(wrap);\n\n    var p = document.createElement(\"p\");\n    p.className = \"jl-map__addr\";\n    p.innerHTML =\n      address + ' – ' +\n      '<a class=\"jl-map__link\" target=\"_blank\" rel=\"noopener\" href=\"https://www.google.com/maps/search/?api=1&query=' +\n      encodeURIComponent(address) + '\">Route planen</a>';\n    card.appendChild(p);\n  };\n</script>\n\n<style>\n  .jl-map {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 16px;\n  }\n\n  .jl-map__title {\n    margin: 0 0 12px;\n    text-align: center;\n  }\n\n  .jl-map__card {\n    border: 1px solid rgba(0,0,0,.12);\n    border-radius: 14px;\n    padding: 16px;\n    text-align: center;\n  }\n\n  .jl-map__text {\n    margin: 0 0 12px;\n  }\n\n  .jl-map__actions {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 12px;\n    flex-wrap: wrap;\n    margin-bottom: 10px;\n  }\n\n  .jl-map__btn {\n    padding: 10px 18px;\n    border-radius: 10px;\n    border: none;\n    cursor: pointer;\n  }\n\n  .jl-map__link {\n    text-decoration: underline;\n    white-space: nowrap;\n  }\n\n  .jl-map__addr {\n    margin: 8px 0 0;\n    font-size: 0.95rem;\n    opacity: 0.9;\n  }\n</style>",
