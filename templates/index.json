      "blocks": {
        "doctor-stracke": {
          "type": "doctor",
          "settings": {
            "name": "Dr. med. Siegbert Stracke, MBA",
            "title": "Facharzt Innere Medizin, Notfall- und Intensivmedizin",
            "qualifications": "Gesundheitsökonom, MBA Healthcare Management (EBS)\nCEO Sanexio GmbH\nPrivate Equity Advisor (EBS)",
            "bio": "Der Überzeugung folgend, dass zur Bewältigung zukünftiger Herausforderungen im Gesundheitswesen und zur Verbesserung der Patientenversorgung neue Wege der Organisation von Informationen inklusive des produktiven Umganges mit dem vorhandenen Wissen nötig sein werden, bringt Siegbert Stracke seine Expertise aus langjähriger klinischer Erfahrung und Kenntnissen aus dem informationstechnischen Bereich in die Praxis ein.",
            "career": "<p><strong>Seit 01/2013:</strong> Geschäftsführender Gesellschafter Sanexio GmbH – Digitale Lösungen im Gesundheitswesen und Big Data Management</p><p><strong>11/2021–heute:</strong> Private Equity Advisor (EBS)</p><p><strong>01/2013–12/2018:</strong> Freiberuflicher Arzt, Schwerpunkt Notaufnahmen</p><p><strong>01/2010–12/2012:</strong> Medizinische Klinik, Universitätsklinikum Gießen</p><p><strong>01/2008–12/2009:</strong> Notarzt am Standort Uniklinikum Gießen</p><p><strong>04/2007–12/2009:</strong> Kardiologische und pulmologische Intensivstation, Med. Klinik I</p><p><strong>02/2005–04/2007:</strong> Ambulanz, Herzkatheterlabor, Intermediate-Care Station</p>",
            "education": "<p><strong>09/2011–09/2012:</strong> MBA Health Care Management, European Business School – OAM: very good. Thesis: „Der Terminkontrakthandel als Risikoinstrument für die Beteiligten im Gesundheitswesen“. Auslandssemester University of Stellenbosch, Cape Town</p><p><strong>09/2010–09/2011:</strong> Gesundheitsökonom, EBS – Note: sehr gut (ECTS A)</p><p><strong>2008:</strong> Gasthörer Wirtschaftsinformatik, FernUni Hagen</p><p><strong>10/1998–10/2004:</strong> Studium der Medizin, JLU Gießen – Staatsexamen &amp; Approbation, Note: sehr gut. Promotion: „Laser-Doppler-Fluxmetrie bei Osteoporose“</p><p><strong>10/1998–10/2000:</strong> Gasthörer Mathematik, JLU Gießen</p>",
            "doctolib_url": "https://www.doctolib.de/praxis/frankfurt-am-main/praxis-dr-stracke-und-kollegen"
          }
        },
        "doctor-saul": {
          "type": "doctor",
          "settings": {
            "name": "Docteur en méd. Sonja Saul",
            "title": "Fachärztin für Allgemeinmedizin",
            "qualifications": "Ultraschalldiagnostik Zertifikat I und II (SEECO)\nMaster Péritaje y valoración de daños corporales (Universität Barcelona)\nSprachen: Deutsch, Englisch, Französisch, Spanisch",
            "bio": "Nach einer Kindheit zwischen Deutschland, Frankreich und Belgien, Abitur an der Europaschule in Brüssel mit anschließendem Medizinstudium in der Université Catholique de Louvain ist für Sonja Saul eine Anamnese in deutsch, englisch, französisch und spanisch kein Problem. Mehr als 15 Jahre Berufserfahrung, zuletzt als leitende Oberärztin in Spanien tätig.",
            "career": "<p><strong>10/2019–04/2020:</strong> Haus- und Facharztzentrum Sachsenhausen, Frankfurt – Hospitation</p><p><strong>2018–2019:</strong> MC Mutual, Madrid – Leitende Oberärztin für Kliniken in Extremadura und Kastilien und León</p><p><strong>2010–2018:</strong> MC Mutual, Madrid – Referent Ultraschalldiagnostik (1.200+ Untersuchungen/Jahr)</p><p><strong>2007–2009:</strong> Private Praxis CENSALUD, Madrid – Allgemeinmedizin, Schwerpunkt ausländische Patienten</p><p><strong>2004–2007:</strong> IMSALUD Madrid – Angestellte Fachärztin</p><p><strong>2002–2005:</strong> Hospital San Rafael Madrid – Notaufnahme Pädiatrie</p><p><strong>2003–2004:</strong> IMSALUD – 2. Jahr Facharztausbildung</p><p><strong>2002–2003:</strong> Praxis Dres. Beucken et Bouffesile, Brüssel – 1. Jahr Facharztausbildung</p>",
            "education": "<p><strong>2005–2018:</strong> SEECO Spanien – Ultraschalldiagnostik Zertifikat I und II</p><p><strong>2006–2007:</strong> Universidad de Barcelona (virtual) – Master „Péritaje y valoración de daños corporales“</p><p><strong>2001–2004:</strong> UCL Belgien – Facharzt für Allgemeinmedizin</p><p><strong>1994–2002:</strong> Université Catholique de Louvain, Belgien – Studium der Medizin, cum laudum</p><p><strong>1991–1994:</strong> Europaschule Brüssel – Europäisches Abitur, deutsche Sektion (1,2)</p>"
          }
        }
