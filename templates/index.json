    "custom_liquid_GMmLqR": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% assign address_text = \"Grüneburgweg 12, 60322 Frankfurt am Main\" %}\n{% assign gmaps_embed_src = \"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2558.1429956777915!2d8.671594477038234!3d50.12104611102635!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47bd0eb3754111f3%3A0x9c1779561d464c64!2sGr%C3%BCneburgweg%2012%2C%2060322%20Frankfurt%20am%20Main!5e0!3m2!1sde!2sde!4v1767805053331!5m2!1sde!2sde\" %}\n\n{%- comment -%}\nUID ohne section.id, damit es in jedem Theme/Custom-Liquid zuverlässig ist.\n{%- endcomment -%}\n{% assign map_uid = 'now' | date: '%s' %}\n\n<div class=\"jl-map\" data-map-uid=\"{{ map_uid }}\">\n  <h2 class=\"jl-map__title\">Standort</h2>\n\n  <div class=\"jl-map__card\" id=\"jl-map-card-{{ map_uid }}\">\n    <p class=\"jl-map__text\">\n      Zur Anzeige der Karte wird eine Verbindung zu Google Maps hergestellt.\n    </p>\n\n    <div class=\"jl-map__actions\">\n      <button\n        type=\"button\"\n        class=\"jl-map__btn\"\n        onclick=\"jlLoadMap('{{ map_uid }}','{{ gmaps_embed_src }}','{{ address_text | escape }}')\">\n        Karte anzeigen\n      </button>\n\n      <a class=\"jl-map__link\"\n         href=\"https://www.google.com/maps/search/?api=1&query={{ address_text | url_encode }}\"\n         target=\"_blank\" rel=\"noopener\">\n        Route planen\n      </a>\n    </div>\n\n    <p class=\"jl-map__addr\">{{ address_text }}</p>\n  </div>\n</div>\n\n<script>\n  // Global, damit iOS/Safari zuverlässig über onclick auslöst\n  window.jlLoadMap = window.jlLoadMap || function(uid, src, address) {\n    var card = document.getElementById(\"jl-map-card-\" + uid);\n    if (!card) return;\n\n    var iframe = document.createElement(\"iframe\");\n    iframe.src = src;\n    iframe.width = \"100%\";\n    iframe.height = \"420\";\n    iframe.style.border = \"0\";\n    iframe.loading = \"lazy\";\n    iframe.referrerPolicy = \"no-referrer-when-downgrade\";\n    iframe.allowFullscreen = true;\n\n    var wrap = document.createElement(\"div\");\n    wrap.style.borderRadius = \"14px\";\n    wrap.style.overflow = \"hidden\";\n    wrap.appendChild(iframe);\n\n    card.innerHTML = \"\";\n    card.appendChild(wrap);\n\n    var p = document.createElement(\"p\");\n    p.className = \"jl-map__addr\";\n    p.innerHTML =\n      address + ' – ' +\n      '<a class=\"jl-map__link\" target=\"_blank\" rel=\"noopener\" href=\"https://www.google.com/maps/search/?api=1&query=' +\n      encodeURIComponent(address) + '\">Route planen</a>';\n    card.appendChild(p);\n  };\n</script>\n\n<style>\n  .jl-map {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 16px;\n  }\n\n  .jl-map__title {\n    margin: 0 0 12px;\n    text-align: center;\n  }\n\n  .jl-map__card {\n    border: 1px solid rgba(0,0,0,.12);\n    border-radius: 14px;\n    padding: 16px;\n    text-align: center;\n  }\n\n  .jl-map__text {\n    margin: 0 0 12px;\n  }\n\n  .jl-map__actions {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 12px;\n    flex-wrap: wrap;\n    margin-bottom: 10px;\n  }\n\n  .jl-map__btn {\n    padding: 10px 18px;\n    border-radius: 10px;\n    border: none;\n    cursor: pointer;\n  }\n\n  .jl-map__link {\n    text-decoration: underline;\n    white-space: nowrap;\n  }\n\n  .jl-map__addr {\n    margin: 8px 0 0;\n    font-size: 0.95rem;\n    opacity: 0.9;\n  }\n</style>",
        "color_scheme": "background-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
